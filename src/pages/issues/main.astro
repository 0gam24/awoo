---
// 레거시 라우트 — Cloudflare Pages _redirects 가 301 처리.
// 캐시되지 않은 직접 접근에 대비한 클라이언트 fallback.
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <title>오늘의 이슈 — 지원금가이드</title>
    <meta http-equiv="refresh" content="0; url=/issues/" />
    <link rel="canonical" href="https://awoo.or.kr/issues/" />
    <meta name="robots" content="noindex" />
  </head>
  <body>
    <p>
      <a href="/issues/">오늘의 이슈로 이동 →</a>
    </p>
    <script>
      window.location.replace('/issues/');
    </script>
  </body>
</html>
