---
import BlufBox from '@/components/BlufBox.astro';
import Container from '@/components/Container.astro';
import Icon from '@/components/Icon.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { CATEGORIES, formatWon } from '@/data/site-data';
import todayIssue from '@/data/today-issue.json';
import { buildCollectionPage } from '@/lib/schema';
import { type GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';

interface SourceArticle {
  title: string;
  link: string;
  pubDate?: string;
  pubDateKR?: string;
  publisher?: string;
}

interface HistoryEntry {
  firstSeen: string;
  lastSeen: string;
  totalCount: number;
  daysActive: number;
  dailyCounts: Record<string, number>;
  postSlug?: string;
}

interface PostData {
  title: string;
  slug: string;
  metaDescription: string;
  category: string;
  date: string;
  publishedAt: string;
  tldr?: string[];
  freshness?: { trendingTerm: string; daysActive: number; totalCount: number; rankToday: number };
}

export const getStaticPaths = (() => {
  const histModules = import.meta.glob<{ default: { byTerm?: Record<string, HistoryEntry> } }>(
    '/src/data/issues/_history.json',
    { eager: true },
  );
  const history = Object.values(histModules)[0]?.default ?? { byTerm: {} };
  const byTerm = history.byTerm ?? {};

  // 포스트 데이터 미리 로드 → term 페이지에서 빠른 매칭
  const postModules = import.meta.glob<{ default: PostData }>(
    '/src/data/issues/*/*.json',
    { eager: true },
  );
  const postsByDate: Record<string, PostData[]> = {};
  for (const [path, mod] of Object.entries(postModules)) {
    const m = path.match(/\/issues\/(\d{4}-\d{2}-\d{2})\/([^/]+)\.json$/);
    if (!m) continue;
    const slug = m[2];
    const date = m[1];
    if (!slug || !date || slug.startsWith('_')) continue;
    if (!postsByDate[date]) postsByDate[date] = [];
    postsByDate[date]!.push(mod.default);
  }

  // 활성 term (totalCount ≥ 1) 정렬 — Cycle #9: 1:1 매핑 보장
  const activeTopics = Object.entries(byTerm)
    .filter(([, e]) => e.totalCount >= 1)
    .sort((a, b) => b[1].totalCount - a[1].totalCount)
    .map(([t, e]) => ({ term: t, totalCount: e.totalCount, daysActive: e.daysActive }));

  // term 별 페이지 생성 — Cycle #9: 모든 트렌딩 키워드 hub 보장 (thin은 noindex)
  const paths = [];
  for (const [term, entry] of Object.entries(byTerm)) {
    if (entry.totalCount < 1) continue;
    // 매칭 포스트 찾기 (postSlug 우선)
    let post: PostData | undefined;
    if (entry.postSlug) {
      const dayPosts = postsByDate[entry.firstSeen] ?? [];
      post = dayPosts.find((p) => p.slug === entry.postSlug);
    }
    // 현재 term을 제외한 다른 토픽 8개
    const otherTopics = activeTopics.filter((t) => t.term !== term).slice(0, 8);
    paths.push({
      params: { term },
      props: { term, entry, post: post ?? null, otherTopics },
    });
  }
  return paths;
}) satisfies GetStaticPaths;

const { term, entry, post, otherTopics } = Astro.props as {
  term: string;
  entry: HistoryEntry;
  post: PostData | null;
  otherTopics: Array<{ term: string; totalCount: number; daysActive: number }>;
};

// term이 포함된 지원금 매칭 — Cycle #11 P1-6: 매칭 점수 산정 (배지용)
// Cycle #58: 매칭 reason (제목/태그/요약) 명시 → 사용자가 "왜 매칭됐는지" 한눈에 인지
// 제목 매칭 +20, 태그 양방향 +8 (각), 요약 매칭 +5
const allSubsidies = await getCollection('subsidies');
type MatchInfo = { score: number; reasons: string[]; matchedTags: string[] };
function analyzeSubsidy(s: typeof allSubsidies[number]['data']): MatchInfo {
  let score = 0;
  const reasons: string[] = [];
  const matchedTags: string[] = [];
  if (s.title?.includes(term)) {
    score += 20;
    reasons.push('제목');
  }
  for (const tag of s.tags ?? []) {
    if (tag.includes(term) || term.includes(tag)) {
      score += 8;
      matchedTags.push(tag);
    }
  }
  if (matchedTags.length > 0) reasons.push('태그');
  if (s.summary?.includes(term)) {
    score += 5;
    reasons.push('요약');
  }
  return { score, reasons, matchedTags };
}
function fitLabel(score: number): { label: string; cls: string } {
  if (score >= 25) return { label: '매우 적합', cls: 'fit-strong' };
  if (score >= 12) return { label: '적합', cls: 'fit-good' };
  return { label: '관련', cls: 'fit-soft' };
}
const matchedSubsidies = allSubsidies
  .map((s) => ({ s, ...analyzeSubsidy(s.data) }))
  .filter((x) => x.score > 0)
  .sort((a, b) => b.score - a.score || (b.s.data.amount ?? 0) - (a.s.data.amount ?? 0))
  .slice(0, 9);

// Cycle #70 (Phase D): 영구 포스트 부재 시 매칭 지원금 기반 보강 섹션
//   - 매칭 카테고리 1위 → commonEligibility 일반 자격 노출
//   - 매칭 페르소나 빈도 desc Top 3 → 페르소나 cross-link
const personasForFallback = await getCollection('personas');
const categoryFreq: Record<string, number> = {};
const personaFreq: Record<string, number> = {};
for (const m of matchedSubsidies) {
  const cat = m.s.data.category;
  if (cat) categoryFreq[cat] = (categoryFreq[cat] ?? 0) + 1;
  for (const pid of m.s.data.targetPersonas ?? []) {
    personaFreq[pid] = (personaFreq[pid] ?? 0) + 1;
  }
}
const topCategoryId = Object.entries(categoryFreq).sort((a, b) => b[1] - a[1])[0]?.[0];
const topCategoryMeta = topCategoryId ? CATEGORIES.find((c) => c.id === topCategoryId) : null;
const topPersonaIds = Object.entries(personaFreq)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 3)
  .map(([pid]) => pid);
const topPersonas = personasForFallback.filter((p) => topPersonaIds.includes(p.data.id));

// Cycle #7: 트렌딩 토픽별 원문 보도 (today-issue.json의 trendingArticlesByTerm)
type TrendingArticlesByTerm = Record<string, SourceArticle[]>;
const articlesByTerm = ((todayIssue as { trendingArticlesByTerm?: TrendingArticlesByTerm }).trendingArticlesByTerm) ?? {};
const sourceArticles: SourceArticle[] = articlesByTerm[term] ?? [];

// thin content 보호 — 매칭 지원금이 0개이고 매칭 포스트도 없으면 noindex
const isThin = matchedSubsidies.length === 0 && !post;

// dailyCounts → 정렬된 일별 트렌드
const dailyEntries = Object.entries(entry.dailyCounts ?? {})
  .sort((a, b) => a[0].localeCompare(b[0]));
const peakDay = dailyEntries.reduce(
  (max, [d, c]) => (c > max.count ? { date: d, count: c } : max),
  { date: '', count: 0 },
);

// BLUF 자동 통계 (Cycle #3 P0-6, Cycle #4 P0-1 firstSeen/lastSeen null 가드)
const firstSeenLabel = entry.firstSeen ?? '최근';
const lastSeenLabel = entry.lastSeen ?? '오늘';
const blufSummaryTopic = `"${term}"는 ${firstSeenLabel}부터 ${lastSeenLabel}까지 ${entry.daysActive}일 동안 ${entry.totalCount}건의 보도가 있던 정부 지원금 키워드입니다. 관련 지원금 ${matchedSubsidies.length}건을 한 페이지에 정리했습니다.`;
const blufStatsTopic = [
  { value: `${entry.totalCount}건`, label: '누적 보도' },
  { value: `${entry.daysActive}일`, label: '화제 일수' },
  { value: `${matchedSubsidies.length}건`, label: '관련 지원금' },
  ...(peakDay.count > 0 ? [{ value: `${peakDay.count}건`, label: `최다 보도 (${peakDay.date})` }] : []),
];

// Cycle #22: 토픽 hub CollectionPage + ItemList — entity 누락 회복
// thin은 noindex이므로 schema도 미주입 (낭비 방지)
const collectionSchema = !isThin
  ? buildCollectionPage({
      name: `${term} 정부 지원금 ${matchedSubsidies.length}건`,
      description: `'${term}' 트렌딩 키워드 관련 정부 지원금 + 보도 ${entry.totalCount}건 (${entry.daysActive}일 화제)`,
      pageUrl: `/issues/topics/${term}/`,
      items: [
        ...matchedSubsidies.map(({ s }) => ({
          url: `/subsidies/${s.data.id}/`,
          name: s.data.title,
        })),
        ...(post
          ? [
              {
                url: `/issues/${entry.firstSeen ?? entry.lastSeen}/${post.slug}/`,
                name: post.title,
              },
            ]
          : []),
      ],
    })
  : null;

---

<BaseLayout
  title={`${term} — 트렌딩 토픽 | 지원금가이드`}
  description={`"${term}" 정부 지원금 한 페이지 정리. ${entry.daysActive}일 화제 · ${entry.totalCount}건 보도 · 관련 지원금 ${matchedSubsidies.length}건 안내.`}
  activeNav="/issues/"
  noindex={isThin}
  breadcrumbs={[
    { name: '홈', href: '/' },
    { name: '오늘의 이슈', href: '/issues/' },
    { name: term, href: `/issues/topics/${encodeURIComponent(term)}/` },
  ]}
>
  <section class="band">
    <Container size="wide">
      <a class="back-link" href="/issues/">← 오늘의 이슈로</a>

      <div class="head">
        <div class="eyebrow">
          <span class="dot" aria-hidden="true" />
          트렌딩 토픽
        </div>
        <h1 class="title">{term}</h1>
        <p class="lead">
          최근 <strong>{entry.totalCount}건</strong>의 보도가 있던 정부 지원금 키워드입니다.
          {entry.daysActive >= 3 && <> {entry.daysActive}일 연속 화제.</>}
          관련 지원금 <strong>{matchedSubsidies.length}건</strong>을 한 페이지에 모았습니다.
        </p>
      </div>

      <BlufBox summary={blufSummaryTopic} stats={blufStatsTopic} basis="네이버 뉴스 트렌딩 + 보조금24 매칭" />

      <div class="stats">
        <div class="stat">
          <div class="lbl">처음 화제</div>
          <div class="val">{entry.firstSeen}</div>
        </div>
        <div class="stat">
          <div class="lbl">최근 보도</div>
          <div class="val">{entry.lastSeen}</div>
        </div>
        <div class="stat">
          <div class="lbl">화제 일수</div>
          <div class="val">{entry.daysActive}일</div>
        </div>
        <div class="stat accent">
          <div class="lbl">누적 보도</div>
          <div class="val">{entry.totalCount}건</div>
        </div>
        {peakDay.count > 0 && (
          <div class="stat">
            <div class="lbl">최다 보도일</div>
            <div class="val">{peakDay.count}건</div>
            <div class="sub">{peakDay.date}</div>
          </div>
        )}
      </div>

      {post && (
        <section class="post-link-card">
          <div class="plc-eyebrow">관련 포스트</div>
          <a class="plc-link" href={`/issues/${entry.firstSeen}/${post.slug}/`}>
            <div class="plc-title">{post.title}</div>
            <div class="plc-meta">
              {post.category} · {post.date}
            </div>
            {post.tldr && post.tldr.length > 0 && (
              <ul class="plc-tldr">
                {post.tldr.slice(0, 3).map((t) => <li>{t}</li>)}
              </ul>
            )}
            <span class="plc-cta">자세히 보기 →</span>
          </a>
        </section>
      )}

      {/* Cycle #70 (Phase D): 영구 포스트 부재 시 자동 보강 섹션 — Top 3 보장 백업 */}
      {!post && (topCategoryMeta?.commonEligibility?.length || topPersonas.length > 0) && (
        <section class="fallback-pack">
          <div class="fp-eyebrow">자동 정리 — 매칭 지원금 기반</div>
          <p class="fp-intro">
            "{term}" 관련 영구 분석 포스트는 아직 없지만, 매칭 지원금
            <strong> {matchedSubsidies.length}건</strong>의 공통 자격·관련 페르소나를
            자동으로 정리했습니다.
          </p>

          {topCategoryMeta?.commonEligibility && topCategoryMeta.commonEligibility.length > 0 && (
            <div class="fp-block">
              <h3 class="fp-h3">{topCategoryMeta.name} 분야 일반 자격 요건</h3>
              <ul class="fp-list">
                {topCategoryMeta.commonEligibility.map((e) => (
                  <li><span class="fp-check" aria-hidden="true">✓</span>{e}</li>
                ))}
              </ul>
              <a class="fp-cta" href={`/categories/${encodeURIComponent(topCategoryMeta.id)}/`}>
                {topCategoryMeta.name} 분야 전체 보기 →
              </a>
            </div>
          )}

          {topPersonas.length > 0 && (
            <div class="fp-block">
              <h3 class="fp-h3">이 키워드 관련 페르소나</h3>
              <ul class="fp-personas">
                {topPersonas.map((p) => (
                  <li>
                    <a class="fp-persona-card" href={`/personas/${p.data.id}/`}>
                      <span class="fp-p-icon" aria-hidden="true">
                        <Icon name={p.data.icon} size={18} strokeWidth={1.6} />
                      </span>
                      <div class="fp-p-meta">
                        <div class="fp-p-label">{p.data.label}</div>
                        <div class="fp-p-sub">{p.data.sub}</div>
                      </div>
                      <span class="fp-p-arrow" aria-hidden="true">→</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </section>
      )}

      {matchedSubsidies.length > 0 && (
        <section class="matched">
          <h2>관련 지원금 {matchedSubsidies.length}건</h2>
          {/* Cycle #58: 매칭 알고리즘 설명 — 사용자가 "왜 이 지원금이 매칭됐는지" 즉시 인지 */}
          <p class="matched-explain">
            "{term}" 키워드가 지원금의 <strong>제목·태그·요약</strong> 중 하나라도 포함된 것을 매칭했습니다.
            각 카드의 매칭 위치를 chip으로 표시했습니다.
          </p>
          <ul class="grid">
            {matchedSubsidies.map(({ s, score, reasons, matchedTags }) => {
              const fit = fitLabel(score);
              const reasonText = reasons.length > 0
                ? matchedTags.length > 0 && reasons.includes('태그')
                  ? `${reasons.join('·')}: ${matchedTags.slice(0, 2).join(', ')}`
                  : reasons.join('·')
                : '';
              return (
              <li>
                <a class="card" href={`/subsidies/${s.data.id}/`}>
                  <div class={`media tint-${s.data.category}`}>
                    <Icon name={s.data.icon} size={26} strokeWidth={1.6} />
                  </div>
                  <div class="body">
                    <div class="meta-row">
                      <span class={`badge ${fit.cls}`} title={`매칭 점수 ${score}`}>{fit.label}</span>
                      <span class="badge neutral">{s.data.category}</span>
                      {s.data.status === '곧 마감' && <span class="badge warning">곧 마감</span>}
                    </div>
                    {reasonText && (
                      <div class="match-reason" title={`매칭 점수 ${score}점`}>
                        <span class="mr-icon" aria-hidden="true">🔍</span>
                        <span class="mr-text">{reasonText} 매칭</span>
                      </div>
                    )}
                    <div class="agency">{s.data.agency}</div>
                    <div class="t">{s.data.title}</div>
                    {s.data.amount > 0 && (
                      <div class="amt">
                        {formatWon(s.data.amount)} <span class="unit">{s.data.amountLabel}</span>
                      </div>
                    )}
                  </div>
                </a>
              </li>
            );})}
          </ul>
        </section>
      )}

      {sourceArticles.length > 0 && (
        <section class="sources">
          <h2>원문 보도 {sourceArticles.length}개</h2>
          <p class="sources-sub">매체별로 핵심 보도 1건씩 모았습니다. 클릭 시 외부 사이트로 이동합니다.</p>
          <ul class="sources-list">
            {sourceArticles.map((a) => (
              <li>
                <a class="source-card" href={a.link} rel="nofollow noopener" target="_blank">
                  <div class="src-meta">
                    {a.publisher && <span class="src-pub">{a.publisher}</span>}
                    {a.pubDateKR && <span class="src-date">{a.pubDateKR}</span>}
                  </div>
                  <div class="src-title">{a.title}</div>
                  <span class="src-cta">원문 보기 →</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      {dailyEntries.length > 0 && (
        <section class="timeline">
          <h2>일별 보도 흐름</h2>
          <ul class="timeline-list">
            {dailyEntries.map(([d, c]) => (
              <li>
                <span class="timeline-date">{d}</span>
                <div class="timeline-bar-row">
                  <div
                    class="timeline-bar"
                    style={`width: ${Math.max(8, (c / (peakDay.count || 1)) * 100)}%`}
                  />
                  <span class="timeline-count">{c}회</span>
                </div>
              </li>
            ))}
          </ul>
        </section>
      )}

      {otherTopics.length > 0 && (
        <nav class="other-topics" aria-label="다른 트렌딩 토픽">
          <h2>다른 토픽 보기</h2>
          <ul class="ot-grid">
            {otherTopics.map((t) => (
              <li>
                <a class="ot-card" href={`/issues/topics/${encodeURIComponent(t.term)}/`}>
                  <span class="ot-term">{t.term}</span>
                  <span class="ot-meta">
                    <span>{t.totalCount}건 보도</span>
                    {t.daysActive >= 3 && <span class="ot-badge">{t.daysActive}일 화제</span>}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )}
    </Container>
  </section>

  {collectionSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />}
</BaseLayout>

<style>
  .band {
    padding: 32px 0 80px;
  }

  .back-link {
    display: inline-block;
    color: var(--text-2);
    font-size: 14px;
    text-decoration: none;
    margin-bottom: 20px;
  }
  .back-link:hover {
    text-decoration: underline;
  }

  .head {
    margin-bottom: 28px;
    max-width: 780px;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 5px 12px;
    background: rgb(0 113 227 / 0.12);
    color: var(--accent);
    border-radius: var(--radius-pill);
    font-size: 13px;
    font-weight: 700;
    margin-bottom: 14px;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse 1.6s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.3); }
  }

  @media (prefers-reduced-motion: reduce) {
    .dot { animation: none; }
  }

  .title {
    font-size: clamp(32px, 4.5vw, 48px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 14px;
  }

  .lead {
    font-size: 16px;
    color: var(--text-2);
    line-height: 1.65;
    margin: 0;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 12px;
    margin-bottom: 32px;
  }

  .stat {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 16px 18px;
  }

  .stat.accent {
    background: rgb(0 113 227 / 0.06);
    border-color: rgb(0 113 227 / 0.18);
  }

  .stat .lbl {
    font-size: 12px;
    color: var(--text-2);
    margin-bottom: 4px;
  }

  .stat .val {
    font-size: 22px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.015em;
  }

  .stat.accent .val {
    color: var(--accent);
  }

  .stat .sub {
    font-size: 11px;
    color: var(--text-3);
    margin-top: 2px;
  }

  .post-link-card {
    background: var(--surface-2);
    border-radius: var(--radius-lg);
    padding: 24px 28px;
    margin-bottom: 32px;
  }

  .plc-eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  /* Cycle #70 (Phase D): fallback 보강 섹션 — 영구 포스트 부재 시 매칭 데이터 기반 자동 정리 */
  .fallback-pack {
