---
import Container from '@/components/Container.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import todayIssue from '@/data/today-issue.json';

interface HistoryEntry { totalCount: number; daysActive: number; firstSeen: string }
const histModules = import.meta.glob<{ default: { byTerm?: Record<string, HistoryEntry> } }>(
  '/src/data/issues/_history.json',
  { eager: true },
);
const historyByTerm = Object.values(histModules)[0]?.default?.byTerm ?? {};
// totalCount ≥ 3 인 term만 토픽 페이지가 생성됨 — 일치 여부로 링크 활성화 결정
function topicHref(term: string): string | null {
  const entry = historyByTerm[term];
  if (!entry || entry.totalCount < 3) return null;
  return `/issues/topics/${encodeURIComponent(term)}/`;
}

interface PostMeta {
  title: string;
  slug: string;
  metaDescription: string;
  category: string;
  tags: string[];
  freshness?: { trendingTerm: string; daysActive: number; totalCount: number };
  date: string;
  publishedAt: string;
}

// 빌드타임 — 모든 영구 포스트 로드
const issueModules = import.meta.glob<{ default: PostMeta }>(
  '/src/data/issues/*/*.json',
  { eager: true },
);

const posts: Array<{ date: string; slug: string; data: PostMeta }> = [];
for (const [path, mod] of Object.entries(issueModules)) {
  const m = path.match(/\/issues\/(\d{4}-\d{2}-\d{2})\/([^/]+)\.json$/);
  if (!m) continue;
  const slug = m[2];
  if (slug.startsWith('_')) continue;
  posts.push({ date: m[1], slug, data: mod.default });
}

// 날짜 desc 정렬
posts.sort((a, b) => (a.date < b.date ? 1 : a.date > b.date ? -1 : 0));

// today-issue 의 1위 토픽 → 그 토픽에 매칭되는 영구 포스트가 있으면 hero 카드로 노출
type TodayIssue = {
  trending?: Array<{ term: string; count: number; topArticle?: { title: string } }>;
  trendingTopic?: string;
  summary?: { headline: string; subhead: string };
  daysActive?: number;
  totalCount?: number;
};
const today = todayIssue as TodayIssue;
const trending = today.trending ?? [];

// 1위 토픽의 매칭 포스트 찾기 (제목·태그에 트렌딩 키워드 포함)
let heroPost: { date: string; slug: string; data: PostMeta } | null = null;
if (today.trendingTopic && posts.length > 0) {
  heroPost =
    posts.find((p) => {
      const t = today.trendingTopic ?? '';
      return p.data.tags?.some((tag) => tag.includes(t)) || p.data.title?.includes(t);
    }) ?? null;
}

// 월별 그루핑 (아카이브) — hero에 사용된 포스트는 제외
const archivePosts = heroPost
  ? posts.filter((p) => !(p.date === heroPost!.date && p.slug === heroPost!.slug))
  : posts;
const byMonth = archivePosts.reduce<Record<string, typeof posts>>((acc, p) => {
  const ym = p.date.slice(0, 7);
  acc[ym] = acc[ym] ?? [];
  acc[ym].push(p);
  return acc;
}, {});
const months = Object.keys(byMonth).sort().reverse();
---

<BaseLayout
  title={`정책 이슈 — 매일 자동 큐레이션 ${posts.length}건`}
  description="매일 자동으로 큐레이션되는 정부 지원금 정책 이슈. 트렌딩 키워드별 대표 포스트, 월별 아카이브 제공."
  activeNav="/issues/"
>
  <section class="band">
    <Container size="wide">
      <div class="head">
        <h1 class="title">오늘의 이슈</h1>
        <p class="lead">
          매일 06:00 한국어 정책·지원금 뉴스에서 가장 화제인 토픽을 자동 큐레이션해 영구 포스트로 보관합니다.<br />
          AI가 SEO/GEO 표준에 맞춰 작성하고, 우리 DB의 매칭 지원금까지 연결합니다.
        </p>
      </div>

      {heroPost && today.summary && (
        <a class="hero-card" href={`/issues/${heroPost.date}/${heroPost.slug}/`}>
          <div class="hero-meta">
            <span class="hero-rank">1위 트렌딩</span>
            {today.daysActive && today.daysActive >= 3 && (
              <span class="hero-badge">
                <span class="dot" aria-hidden="true" />
                {today.daysActive}일 연속
              </span>
            )}
            <span class="hero-cat">{heroPost.data.category}</span>
            <span class="hero-date">{heroPost.date}</span>
          </div>
          <h2 class="hero-title">{heroPost.data.title}</h2>
          <p class="hero-desc">{heroPost.data.metaDescription}</p>
          <div class="hero-cta">자세히 보기 →</div>
        </a>
      )}

      <div class="body-grid">
        <main class="body">
          {posts.length === 0 ? (
            <div class="empty">
              <p>아직 등록된 포스트가 없습니다. 매일 06:00 자동 갱신을 기다려 주세요.</p>
              <a class="empty-link" href="/subsidies/new/">신규 지원금 둘러보기 →</a>
            </div>
          ) : (
            months.map((ym) => (
              <section class="month-block">
                <h2 class="month-title">{ym.replace('-', '년 ')}월</h2>
                <ul class="post-list">
                  {byMonth[ym].map((p) => (
                    <li>
                      <a class="post-card" href={`/issues/${p.date}/${p.slug}/`}>
                        <div class="pc-meta">
                          {p.data.freshness && p.data.freshness.daysActive >= 3 && (
                            <span class="freshness">
                              <span class="dot" aria-hidden="true" />
                              {p.data.freshness.daysActive}일 연속 트렌딩
                            </span>
                          )}
                          <span class="cat">{p.data.category}</span>
                          <span class="date">{p.date}</span>
                        </div>
                        <div class="pc-title">{p.data.title}</div>
                        <div class="pc-desc">{p.data.metaDescription}</div>
                        <span class="pc-arrow" aria-hidden="true">→</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </section>
            ))
          )}
        </main>

        <aside class="rail">
          <div class="rail-card">
            <div class="rail-eyebrow"><span class="dot" aria-hidden="true" />트렌딩 키워드</div>
            <div class="rail-title">오늘 매체 언급 Top {Math.min(trending.length, 5)}</div>
            {trending.length > 0 ? (
              <ol class="trend-list">
                {trending.slice(0, 5).map((t, i) => {
                  const href = topicHref(t.term);
                  const inner = (
                    <>
                      <span class="rk">{i + 1}</span>
                      <span class="trm">{t.term}</span>
                      <span class="cnt">{t.count}회</span>
                    </>
                  );
                  return (
                    <li class={i === 0 ? 'hot' : ''}>
                      {href ? <a class="trend-link" href={href}>{inner}</a> : inner}
                    </li>
                  );
                })}
              </ol>
            ) : (
              <p class="trend-empty">데이터 없음</p>
            )}
          </div>

          <div class="rail-card">
            <div class="rail-eyebrow">5분 진단</div>
            <div class="rail-title">받을 수 있는 지원금 자동 매칭</div>
            <a class="rail-cta" href="/quick/">진단 시작하기 →</a>
          </div>
          <div class="rail-card">
            <div class="rail-eyebrow">상황별</div>
            <div class="rail-title">출산·이사·실직 등 라이프 이벤트</div>
            <a class="rail-cta" href="/situations/">상황별 보기 →</a>
          </div>
          <div class="rail-card">
            <div class="rail-eyebrow">RSS</div>
            <div class="rail-title">이슈 포스트 전용 피드</div>
            <a class="rail-cta" href="/feed-issues.xml">/feed-issues.xml →</a>
          </div>
          <div class="rail-card">
            <div class="rail-eyebrow">RSS</div>
            <div class="rail-title">최근 등록 지원금 피드</div>
            <a class="rail-cta" href="/feed.xml">/feed.xml →</a>
          </div>
        </aside>
      </div>
    </Container>
  </section>
</BaseLayout>

<style>
  .band { padding: 48px 0 80px; }

  .head {
    margin-bottom: 28px;
    max-width: 720px;
  }
  .title {
    font-size: clamp(28px, 3.6vw, 44px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 12px;
  }
  .lead {
    font-size: 16px;
    color: var(--text-2);
    line-height: 1.65;
    margin: 0;
  }

  /* 1위 토픽 hero */
  .hero-card {
    display: block;
    padding: 28px 32px;
    background: linear-gradient(135deg, var(--accent) 0%, #003875 100%);
    color: #fff;
    border-radius: var(--radius-xl);
    text-decoration: none;
    margin-bottom: 32px;
    position: relative;
    overflow: hidden;
    isolation: isolate;
    transition: transform 0.18s var(--ease-standard);
  }
  .hero-card::before {
    content: '';
    position: absolute;
    top: -50px; right: -50px;
    width: 240px; height: 240px;
    background: radial-gradient(circle, rgb(255 255 255 / 0.16) 0%, transparent 65%);
    pointer-events: none;
    z-index: -1;
  }
  .hero-card:hover {
    transform: translateY(-2px);
    text-decoration: none;
  }
  @media (max-width: 600px) { .hero-card { padding: 24px; } }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }
  .hero-rank {
    padding: 4px 12px;
    background: rgb(255 255 255 / 0.95);
    color: var(--accent);
    border-radius: var(--radius-pill);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.04em;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 10px;
    background: rgb(255 255 255 / 0.18);
    border-radius: var(--radius-pill);
    font-size: 12px;
    font-weight: 700;
  }
  .hero-badge .dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: #fff;
    animation: pulse-dot 1.6s ease-in-out infinite;
  }
  .hero-cat {
    padding: 3px 10px;
    background: rgb(255 255 255 / 0.18);
    border-radius: var(--radius-pill);
    font-size: 12px;
    font-weight: 600;
  }
  .hero-date {
    font-size: 12px;
    color: rgb(255 255 255 / 0.7);
    margin-left: auto;
  }

  .hero-title {
    font-size: clamp(22px, 2.8vw, 32px);
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.02em;
    margin: 0 0 10px;
    color: #fff;
  }
  .hero-desc {
    font-size: 15px;
    color: rgb(255 255 255 / 0.86);
    line-height: 1.6;
    margin: 0 0 16px;
  }
  .hero-cta {
    display: inline-flex;
    align-items: center;
    padding: 10px 18px;
    background: #fff;
    color: var(--accent);
    border-radius: var(--radius-pill);
    font-size: 14px;
    font-weight: 700;
    transition: transform 0.18s var(--ease-standard);
  }
  .hero-card:hover .hero-cta { transform: translateX(3px); }

  .body-grid {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 32px;
  }
  @media (max-width: 880px) { .body-grid { grid-template-columns: 1fr; } }

  .body { min-width: 0; }

  .empty {
    text-align: center;
    padding: 80px 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }
  .empty p { color: var(--text-2); }
  .empty-link {
    display: inline-block;
    margin-top: 12px;
    color: var(--accent-link);
    text-decoration: none;
    font-weight: 500;
  }
  .empty-link:hover { text-decoration: underline; }

  .month-block { margin-bottom: 36px; }
  .month-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-2);
    margin: 0 0 14px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .post-card {
    position: relative;
    display: block;
    padding: 18px 22px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: transform 0.18s var(--ease-standard), border-color 0.18s;
  }
  .post-card:hover {
    transform: translateY(-2px);
    border-color: var(--border-2);
    text-decoration: none;
  }

  .pc-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }
  .freshness {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 10px;
    background: rgb(0 113 227 / 0.12);
    color: var(--accent);
    border-radius: var(--radius-pill);
    font-size: 12px;
    font-weight: 700;
  }
  .dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: currentColor;
    animation: pulse-dot 1.6s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.3); }
  }
  @media (prefers-reduced-motion: reduce) { .dot { animation: none; } }

  .cat {
    padding: 2px 8px;
    background: var(--surface-2);
    color: var(--text-2);
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
  }
  .date { color: var(--text-3); font-size: 12px; }

  .pc-title {
    font-size: 17px;
    font-weight: 600;
    line-height: 1.35;
    margin-bottom: 4px;
  }
  .pc-desc {
    font-size: 14px;
    color: var(--text-2);
    line-height: 1.6;
  }
  .pc-arrow {
    position: absolute;
    top: 50%;
    right: 18px;
    transform: translateY(-50%);
    color: var(--text-3);
    font-size: 18px;
    transition: transform 0.18s var(--ease-standard), color 0.18s;
  }
  .post-card:hover .pc-arrow {
    transform: translateY(-50%) translateX(4px);
    color: var(--accent);
  }

  /* 사이드바 */
  .rail { display: flex; flex-direction: column; gap: 12px; }
  .rail-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 16px 18px;
  }
  .rail-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .rail-title {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.4;
    margin-bottom: 10px;
  }
  .rail-cta {
    color: var(--accent-link);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
  }
  .rail-cta:hover { text-decoration: underline; }

  .trend-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .trend-list li {
    padding: 6px 0;
    font-size: 13px;
  }
  .trend-list li,
  .trend-list .trend-link {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .trend-list .trend-link {
    text-decoration: none;
    color: inherit;
    padding: 6px 8px;
    margin: 0 -8px;
    border-radius: 4px;
    min-height: 24px; /* WCAG 2.2 SC 2.5.8 target-size */
    transition: background 0.15s;
  }
  .trend-list .trend-link:hover {
    background: var(--surface-2);
    text-decoration: none;
  }
  .rk {
    width: 22px; height: 22px;
    background: var(--surface-2);
    border-radius: 50%;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 700;
    flex-shrink: 0;
  }
  .trend-list .hot .rk {
    background: var(--accent);
    color: #fff;
  }
  .trm { flex: 1; min-width: 0; font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .cnt { color: var(--accent); font-weight: 700; flex-shrink: 0; }
  .trend-empty { font-size: 13px; color: var(--text-3); }
</style>
