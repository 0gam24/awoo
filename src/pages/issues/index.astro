---
import Container from '@/components/Container.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import todayIssue from '@/data/today-issue.json';

interface HistoryEntry { totalCount: number; daysActive: number; firstSeen: string }
const histModules = import.meta.glob<{ default: { byTerm?: Record<string, HistoryEntry> } }>(
  '/src/data/issues/_history.json',
  { eager: true },
);
const historyByTerm = Object.values(histModules)[0]?.default?.byTerm ?? {};
// totalCount ≥ 3 인 term만 토픽 페이지가 생성됨 — 일치 여부로 링크 활성화 결정
function topicHref(term: string): string | null {
  const entry = historyByTerm[term];
  if (!entry || entry.totalCount < 3) return null;
  return `/issues/topics/${encodeURIComponent(term)}/`;
}

interface PostMeta {
  title: string;
  slug: string;
  metaDescription: string;
  category: string;
  tags: string[];
  freshness?: { trendingTerm: string; daysActive: number; totalCount: number };
  date: string;
  publishedAt: string;
  sections?: unknown[];
  faq?: unknown[];
  tldr?: unknown[];
}

// 한국어 분당 500자 기준 — sections·faq·tldr 평균 길이로 추정 (server-side, 빌드타임)
function readingTimeMin(post: PostMeta): number {
  const sectionsLen = (post.sections?.length ?? 0) * 250; // 섹션당 평균
  const faqLen = (post.faq?.length ?? 0) * 100;
  const tldrLen = (post.tldr?.length ?? 0) * 80;
  const chars = sectionsLen + faqLen + tldrLen + (post.metaDescription?.length ?? 0);
  return Math.max(2, Math.round(chars / 500));
}

// 빌드타임 — 모든 영구 포스트 로드
const issueModules = import.meta.glob<{ default: PostMeta }>(
  '/src/data/issues/*/*.json',
  { eager: true },
);

const posts: Array<{ date: string; slug: string; data: PostMeta }> = [];
for (const [path, mod] of Object.entries(issueModules)) {
  const m = path.match(/\/issues\/(\d{4}-\d{2}-\d{2})\/([^/]+)\.json$/);
  if (!m) continue;
  const slug = m[2];
  if (slug.startsWith('_')) continue;
  posts.push({ date: m[1], slug, data: mod.default });
}

// 날짜 desc 정렬
posts.sort((a, b) => (a.date < b.date ? 1 : a.date > b.date ? -1 : 0));

// today-issue 의 트렌딩 → 매칭 포스트로 다층 hero 구성
type TodayIssue = {
  trending?: Array<{
    term: string;
    count: number;
    topArticle?: { title: string; link?: string; category?: string };
  }>;
  trendingTopic?: string;
  summary?: { headline: string; subhead: string };
  daysActive?: number;
  totalCount?: number;
  matchedSubsidies?: Array<{ id: string; title: string; agency: string; category: string }>;
};
const today = todayIssue as TodayIssue;
const trending = today.trending ?? [];

function findPost(term: string) {
  return posts.find((p) => p.data.tags?.some((tag) => tag.includes(term)) || p.data.title?.includes(term)) ?? null;
}

// Top 3 트렌딩 → hero 후보. 1위는 lg, 2·3위는 sm
type HeroCard = {
  rank: number;
  term: string;
  count: number;
  post: { date: string; slug: string; data: PostMeta } | null;
  topicHref: string | null;
};
const heroCards: HeroCard[] = trending.slice(0, 3).map((t, i) => ({
  rank: i + 1,
  term: t.term,
  count: t.count,
  post: findPost(t.term),
  topicHref: topicHref(t.term),
}));
const heroPost = heroCards[0]?.post ?? null;

// hero 영역 사용된 포스트 슬러그 set — 아카이브에서 중복 제거
const heroPostKeys = new Set(
  heroCards
    .map((c) => (c.post ? `${c.post.date}/${c.post.slug}` : null))
    .filter((x): x is string => x !== null),
);
const archivePosts = posts.filter((p) => !heroPostKeys.has(`${p.date}/${p.slug}`));
const byMonth = archivePosts.reduce<Record<string, typeof posts>>((acc, p) => {
  const ym = p.date.slice(0, 7);
  acc[ym] = acc[ym] ?? [];
  acc[ym].push(p);
  return acc;
}, {});
const months = Object.keys(byMonth).sort().reverse();
---

<BaseLayout
  title={`오늘의 이슈 — 정부 지원금 정책 ${posts.length}건`}
  description="이번 주 가장 화제인 정부 지원금 정책 이슈를 한 페이지에서 확인하세요. 자격·금액·신청 방법까지 핵심 요약."
  activeNav="/issues/"
  breadcrumbs={[
    { name: '홈', href: '/' },
    { name: '오늘의 이슈', href: '/issues/' },
  ]}
>
  <section class="band">
    <Container size="wide">
      <div class="head">
        <h1 class="title">오늘의 이슈</h1>
        <p class="lead">
          이번 주 가장 화제인 정부 지원금을 한 페이지에서 확인하세요.<br />
          핵심 요약·자격 조건·관련 지원금까지 함께 정리했습니다.
        </p>
      </div>

      {heroCards.length > 0 && (
        <section class="hero-section" aria-label="이번 주 화제 Top 3">
          {heroCards[0] && (
            heroCards[0].post ? (
              <a class={`hero-lg cat-${heroCards[0].post.data.category}`} href={`/issues/${heroCards[0].post.date}/${heroCards[0].post.slug}/`}>
                <div class="hero-meta">
                  <span class="hero-rank">1위 화제</span>
                  {today.daysActive && today.daysActive >= 3 && (
                    <span class="hero-badge">
                      <span class="dot" aria-hidden="true" />
                      {today.daysActive}일 연속
                    </span>
                  )}
                  <span class="hero-cat">{heroCards[0].post.data.category}</span>
                  <span class="hero-count">{heroCards[0].count}건 보도</span>
                </div>
                <h2 class="hero-title">{heroCards[0].post.data.title}</h2>
                <p class="hero-desc">{heroCards[0].post.data.metaDescription}</p>
                <div class="hero-cta">자세히 보기 →</div>
              </a>
            ) : (
              <a
                class={`hero-lg topic ${heroCards[0].topicHref ? '' : 'static'}`}
                href={heroCards[0].topicHref ?? '/subsidies/'}
              >
                <div class="hero-meta">
                  <span class="hero-rank">1위 화제</span>
                  <span class="hero-count">{heroCards[0].count}건 보도</span>
                </div>
                <h2 class="hero-title">{heroCards[0].term}</h2>
                <p class="hero-desc">관련 지원금과 정책 내용을 한 페이지에서 확인하세요.</p>
                <div class="hero-cta">{heroCards[0].topicHref ? '관련 지원금 보기 →' : '지원금 둘러보기 →'}</div>
              </a>
            )
          )}

          {heroCards.length > 1 && (
            <div class="hero-sub-grid">
              {heroCards.slice(1, 3).map((c) =>
                c.post ? (
                  <a class={`hero-sm cat-${c.post.data.category}`} href={`/issues/${c.post.date}/${c.post.slug}/`}>
                    <div class="hero-sm-meta">
                      <span class="hero-rank-sm">{c.rank}위</span>
                      <span class="hero-cat-sm">{c.post.data.category}</span>
                    </div>
                    <div class="hero-sm-title">{c.post.data.title}</div>
                    <div class="hero-sm-count">{c.count}건 보도</div>
                  </a>
                ) : (
                  <a class="hero-sm topic" href={c.topicHref ?? `/subsidies/?q=${encodeURIComponent(c.term)}`}>
                    <div class="hero-sm-meta">
                      <span class="hero-rank-sm">{c.rank}위</span>
                      <span class="hero-cat-sm">트렌딩</span>
                    </div>
                    <div class="hero-sm-title">{c.term}</div>
                    <div class="hero-sm-count">{c.count}건 보도 · 관련 지원금 보기 →</div>
                  </a>
                ),
              )}
            </div>
          )}
        </section>
      )}

      <div class="body-grid">
        <main class="body">
          {posts.length < 3 && today.matchedSubsidies && today.matchedSubsidies.length > 0 && (
            <section class="matched-section">
              <h2 class="section-title">이번 주 화제 — 관련 지원금 {today.matchedSubsidies.length}건</h2>
              <p class="section-sub">바로 확인할 수 있는 매칭 지원금을 모았습니다.</p>
              <ul class="matched-list">
                {today.matchedSubsidies.slice(0, 6).map((s) => (
                  <li>
                    <a class={`matched-card cat-${s.category}`} href={`/subsidies/${s.id}/`}>
                      <div class="m-cat">{s.category}</div>
                      <div class="m-title">{s.title}</div>
                      <div class="m-agency">{s.agency}</div>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}

          {posts.length === 0 ? (
            <div class="empty">
              <p>이번 주 화제 이슈가 곧 올라옵니다. 그 동안 새로 등록된 지원금을 먼저 확인해 보세요.</p>
              <a class="empty-link" href="/subsidies/new/">신규 지원금 둘러보기 →</a>
            </div>
          ) : (
            months.map((ym) => (
              <section class="month-block">
                <h2 class="month-title">{ym.replace('-', '년 ')}월</h2>
                <ul class="post-list">
                  {byMonth[ym].map((p) => (
                    <li>
                      <a class={`post-card cat-${p.data.category}`} href={`/issues/${p.date}/${p.slug}/`}>
                        <div class="pc-meta">
                          {p.data.freshness && p.data.freshness.daysActive >= 3 && (
                            <span class="freshness">
                              <span class="dot" aria-hidden="true" />
                              {p.data.freshness.daysActive}일 연속 화제
                            </span>
                          )}
                          <span class="cat">{p.data.category}</span>
                          <span class="date">{p.date}</span>
                          <span class="read-time">📖 {readingTimeMin(p.data)}분</span>
                        </div>
                        <div class="pc-title">{p.data.title}</div>
                        <div class="pc-desc">{p.data.metaDescription}</div>
                        {p.data.tags && p.data.tags.length > 0 && (
                          <div class="pc-tags">
                            {p.data.tags.slice(0, 2).map((tag) => <span class="pc-tag">#{tag}</span>)}
                          </div>
                        )}
                        <span class="pc-arrow" aria-hidden="true">→</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </section>
            ))
          )}
        </main>

        <aside class="rail">
          <div class="rail-card">
            <div class="rail-eyebrow"><span class="dot" aria-hidden="true" />트렌딩 키워드</div>
            <div class="rail-title">이번 주 가장 화제인 키워드</div>
            {trending.length > 0 ? (
              <ol class="trend-list">
                {trending.slice(0, 5).map((t, i) => {
                  // Cycle #6 P0-5: topicHref null fallback — /subsidies/?q={term} 정적 검색 링크
                  const href = topicHref(t.term) ?? `/subsidies/?q=${encodeURIComponent(t.term)}`;
                  const inner = (
                    <>
                      <span class="rk">{i + 1}</span>
                      <span class="trm">{t.term}</span>
                      <span class="cnt">{t.count}회</span>
                    </>
                  );
                  return (
                    <li class={i === 0 ? 'hot' : ''}>
                      <a class="trend-link" href={href}>{inner}</a>
                    </li>
                  );
                })}
              </ol>
            ) : (
              <p class="trend-empty">곧 업데이트됩니다</p>
            )}
          </div>

          <div class="rail-card">
            <div class="rail-eyebrow">5분 진단</div>
            <div class="rail-title">내가 받을 수 있는 지원금 찾기</div>
            <a class="rail-cta" href="/quick/">진단 시작하기 →</a>
          </div>
          <div class="rail-card">
            <div class="rail-eyebrow">상황별</div>
            <div class="rail-title">출산·이사·실직, 지금 내 상황은?</div>
            <a class="rail-cta" href="/situations/">상황별 보기 →</a>
          </div>
          <div class="rail-card">
            <div class="rail-eyebrow">RSS 구독</div>
            <div class="rail-title">새 이슈를 RSS로 받아보기</div>
            <a class="rail-cta" href="/feed-issues.xml">이슈 피드 →</a>
          </div>
          <div class="rail-card">
            <div class="rail-eyebrow">RSS 구독</div>
            <div class="rail-title">신규 지원금을 RSS로 받아보기</div>
            <a class="rail-cta" href="/feed.xml">지원금 피드 →</a>
          </div>
        </aside>
      </div>
    </Container>
  </section>
</BaseLayout>

<style>
  .band { padding: 48px 0 80px; }

  .head {
    margin-bottom: 28px;
    max-width: 720px;
  }
  .title {
    font-size: clamp(28px, 3.6vw, 44px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 12px;
  }
  .lead {
    font-size: 16px;
    color: var(--text-2);
    line-height: 1.65;
    margin: 0;
  }

  /* .cat-* 카테고리 토큰은 global.css에서 일괄 정의 (라이트/다크 양쪽) */

  /* 다층 hero — 1위 lg + 2·3위 sm grid */
  .hero-section {
    display: grid;
    gap: 14px;
    margin-bottom: 36px;
  }

  .hero-lg {
    display: block;
    padding: 28px 32px;
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark, #003875) 100%);
    color: #fff;
    border-radius: var(--radius-xl);
    text-decoration: none;
    position: relative;
    overflow: hidden;
    isolation: isolate;
    transition: transform 0.18s var(--ease-standard);
  }
  .hero-lg::before {
    content: '';
    position: absolute;
    top: -50px; right: -50px;
    width: 240px; height: 240px;
    background: radial-gradient(circle, rgb(255 255 255 / 0.16) 0%, transparent 65%);
    pointer-events: none;
    z-index: -1;
  }
  .hero-lg:hover {
    transform: translateY(-2px);
    text-decoration: none;
  }
  .hero-lg.topic.static {
    background: linear-gradient(135deg, var(--text-2) 0%, var(--text-3) 100%);
  }
  @media (max-width: 600px) { .hero-lg { padding: 24px; } }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }
  .hero-rank {
    padding: 4px 12px;
    background: rgb(255 255 255 / 0.95);
    color: var(--accent);
    border-radius: var(--radius-pill);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.04em;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 10px;
    background: rgb(255 255 255 / 0.18);
    border-radius: var(--radius-pill);
    font-size: 12px;
    font-weight: 700;
  }
  .hero-badge .dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: #fff;
    animation: pulse-dot 1.6s ease-in-out infinite;
  }
  .hero-cat {
    padding: 3px 10px;
    background: rgb(255 255 255 / 0.18);
    border-radius: var(--radius-pill);
    font-size: 12px;
    font-weight: 600;
  }
  .hero-count {
    font-size: 12px;
    color: rgb(255 255 255 / 0.86);
    margin-left: auto;
    font-weight: 600;
  }

  .hero-title {
    font-size: clamp(22px, 2.8vw, 32px);
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.02em;
    margin: 0 0 10px;
    color: #fff;
  }
  .hero-desc {
    font-size: 15px;
    color: rgb(255 255 255 / 0.86);
    line-height: 1.6;
    margin: 0 0 16px;
  }
  .hero-cta {
    display: inline-flex;
    align-items: center;
    padding: 10px 18px;
    background: #fff;
    color: var(--accent);
    border-radius: var(--radius-pill);
    font-size: 14px;
    font-weight: 700;
    transition: transform 0.18s var(--ease-standard);
  }
  .hero-lg:hover .hero-cta { transform: translateX(3px); }

  /* 2·3위 sm hero */
  .hero-sub-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 12px;
  }

  .hero-sm {
    display: block;
    padding: 18px 20px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 4px solid var(--cat-color, var(--accent));
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s, border-color 0.15s;
  }
  .hero-sm:hover {
    transform: translateY(-2px);
    border-color: var(--border-2);
    border-left-color: var(--cat-color, var(--accent));
    text-decoration: none;
  }
  .hero-sm.topic { --cat-color: var(--text-3); }

  .hero-sm-meta {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-bottom: 8px;
  }
  .hero-rank-sm {
    padding: 2px 8px;
    background: var(--surface-2);
    color: var(--text);
    border-radius: var(--radius-pill);
    font-size: 11px;
    font-weight: 700;
  }
  .hero-cat-sm {
    font-size: 11px;
    color: var(--cat-color, var(--text-2));
    font-weight: 600;
  }
  .hero-sm-title {
    font-size: 15px;
    font-weight: 600;
    line-height: 1.4;
    margin-bottom: 6px;
    color: var(--text);
  }
  .hero-sm-count {
    font-size: 12px;
    color: var(--text-2);
  }

  .body-grid {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 32px;
  }
  @media (max-width: 880px) { .body-grid { grid-template-columns: 1fr; } }

  .body { min-width: 0; }

  /* 소량 상태 풍성화 — 매칭 지원금 카드 */
  .matched-section {
    margin-bottom: 36px;
    padding: 24px 28px;
    background: var(--bg-alt);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .section-title {
    font-size: 17px;
    font-weight: 700;
    margin: 0 0 4px;
    letter-spacing: -0.01em;
  }

  .section-sub {
    font-size: 13px;
    color: var(--text-2);
    margin: 0 0 16px;
  }

  .matched-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 10px;
  }

  .matched-card {
    display: block;
    padding: 14px 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 4px solid var(--cat-color, var(--accent));
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s, border-color 0.15s;
  }
  .matched-card:hover {
    transform: translateY(-1px);
    border-color: var(--border-2);
    border-left-color: var(--cat-color, var(--accent));
    text-decoration: none;
  }

  .m-cat {
    font-size: 11px;
    color: var(--cat-color, var(--text-2));
    font-weight: 700;
    margin-bottom: 4px;
  }

  .m-title {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.4;
    margin-bottom: 4px;
  }

  .m-agency {
    font-size: 12px;
    color: var(--text-2);
  }

  .empty {
    text-align: center;
    padding: 80px 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }
  .empty p { color: var(--text-2); }
  .empty-link {
    display: inline-block;
    margin-top: 12px;
    color: var(--accent-link);
    text-decoration: none;
    font-weight: 500;
  }
  .empty-link:hover { text-decoration: underline; }

  .month-block { margin-bottom: 36px; }
  .month-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-2);
    margin: 0 0 14px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .post-card {
    position: relative;
    display: block;
    padding: 18px 22px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 4px solid var(--cat-color, var(--border-2));
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: transform 0.18s var(--ease-standard), border-color 0.18s;
  }
  .post-card:hover {
    transform: translateY(-2px);
    border-color: var(--border-2);
    border-left-color: var(--cat-color, var(--accent));
    text-decoration: none;
  }

  .pc-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }
  .freshness {
    display: inline-flex;
