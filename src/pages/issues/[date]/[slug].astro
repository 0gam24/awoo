            </a>
          ) : (
            <span class="pn-spacer"></span>
          )}
          {nextPost ? (
            <a class="pn-link next" href={`/issues/${nextPost.date}/${nextPost.slug}/`} rel="next">
              <span class="pn-label">다음 포스트 →</span>
              <span class="pn-title">{nextPost.title}</span>
            </a>
          ) : (
            <span class="pn-spacer"></span>
          )}
        </nav>
      )}
    </Container>
  </article>
</BaseLayout>

