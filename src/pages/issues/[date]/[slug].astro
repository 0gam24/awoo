---
import Container from '@/components/Container.astro';
import Icon from '@/components/Icon.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { formatWon } from '@/data/site-data';
import { paragraphsAndLists } from '@/lib/inline-markdown';
import { type GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';

interface Source {
  title: string;
  url: string;
  publisher: string;
  pubDate?: string;
}
interface FaqItem {
  q: string;
  a: string;
}
interface Section {
  heading: string;
  lead: string;
  body: string;
}
interface PostTable {
  title: string;
  headers: string[];
  rows: string[][];
}
interface PostData {
  title: string;
  slug: string;
  metaDescription: string;
  tldr: string[];
  category: string;
  tags: string[];
  coreFacts: { who: string; amount: string; deadline: string; where: string };
  freshness?: { trendingTerm: string; daysActive: number; totalCount: number; rankToday: number };
  sections: Section[];
  table?: PostTable;
  faq: FaqItem[];
  relatedSubsidies: string[];
  relatedPersonas: string[];
  sources: Source[];
  publishedAt: string;
  date: string;
}

export const getStaticPaths = (() => {
  // 빌드타임 — Vite glob (getStaticPaths 호이스팅 호환 위해 함수 내부 정의)
  const issueModules = import.meta.glob<{ default: PostData }>(
    '/src/data/issues/*/*.json',
    { eager: true },
  );
  // Cycle #25: prev/next 자동 계산 — 모든 포스트 시간 desc 정렬 후 인덱스 기반 매핑
  type Entry = { date: string; slug: string; data: PostData };
  const all: Entry[] = [];
  for (const [path, mod] of Object.entries(issueModules)) {
    const m = path.match(/\/issues\/(\d{4}-\d{2}-\d{2})\/([^/]+)\.json$/);
    if (!m) continue;
    const date = m[1];
    const slug = m[2];
    if (!date || !slug || slug.startsWith('_')) continue;
    all.push({ date, slug, data: mod.default });
  }
  // 시간 desc 정렬 (최신순)
  all.sort((a, b) =>
    a.date < b.date ? 1 : a.date > b.date ? -1 : a.slug.localeCompare(b.slug),
  );

  return all.map((entry, i) => {
    const prev = all[i + 1]; // desc 정렬: 다음 인덱스는 더 옛날 (prev = older)
    const next = all[i - 1]; // 이전 인덱스는 더 최근 (next = newer)
    return {
      params: { date: entry.date, slug: entry.slug },
      props: {
        post: entry.data,
        prevPost: prev
          ? { date: prev.date, slug: prev.slug, title: prev.data.title }
          : null,
        nextPost: next
          ? { date: next.date, slug: next.slug, title: next.data.title }
          : null,
      },
    };
  });
}) satisfies GetStaticPaths;

const { post, prevPost, nextPost } = Astro.props as {
  post: PostData;
  prevPost: { date: string; slug: string; title: string } | null;
  nextPost: { date: string; slug: string; title: string } | null;
};
const { date, slug } = Astro.params;

const subsidies = await getCollection('subsidies');
const subsidyById = new Map(subsidies.map((s) => [s.data.id, s.data]));
const relatedSubsidies = post.relatedSubsidies
  .map((id) => subsidyById.get(id))
  .filter((x): x is NonNullable<ReturnType<typeof subsidyById.get>> => x !== undefined);

const personas = await getCollection('personas');
const personaById = new Map(personas.map((p) => [p.data.id, p.data]));
const relatedPersonas = post.relatedPersonas
  .map((id) => personaById.get(id))
  .filter((x): x is NonNullable<ReturnType<typeof personaById.get>> => x !== undefined);

// Cycle #31: history.byTerm — dateModified를 트렌딩 lastSeen으로 갱신 (freshness 신호)
interface HistoryEntry { firstSeen: string; lastSeen: string; totalCount: number; daysActive: number }
const histModules = import.meta.glob<{ default: { byTerm?: Record<string, HistoryEntry> } }>(
  '/src/data/issues/_history.json',
  { eager: true },
);
const historyByTerm = Object.values(histModules)[0]?.default?.byTerm ?? {};

// JSON-LD — NewsArticle 강화 (mainEntityOfPage·articleSection·inLanguage 등)
const canonicalUrl = `https://awoo.or.kr/issues/${date}/${slug}/`;
// Cycle #11 P0-1: wordCount — AI 인용 confidence 신호 (콘텐츠 depth 명시)
const articleWordCount =
  (post.metaDescription?.length ?? 0) +
  (post.tldr ?? []).reduce((s, t) => s + t.length, 0) +
  (post.sections ?? []).reduce(
    (s, sec) => s + (sec.heading?.length ?? 0) + (sec.lead?.length ?? 0) + (sec.body?.length ?? 0),
    0,
  ) +
  (post.faq ?? []).reduce((s, f) => s + (f.q?.length ?? 0) + (f.a?.length ?? 0), 0);
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  '@id': canonicalUrl,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
  headline: post.title,
  description: post.metaDescription,
  url: canonicalUrl,
  inLanguage: 'ko-KR',
  datePublished: post.publishedAt,
  // Cycle #31: dateModified — history.lastSeen 우선 (트렌딩 재등장 시 freshness 갱신)
  dateModified:
    post.freshness?.trendingTerm && historyByTerm[post.freshness.trendingTerm]?.lastSeen
      ? `${historyByTerm[post.freshness.trendingTerm]!.lastSeen}T00:00:00.000Z`
      : post.publishedAt,
  articleSection: post.category,
  keywords: post.tags.join(', '),
  about: post.freshness?.trendingTerm ?? post.tags[0],
  // 본 사이트는 AI 보조 + 사람 편집 정책 (editorial-policy 페이지 명시)
  // E-E-A-T 강화 — 책임 편집자 실명 명시 (Discover YMYL 영역 가산)
  author: [
    {
      '@type': 'Person',
      name: '김준혁',
      jobTitle: '편집책임자',
      url: 'https://awoo.or.kr/about/',
      worksFor: {
        '@type': 'Organization',
        name: '스마트데이터샵',
      },
    },
    {
      '@type': 'Organization',
      name: '지원금가이드 편집팀',
      url: 'https://awoo.or.kr/editorial-policy/',
    },
  ],
  // 사이트와이드 Organization @id 참조 (Cycle #1 P0-2 자산) — entity 일관성 + 중복 제거
  publisher: { '@id': 'https://awoo.or.kr/#organization' },
  image: ['https://awoo.or.kr/og-default.png'],
  isAccessibleForFree: true,
  // Cycle #11 P0-1: AI 답변 엔진 인용 confidence 신호
  wordCount: articleWordCount,
  // Cycle #29: archive + topic hub 관계 명시 (entity 그래프 strengthen)
  isPartOf: {
    '@type': 'CollectionPage',
    '@id': 'https://awoo.or.kr/issues/all/#collection',
    name: '전체 분석 포스트 아카이브',
    url: 'https://awoo.or.kr/issues/all/',
  },
  ...(post.freshness?.trendingTerm
    ? {
        discussionUrl: `https://awoo.or.kr/issues/topics/${encodeURIComponent(post.freshness.trendingTerm)}/`,
      }
    : {}),
  // Cycle #6 P0-4: audience + mentions — 페르소나 매칭 + glossary entity 그래프 연결
  // relatedPersonas/relatedSubsidies는 이미 .data 객체 추출됨 (Map.get 결과)
  ...(relatedPersonas.length > 0
    ? {
        audience: {
          '@type': 'PeopleAudience',
          audienceType: relatedPersonas.map((p) => p.label).join(', '),
        },
      }
    : {}),
  ...(relatedSubsidies.length > 0
    ? {
        mentions: relatedSubsidies.map((s) => ({
          '@type': 'GovernmentService',
          '@id': `https://awoo.or.kr/subsidies/${s.id}/#govservice`,
          name: s.title,
        })),
      }
    : {}),
};

// Cycle #26: speakable schema — FAQ를 음성 검색 (Google Assistant, Bixby 등) 친화적으로 마킹
const faqSchema = post.faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: post.faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.a,
    },
  })),
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['.tldr', '.faq-section'],
  },
} : null;

const breadcrumbs = [
  { name: '홈', href: '/' },
  { name: '오늘의 이슈', href: '/issues/' },
  { name: post.title, href: `/issues/${date}/${slug}/` },
];

// 읽기 시간 — 한국어 분당 평균 500자 기준
function readingTimeMinutes(): number {
  const all =
    (post.tldr ?? []).join(' ') +
    ' ' +
    post.sections.map((s) => `${s.heading} ${s.lead} ${s.body}`).join(' ') +
    ' ' +
    post.faq.map((f) => `${f.q} ${f.a}`).join(' ');
  const chars = all.replace(/\s+/g, '').length;
  return Math.max(1, Math.round(chars / 500));
}
const readMin = readingTimeMinutes();

// Cycle #23 P0-3: thin post auto-noindex (AdSense 정책 정합)
// 평가 결과: "확인 필요" 같은 broad claims만 있는 글이 거부 사유. 자동 검사로 차단.
const fullText = [
  post.metaDescription ?? '',
  ...(post.tldr ?? []),
  ...post.sections.map((s) => `${s.heading} ${s.lead} ${s.body}`),
  ...post.faq.map((f) => `${f.q} ${f.a}`),
].join(' ');
const totalChars = fullText.replace(/\s+/g, '').length;
const vagueCount = (fullText.match(/(확인\s*필요|문의\s*요망|확인\s*해|공식\s*공고\s*참조)/g) ?? []).length;
const factCheckScore = (post as { factCheckScore?: number }).factCheckScore ?? 1;
// thin 기준: 본문 1500자 미만 OR vague 표현 5건 이상 OR factCheck < 0.6
const isThinPost = totalChars < 1500 || vagueCount >= 5 || factCheckScore < 0.6;
---

<BaseLayout
  title={`${post.title} | 지원금가이드`}
  description={post.metaDescription}
  activeNav="/issues/"
  breadcrumbs={breadcrumbs}
  noindex={isThinPost}
  ogType="article"
  ogArticle={{
    publishedTime: post.publishedAt,
    modifiedTime: post.publishedAt,
    author: '김준혁',
    section: post.category,
    tags: post.tags,
  }}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

  <script>
    // 공유 — Web Share API 우선, 없으면 clipboard, 모두 실패 시 prompt
    const btn = document.querySelector<HTMLButtonElement>('[data-share-btn]');
    if (btn) {
      const url = btn.dataset.shareUrl ?? window.location.href;
      const title = btn.dataset.shareTitle ?? document.title;
      const original = btn.textContent;
      btn.addEventListener('click', async () => {
        try {
          if (typeof navigator.share === 'function') {
            await navigator.share({ title, url });
            return;
          }
          await navigator.clipboard.writeText(url);
          btn.textContent = '✓ 링크 복사됨';
        } catch {
          window.prompt('복사할 링크', url);
        } finally {
          setTimeout(() => {
            if (btn.textContent !== original) btn.textContent = original;
          }, 2000);
        }
      });
    }
  </script>

  <article class="band">
    <Container size="wide">
      <a class="back-link" href="/">← 홈으로</a>

      <header class="hero">
        <div class="meta">
          {post.freshness && (
            <a
              class="freshness-pill"
              href={`/issues/topics/${encodeURIComponent(post.freshness.trendingTerm)}/`}
              title={`${post.freshness.trendingTerm} 토픽 hub로 이동`}
            >
              <span class="dot" aria-hidden="true" />
              {post.freshness.daysActive}일 연속 화제
              {post.freshness.totalCount > 0 && ` · ${post.freshness.totalCount}건 보도`}
            </a>
          )}
          <span class="cat-pill">{post.category}</span>
          <span class="date">{post.date}</span>
          <span class="read-time" aria-label={`${readMin}분 분량`}>📖 {readMin}분</span>
          <button
            type="button"
            class="share-btn"
            data-share-btn
            data-share-url={`https://awoo.or.kr/issues/${date}/${slug}/`}
            data-share-title={post.title}
            aria-live="polite"
          >🔗 공유</button>
        </div>

        <h1 class="title">{post.title}</h1>

        {/* Cycle #23: AI 사용 disclosure 글 단위 명시 (E-E-A-T 신호 + AdSense 정책 정합) */}
        <aside class="ai-disclosure" aria-label="AI 활용 명시">
          <span class="ai-icon" aria-hidden="true">✓</span>
          <span class="ai-text">
            <strong>AI 보조 작성</strong> · 편집책임자
            <a href="/editor/jjh/">김준혁</a> 검수 · Fact-check {(((post as { factCheckScore?: number }).factCheckScore ?? 0) * 100).toFixed(0)}%
            <a class="ai-policy" href="/editorial-policy/">편집 정책</a>
          </span>
        </aside>

        {post.tldr.length > 0 && (
          <div class="tldr">
            <div class="tldr-label">핵심 요약</div>
            <ul>
              {post.tldr.map((t) => <li>{t}</li>)}
            </ul>
          </div>
        )}

        <div class="core-facts">
          <div class="fact"><div class="lbl">대상</div><div class="val">{post.coreFacts.who}</div></div>
          <div class="fact"><div class="lbl">금액</div><div class="val">{post.coreFacts.amount}</div></div>
          <div class="fact"><div class="lbl">기간</div><div class="val">{post.coreFacts.deadline}</div></div>
          <div class="fact"><div class="lbl">신청</div><div class="val">{post.coreFacts.where}</div></div>
        </div>
      </header>

      <div class="body-grid">
        <main class="body">
          {post.sections.map((s, i) => {
            // Cycle #35: anchor id 자동 생성 — AI 답변 엔진 + 검색 결과 deep-link
            const anchorId = `sec-${i + 1}`;
            return (
            <section class="post-section" id={anchorId}>
              <h2>
                <a class="sec-anchor" href={`#${anchorId}`} aria-label={`${s.heading} 섹션 직접 링크`}>
                  {s.heading}
                </a>
              </h2>
              <p class="lead">{s.lead}</p>
              <div class="prose">
                {paragraphsAndLists(s.body).map((block) =>
                  block.type === 'p' ? (
                    <p set:html={block.html} />
                  ) : (
                    <ul>
                      {block.items.map((item) => <li set:html={item} />)}
                    </ul>
                  ),
                )}
              </div>
            </section>
          );})}

          {post.table && (
            <section class="post-section">
              <h2>{post.table.title}</h2>
              <div class="table-wrap">
                <table>
                  <thead>
                    <tr>{post.table.headers.map((h) => <th>{h}</th>)}</tr>
                  </thead>
                  <tbody>
                    {post.table.rows.map((row) => (
                      <tr>{row.map((cell) => <td>{cell}</td>)}</tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </section>
          )}

          {relatedSubsidies.length > 0 && (
            <section class="post-section">
              <h2>이 이슈와 함께 보면 좋은 지원금</h2>
              <ul class="related-grid">
                {relatedSubsidies.map((s) => (
                  <li>
                    <a class="related-card" href={`/subsidies/${s.id}/`}>
                      <div class={`media tint-${s.category}`}>
                        <Icon name={s.icon} size={22} strokeWidth={1.6} />
                      </div>
                      <div class="rc-body">
                        <div class="rc-cat">{s.category} · {s.agency}</div>
                        <div class="rc-title">{s.title}</div>
                        <div class="rc-amt">
                          {s.amount > 0 ? formatWon(s.amount) : '내용 확인'}
                          {s.amount > 0 && <span class="rc-unit">{s.amountLabel}</span>}
                        </div>
                      </div>
                      <span class="rc-arrow" aria-hidden="true">→</span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}

          {relatedPersonas.length > 0 && (
            <section class="post-section">
              <h2>이런 분에게 추천</h2>
              <ul class="persona-row">
                {relatedPersonas.map((p) => (
                  <li>
                    <a class="persona-chip" href={`/personas/${p.id}/`}>
                      <Icon name={p.icon} size={16} strokeWidth={1.7} />
                      <span>{p.label}</span>
                      <span class="rc-arrow" aria-hidden="true">→</span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}

          {post.faq.length > 0 && (
            <section class="post-section">
              <h2>자주 묻는 질문</h2>
              <div class="faq">
                {post.faq.map((f) => (
                  <details class="faq-item">
                    <summary>{f.q}</summary>
                    <p>{f.a}</p>
                  </details>
                ))}
              </div>
            </section>
          )}

          {post.sources.length > 0 && (
            <section class="post-section sources" id="sources">
              <h2>
                <a class="sec-anchor" href="#sources">원문 출처 {post.sources.length}건</a>
              </h2>
              <p class="sources-lead">
                본 분석은 <strong>{new Set(post.sources.map((s) => s.publisher)).size}곳 매체 {post.sources.length}건</strong>의 보도를 종합했습니다.
                매체별로 보도 각도가 다를 수 있어, 가능한 모든 출처를 명시합니다.
              </p>
              <ul class="sources-grid">
                {post.sources.map((src) => (
                  <li>
                    <a class="source-card" href={src.url} target="_blank" rel="nofollow noopener noreferrer">
                      <div class="src-meta">
                        <span class="src-publisher">{src.publisher}</span>
                        {src.pubDate && <span class="src-date">{(src.pubDate as string).slice(0, 10)}</span>}
                      </div>
                      <div class="src-title">{src.title}</div>
                      <span class="src-cta">원문 보기 →</span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}

          <section class="next-actions">
            <div class="na-eyebrow">다음 단계</div>
            <h2>이 이슈를 보셨다면</h2>
            <ul class="na-grid">
              <li>
                <a class="na-card na-primary" href="/quick/">
                  <div class="na-step">1</div>
                  <div class="na-body">
                    <div class="na-title">5분 진단으로 정확히 매칭</div>
                    <div class="na-desc">페르소나·소득·관심 분야 4단계 — 입력은 익명, 저장 X.</div>
                  </div>
                  <span class="na-arrow" aria-hidden="true">→</span>
                </a>
              </li>
              {relatedSubsidies[0] && (
                <li>
                  <a class="na-card" href={`/subsidies/${relatedSubsidies[0].id}/`}>
                    <div class="na-step">2</div>
                    <div class="na-body">
                      <div class="na-title">관련 지원금 바로 보기</div>
                      <div class="na-desc">{relatedSubsidies[0].title} · {relatedSubsidies[0].agency}</div>
                    </div>
                    <span class="na-arrow" aria-hidden="true">→</span>
                  </a>
                </li>
              )}
              {relatedPersonas[0] && (
                <li>
                  <a class="na-card" href={`/personas/${relatedPersonas[0].id}/`}>
                    <div class="na-step">3</div>
                    <div class="na-body">
                      <div class="na-title">{relatedPersonas[0].label} 전체 지원금</div>
                      <div class="na-desc">같은 상황의 사람들이 받는 지원금 모아보기.</div>
                    </div>
                    <span class="na-arrow" aria-hidden="true">→</span>
                  </a>
                </li>
              )}
              <li>
                <a class="na-card" href="/guide/">
                  <div class="na-step">+</div>
                  <div class="na-body">
                    <div class="na-title">신청 가이드</div>
                    <div class="na-desc">서류 준비 · 공식 사이트 · 처리 기간까지 한 번에.</div>
                  </div>
                  <span class="na-arrow" aria-hidden="true">→</span>
                </a>
              </li>
            </ul>
          </section>
        </main>

        <aside class="rail">
          <div class="rail-card">
            <div class="rail-eyebrow">5분 진단</div>
            <div class="rail-title">받을 수 있는 지원금이 뭔지 빠르게 확인</div>
            <a class="rail-cta" href="/subsidies/">전체 지원금 둘러보기 →</a>
          </div>
          <div class="rail-card">
            <div class="rail-eyebrow">신청 흐름</div>
            <div class="rail-title">정부 지원금 신청 단계 가이드</div>
            <a class="rail-cta" href="/guide/">신청 가이드 →</a>
          </div>
        </aside>
      </div>

      {(prevPost || nextPost) && (
        <nav class="post-nav" aria-label="다른 분석 포스트">
          {prevPost ? (
            <a class="pn-link prev" href={`/issues/${prevPost.date}/${prevPost.slug}/`} rel="prev">
              <span class="pn-label">← 이전 포스트</span>
