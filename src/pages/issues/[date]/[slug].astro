---
import Container from '@/components/Container.astro';
import Icon from '@/components/Icon.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { formatWon } from '@/data/site-data';
import { type GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';

interface Source {
  title: string;
  url: string;
  publisher: string;
  pubDate?: string;
}
interface FaqItem {
  q: string;
  a: string;
}
interface Section {
  heading: string;
  lead: string;
  body: string;
}
interface PostTable {
  title: string;
  headers: string[];
  rows: string[][];
}
interface PostData {
  title: string;
  slug: string;
  metaDescription: string;
  tldr: string[];
  category: string;
  tags: string[];
  coreFacts: { who: string; amount: string; deadline: string; where: string };
  freshness?: { trendingTerm: string; daysActive: number; totalCount: number; rankToday: number };
  sections: Section[];
  table?: PostTable;
  faq: FaqItem[];
  relatedSubsidies: string[];
  relatedPersonas: string[];
  sources: Source[];
  publishedAt: string;
  date: string;
}

export const getStaticPaths = (() => {
  // 빌드타임 — Vite glob (getStaticPaths 호이스팅 호환 위해 함수 내부 정의)
  const issueModules = import.meta.glob<{ default: PostData }>(
    '/src/data/issues/*/*.json',
    { eager: true },
  );
  const paths: { params: { date: string; slug: string }; props: { post: PostData } }[] = [];
  for (const [path, mod] of Object.entries(issueModules)) {
    // path 예: /src/data/issues/2026-04-29/some-slug.json
    const m = path.match(/\/issues\/(\d{4}-\d{2}-\d{2})\/([^/]+)\.json$/);
    if (!m) continue;
    const date = m[1];
    const slug = m[2];
    if (slug.startsWith('_')) continue; // _history.json 등 메타 파일 제외
    paths.push({ params: { date, slug }, props: { post: mod.default } });
  }
  return paths;
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { date, slug } = Astro.params;

const subsidies = await getCollection('subsidies');
const subsidyById = new Map(subsidies.map((s) => [s.data.id, s.data]));
const relatedSubsidies = post.relatedSubsidies
  .map((id) => subsidyById.get(id))
  .filter((x): x is NonNullable<ReturnType<typeof subsidyById.get>> => x !== undefined);

const personas = await getCollection('personas');
const personaById = new Map(personas.map((p) => [p.data.id, p.data]));
const relatedPersonas = post.relatedPersonas
  .map((id) => personaById.get(id))
  .filter((x): x is NonNullable<ReturnType<typeof personaById.get>> => x !== undefined);

// JSON-LD — NewsArticle 강화 (mainEntityOfPage·articleSection·inLanguage 등)
const canonicalUrl = `https://awoo.or.kr/issues/${date}/${slug}/`;
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  '@id': canonicalUrl,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
  headline: post.title,
  description: post.metaDescription,
  url: canonicalUrl,
  inLanguage: 'ko-KR',
  datePublished: post.publishedAt,
  dateModified: post.publishedAt,
  articleSection: post.category,
  keywords: post.tags.join(', '),
  about: post.freshness?.trendingTerm ?? post.tags[0],
  // 본 사이트는 AI 보조 + 사람 편집 정책 (editorial-policy 페이지 명시)
  author: {
    '@type': 'Organization',
    name: '지원금가이드 편집팀',
    url: 'https://awoo.or.kr/editorial-policy/',
  },
  publisher: {
    '@type': 'Organization',
    name: '스마트데이터샵',
    url: 'https://awoo.or.kr',
    logo: {
      '@type': 'ImageObject',
      url: 'https://awoo.or.kr/og-default.png',
      width: 1200,
      height: 630,
    },
  },
  image: ['https://awoo.or.kr/og-default.png'],
  isAccessibleForFree: true,
};

const faqSchema = post.faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: post.faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.a,
    },
  })),
} : null;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: 'https://awoo.or.kr/' },
    { '@type': 'ListItem', position: 2, name: '오늘의 이슈', item: 'https://awoo.or.kr/issues/' },
    { '@type': 'ListItem', position: 3, name: post.title, item: `https://awoo.or.kr/issues/${date}/${slug}/` },
  ],
};
---

<BaseLayout
  title={`${post.title} | 지원금가이드`}
  description={post.metaDescription}
  activeNav="/issues/"
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <article class="band">
    <Container size="wide">
      <a class="back-link" href="/">← 홈으로</a>

      <header class="hero">
        <div class="meta">
          {post.freshness && (
            <span class="freshness-pill">
              <span class="dot" aria-hidden="true" />
              {post.freshness.daysActive}일 연속 트렌딩 · {post.freshness.totalCount}회 매체 언급
            </span>
          )}
          <span class="cat-pill">{post.category}</span>
          <span class="date">{post.date}</span>
        </div>

        <h1 class="title">{post.title}</h1>

        {post.tldr.length > 0 && (
          <div class="tldr">
            <div class="tldr-label">핵심 요약</div>
            <ul>
              {post.tldr.map((t) => <li>{t}</li>)}
            </ul>
          </div>
        )}

        <div class="core-facts">
          <div class="fact"><div class="lbl">대상</div><div class="val">{post.coreFacts.who}</div></div>
          <div class="fact"><div class="lbl">금액</div><div class="val">{post.coreFacts.amount}</div></div>
          <div class="fact"><div class="lbl">기간</div><div class="val">{post.coreFacts.deadline}</div></div>
          <div class="fact"><div class="lbl">신청</div><div class="val">{post.coreFacts.where}</div></div>
        </div>
      </header>

      <div class="body-grid">
        <main class="body">
          {post.sections.map((s) => (
            <section class="post-section">
              <h2>{s.heading}</h2>
              <p class="lead">{s.lead}</p>
              <div class="prose">
                {s.body.split(/\n\n+/).map((para) => <p>{para}</p>)}
              </div>
            </section>
          ))}

          {post.table && (
            <section class="post-section">
              <h2>{post.table.title}</h2>
              <div class="table-wrap">
                <table>
                  <thead>
                    <tr>{post.table.headers.map((h) => <th>{h}</th>)}</tr>
                  </thead>
                  <tbody>
                    {post.table.rows.map((row) => (
                      <tr>{row.map((cell) => <td>{cell}</td>)}</tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </section>
          )}

          {relatedSubsidies.length > 0 && (
            <section class="post-section">
              <h2>이 이슈와 함께 보면 좋은 지원금</h2>
              <ul class="related-grid">
                {relatedSubsidies.map((s) => (
                  <li>
                    <a class="related-card" href={`/subsidies/${s.id}/`}>
                      <div class={`media tint-${s.category}`}>
                        <Icon name={s.icon} size={22} strokeWidth={1.6} />
                      </div>
                      <div class="rc-body">
                        <div class="rc-cat">{s.category} · {s.agency}</div>
                        <div class="rc-title">{s.title}</div>
                        <div class="rc-amt">
                          {s.amount > 0 ? formatWon(s.amount) : '내용 확인'}
                          {s.amount > 0 && <span class="rc-unit">{s.amountLabel}</span>}
                        </div>
                      </div>
                      <span class="rc-arrow" aria-hidden="true">→</span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}

          {relatedPersonas.length > 0 && (
            <section class="post-section">
              <h2>이런 분에게 추천</h2>
              <ul class="persona-row">
                {relatedPersonas.map((p) => (
                  <li>
                    <a class="persona-chip" href={`/personas/${p.id}/`}>
                      <Icon name={p.icon} size={16} strokeWidth={1.7} />
                      <span>{p.label}</span>
                      <span class="rc-arrow" aria-hidden="true">→</span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}

          {post.faq.length > 0 && (
            <section class="post-section">
              <h2>자주 묻는 질문</h2>
              <div class="faq">
                {post.faq.map((f) => (
                  <details class="faq-item">
                    <summary>{f.q}</summary>
                    <p>{f.a}</p>
                  </details>
                ))}
              </div>
            </section>
          )}

          {post.sources.length > 0 && (
            <section class="post-section sources">
              <h2>원문 출처</h2>
              <ul class="sources-list">
                {post.sources.map((src) => (
                  <li>
                    <a href={src.url} target="_blank" rel="noopener noreferrer">
                      [{src.publisher}] {src.title}
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}

          <section class="next-actions">
            <div class="na-eyebrow">다음 단계</div>
            <h2>이 이슈를 보셨다면</h2>
            <ul class="na-grid">
              <li>
                <a class="na-card na-primary" href="/quick/">
                  <div class="na-step">1</div>
                  <div class="na-body">
                    <div class="na-title">5분 진단으로 정확히 매칭</div>
                    <div class="na-desc">페르소나·소득·관심 분야 4단계 — 입력은 익명, 저장 X.</div>
                  </div>
                  <span class="na-arrow" aria-hidden="true">→</span>
                </a>
              </li>
              {relatedSubsidies.length > 0 && (
                <li>
                  <a class="na-card" href={`/subsidies/${relatedSubsidies[0].id}/`}>
                    <div class="na-step">2</div>
                    <div class="na-body">
                      <div class="na-title">관련 지원금 바로 보기</div>
                      <div class="na-desc">{relatedSubsidies[0].title} · {relatedSubsidies[0].agency}</div>
                    </div>
                    <span class="na-arrow" aria-hidden="true">→</span>
                  </a>
                </li>
              )}
              {relatedPersonas.length > 0 && (
                <li>
                  <a class="na-card" href={`/personas/${relatedPersonas[0].id}/`}>
                    <div class="na-step">3</div>
                    <div class="na-body">
                      <div class="na-title">{relatedPersonas[0].label} 전체 지원금</div>
                      <div class="na-desc">같은 상황의 사람들이 받는 지원금 모아보기.</div>
                    </div>
                    <span class="na-arrow" aria-hidden="true">→</span>
                  </a>
                </li>
              )}
              <li>
                <a class="na-card" href="/guide/">
                  <div class="na-step">+</div>
                  <div class="na-body">
                    <div class="na-title">신청 가이드</div>
                    <div class="na-desc">서류 준비 · 공식 사이트 · 처리 기간까지 한 번에.</div>
                  </div>
                  <span class="na-arrow" aria-hidden="true">→</span>
                </a>
              </li>
            </ul>
          </section>
        </main>

        <aside class="rail">
          <div class="rail-card">
            <div class="rail-eyebrow">5분 진단</div>
            <div class="rail-title">받을 수 있는 지원금이 뭔지 빠르게 확인</div>
            <a class="rail-cta" href="/subsidies/">전체 지원금 둘러보기 →</a>
          </div>
          <div class="rail-card">
            <div class="rail-eyebrow">신청 흐름</div>
            <div class="rail-title">정부 지원금 신청 단계 가이드</div>
            <a class="rail-cta" href="/guide/">신청 가이드 →</a>
          </div>
        </aside>
      </div>
    </Container>
  </article>
</BaseLayout>

<style>
  .band {
    padding: 32px 0 80px;
  }

  .back-link {
    display: inline-block;
    color: var(--text-2);
    font-size: 14px;
    text-decoration: none;
    margin-bottom: 20px;
  }
  .back-link:hover { text-decoration: underline; }

  .hero {
    margin-bottom: 28px;
    max-width: 760px;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }

  .freshness-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    background: rgb(0 113 227 / 0.12);
    color: var(--accent);
    border-radius: var(--radius-pill);
    font-size: 13px;
    font-weight: 700;
  }
  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse-dot 1.6s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.3); }
  }
  @media (prefers-reduced-motion: reduce) { .dot { animation: none; } }

  .cat-pill {
    padding: 3px 10px;
    background: var(--surface-2);
    color: var(--text-2);
    border-radius: var(--radius-pill);
    font-size: 13px;
    font-weight: 600;
  }
  .date {
    color: var(--text-3);
    font-size: 13px;
  }

  .title {
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin: 0 0 20px;
  }

  .tldr {
    background: var(--surface-2);
    border-radius: var(--radius-md);
    padding: 18px 22px;
    margin: 0 0 24px;
  }
  .tldr-label {
    font-size: 12px;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 8px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .tldr ul { margin: 0; padding-left: 18px; }
  .tldr li { font-size: 15px; line-height: 1.6; color: var(--text); margin: 4px 0; }

  .core-facts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 12px;
  }
  .fact {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 14px 16px;
  }
  .lbl { font-size: 12px; color: var(--text-2); margin-bottom: 4px; }
  .val { font-size: 15px; font-weight: 600; line-height: 1.4; }

  .body-grid {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 32px;
  }
  @media (max-width: 880px) {
    .body-grid { grid-template-columns: 1fr; }
  }

  .body { min-width: 0; }

  .post-section {
    margin: 32px 0;
  }
  .post-section h2 {
    font-size: clamp(20px, 2.4vw, 26px);
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin: 0 0 12px;
  }
  .lead {
    font-size: 17px;
    font-weight: 600;
    color: var(--text);
    line-height: 1.55;
    margin: 0 0 12px;
  }
  .prose {
    color: var(--text);
    line-height: 1.7;
    font-size: 16px;
  }
  .prose p { margin: 12px 0; }

  .table-wrap { overflow-x: auto; }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }
  th, td {
    padding: 10px 14px;
    border: 1px solid var(--border);
    text-align: left;
  }
  th {
    background: var(--surface-2);
    font-weight: 600;
  }

  .related-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 12px;
  }
  .related-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: transform 0.18s var(--ease-standard), border-color 0.18s var(--ease-standard);
  }
  .related-card:hover {
    transform: translateY(-2px);
    border-color: var(--border-2);
    text-decoration: none;
  }
  .media {
    width: 40px; height: 40px; border-radius: var(--radius-sm);
    display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .tint-주거 { background: rgb(0 113 227 / 0.12); color: var(--accent); }
  .tint-자산 { background: rgb(8 145 178 / 0.12); color: #0891b2; }
  .tint-교육 { background: rgb(139 92 246 / 0.12); color: #8b5cf6; }
  .tint-창업 { background: rgb(234 88 12 / 0.12); color: #ea580c; }
  .tint-복지 { background: rgb(236 72 153 / 0.12); color: #ec4899; }
  .tint-취업 { background: rgb(16 185 129 / 0.12); color: #10b981; }
  .tint-농업 { background: rgb(217 119 6 / 0.12); color: #d97706; }

  .rc-body { flex: 1; min-width: 0; }
  .rc-cat { font-size: 12px; color: var(--accent-link); }
  .rc-title { font-size: 14px; font-weight: 600; line-height: 1.3; margin: 2px 0; }
  .rc-amt { font-size: 16px; font-weight: 700; color: var(--accent); margin-top: 4px; }
  .rc-unit { font-size: 12px; color: var(--text-2); font-weight: 500; margin-left: 4px; }
  .rc-arrow {
    color: var(--text-3);
    transition: transform 0.18s var(--ease-standard), color 0.18s var(--ease-standard);
  }
  .related-card:hover .rc-arrow {
    transform: translateX(3px);
    color: var(--accent);
  }

  .persona-row {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .persona-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    font-size: 14px;
    color: var(--text);
    text-decoration: none;
  }
  .persona-chip:hover {
    border-color: var(--border-2);
    text-decoration: none;
  }

  .faq-item {
    border-bottom: 1px solid var(--border);
    padding: 12px 0;
  }
  .faq-item summary {
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    padding: 4px 0;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before { content: 'Q '; color: var(--accent); font-weight: 700; }
  .faq-item p { margin: 8px 0 4px; padding-left: 22px; color: var(--text-2); line-height: 1.6; }
  .faq-item p::before { content: ''; }

  .sources { font-size: 13px; color: var(--text-2); }
  .sources-list { margin: 0; padding-left: 18px; }
  .sources-list li { margin: 4px 0; }
  .sources-list a { color: var(--accent-link); text-decoration: none; }
  .sources-list a:hover { text-decoration: underline; }

  .rail { display: flex; flex-direction: column; gap: 12px; }
  .rail-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 18px 20px;
  }
  .rail-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .rail-title {
    font-size: 15px;
    font-weight: 600;
    line-height: 1.4;
    margin-bottom: 10px;
  }
  .rail-cta {
    display: inline-block;
    color: var(--accent-link);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
  }
  .rail-cta:hover { text-decoration: underline; }

  /* Next actions */
  .next-actions {
    margin-top: 48px;
    padding: 28px 24px;
    background: var(--bg-alt);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
  }
  .na-eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .next-actions h2 {
    font-size: clamp(20px, 2.4vw, 26px);
    font-weight: 700;
    margin: 0 0 18px;
    letter-spacing: -0.01em;
  }
  .na-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 12px;
  }
  .na-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 18px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: transform 0.18s var(--ease-standard), border-color 0.18s var(--ease-standard);
  }
  .na-card:hover {
    transform: translateY(-2px);
    border-color: var(--border-2);
