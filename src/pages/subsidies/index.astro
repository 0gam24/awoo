---
import Container from '@/components/Container.astro';
import Icon from '@/components/Icon.astro';
import PageHeader from '@/components/PageHeader.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { CATEGORIES, formatWon } from '@/data/site-data';
import { isNew } from '@/lib/subsidies-meta';
import { buildCollectionPage } from '@/lib/schema';
import { getCollection } from 'astro:content';

const subsidies = await getCollection('subsidies');
// 정렬: NEW > HOT > 나머지
const sorted = [...subsidies].sort((a, b) => {
  const an = isNew(a.data.id) ? 2 : a.data.isHot ? 1 : 0;
  const bn = isNew(b.data.id) ? 2 : b.data.isHot ? 1 : 0;
  return bn - an;
});

// 정렬용 키 — 클라이언트 JS 정렬에 사용
function deadlineRank(s: { deadline?: string; status?: string }): number {
  // 작을수록 임박. '곧 마감' 최우선 → 0
  if (s.status === '곧 마감') return 0;
  const d = (s.deadline ?? '').trim();
  // 'D-N일' 패턴
  const dMatch = d.match(/D[-−]\s*(\d+)/);
  if (dMatch) return 1 + parseInt(dMatch[1], 10);
  // 'M.D' 또는 '~M.D' 패턴 → 1xxxx
  const mdMatch = d.match(/(\d{1,2})[.\/](\d{1,2})/);
  if (mdMatch) {
    const m = parseInt(mdMatch[1], 10);
    const day = parseInt(mdMatch[2], 10);
    return 1000 + m * 31 + day;
  }
  // '상시' '연중' 등 → 가장 뒤
  return 99999;
}

function popularityRank(s: { id: string; isHot?: boolean }): number {
  // 큰 값일수록 상위
  if (isNew(s.id)) return 2;
  if (s.isHot) return 1;
  return 0;
}

const NA_LABEL: Record<string, string> = {
  주거: '주택·임대 우선공급',
  복지: '맞춤 복지 혜택',
  교육: '학비·장학 지원',
  창업: '사업·자금 지원',
  취업: '취업·고용 혜택',
  자산: '자산 형성 혜택',
  농업: '영농 정착 지원',
};
const naLabel = (cat: string) => NA_LABEL[cat] ?? '맞춤 혜택';

const categoryCounts = subsidies.reduce<Record<string, number>>((acc, s) => {
  acc[s.data.category] = (acc[s.data.category] ?? 0) + 1;
  return acc;
}, {});

const categoriesWithCount = CATEGORIES.map((c) => ({
  ...c,
  count: c.id === 'all' ? subsidies.length : (categoryCounts[c.id] ?? 0),
}));

const collectionSchema = buildCollectionPage({
  name: `정부 지원금 ${subsidies.length}개`,
  description: '전 국민 대상 정부 지원금을 분야·페르소나별로 정리한 목록.',
  pageUrl: '/subsidies/',
  items: sorted.slice(0, 100).map((s) => ({ url: `/subsidies/${s.data.id}/`, name: s.data.title })),
});
---

<BaseLayout
  title={`정부 지원금 ${subsidies.length}개 둘러보기 — 지원금가이드`}
  description={`전 국민 대상 정부 지원금 ${subsidies.length}개를 분야·페르소나별로 정리. 청년 월세, 신혼 특공, 청년도약계좌, 소상공인 정책자금 등.`}
  activeNav="/subsidies/"
  breadcrumbs={[
    { name: '홈', href: '/' },
    { name: '지원금', href: '/subsidies/' },
  ]}
>
  <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />

  <section class="band">
    <Container size="wide">
      <PageHeader
        eyebrow="둘러보기"
        title="지원금 둘러보기"
        lead={`전 국민 대상 정부 지원금 <strong>${subsidies.length}개</strong>를 분야·페르소나별로 살펴보세요.`}
      />

      <div class="filter-rail" aria-label="분야 필터">
        {
          categoriesWithCount.map((c) => (
            <a
              class="chip"
              data-chip-cat={c.id}
              href={c.id === 'all' ? '/subsidies/' : `/subsidies/?category=${encodeURIComponent(c.id)}`}
            >
              <Icon name={c.icon} size={14} />
              {c.name}
              <span class="cnt">{c.count}</span>
            </a>
          ))
        }
      </div>

      <div class="sort-rail" aria-label="정렬">
        <span class="sort-label">정렬</span>
        <button class="sort-btn active" type="button" data-sort="popular">인기순</button>
        <button class="sort-btn" type="button" data-sort="amount">금액 큰순</button>
        <button class="sort-btn" type="button" data-sort="deadline">마감 임박순</button>
      </div>

      <p class="empty-msg" id="empty-msg" hidden>해당 분야의 지원금이 없습니다.</p>

      <ul class="subsidy-grid" id="subsidy-grid">
        {
          sorted.map((s) => (
            <li
              data-cat={s.data.category}
              data-amount={s.data.amount ?? 0}
              data-deadline-rank={deadlineRank(s.data)}
              data-popularity-rank={popularityRank(s.data)}
            >
              <a class={`subsidy-card cat-${s.data.category}`} href={`/subsidies/${s.data.id}/`}>
                <div class={`media tint-${s.data.category}`}>
                  <Icon name={s.data.icon} size={26} strokeWidth={1.6} />
                </div>
                <div class="body">
                  <div class="meta-row">
                    <span class="badge neutral">{s.data.category}</span>
                    {isNew(s.data.id) && <span class="badge new">NEW</span>}
                    {s.data.status === '곧 마감' && <span class="badge warning">곧 마감</span>}
                    {s.data.isHot && !isNew(s.data.id) && <span class="badge accent">HOT</span>}
                    {s.data.status === '신청 가능' && !s.data.isHot && !isNew(s.data.id) && (
                      <span class="badge open"><span class="open-dot" aria-hidden="true" />신청 가능</span>
                    )}
                  </div>
                  <div class="agency">{s.data.agency}</div>
                  <div class="t">{s.data.title}</div>
                  <div class="sum">{s.data.summary.slice(0, 64)}{s.data.summary.length > 64 ? '…' : ''}</div>
                  {s.data.tags && s.data.tags.length > 0 && (
                    <div class="tag-row">
                      {s.data.tags.slice(0, 3).map((t) => (
                        <span class="tag-chip">#{t}</span>
                      ))}
                    </div>
                  )}
                  <div class="amt-row">
                    {s.data.amount > 0 ? (
                      <div class="amt">
                        {formatWon(s.data.amount)}
                        <span class="unit">{s.data.amountLabel}</span>
                      </div>
                    ) : (
                      <div class={`amt-hook tone-${s.data.category}`}>
                        <span class="amt-hook-dot" aria-hidden="true" />
                        <span class="amt-hook-label">{naLabel(s.data.category)}</span>
                      </div>
                    )}
                    <span class="arrow-cta" aria-hidden="true">→</span>
                  </div>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </Container>
  </section>
</BaseLayout>

<script>
  type SortKey = 'popular' | 'amount' | 'deadline';
  let currentSort: SortKey = 'popular';

  const sortItems = () => {
    const grid = document.getElementById('subsidy-grid');
    if (!grid) return;
    const items = Array.from(grid.querySelectorAll<HTMLLIElement>(':scope > li'));
    items.sort((a, b) => {
      if (currentSort === 'amount') {
        return (Number(b.dataset.amount) || 0) - (Number(a.dataset.amount) || 0);
      }
      if (currentSort === 'deadline') {
        return (Number(a.dataset.deadlineRank) || 0) - (Number(b.dataset.deadlineRank) || 0);
      }
      // popular
      return (Number(b.dataset.popularityRank) || 0) - (Number(a.dataset.popularityRank) || 0);
    });
    items.forEach((li) => grid.appendChild(li));
  };

  const apply = () => {
    const params = new URLSearchParams(window.location.search);
    const active = params.get('category') || 'all';
    let visible = 0;
    document.querySelectorAll<HTMLLIElement>('.subsidy-grid li').forEach((li) => {
      const cat = li.dataset.cat;
      const show = active === 'all' || cat === active;
      li.hidden = !show;
      if (show) visible++;
    });
    document.querySelectorAll<HTMLAnchorElement>('.chip').forEach((chip) => {
      chip.classList.toggle('active', chip.dataset.chipCat === active);
    });
    const empty = document.getElementById('empty-msg');
    if (empty) empty.hidden = visible !== 0;
  };

  // Intercept chip clicks to use history.pushState (no full reload)
  document.querySelectorAll<HTMLAnchorElement>('.chip').forEach((chip) => {
    chip.addEventListener('click', (e) => {
      const cat = chip.dataset.chipCat;
      if (!cat) return;
      e.preventDefault();
      const url = cat === 'all' ? '/subsidies/' : `/subsidies/?category=${encodeURIComponent(cat)}`;
      history.pushState({ cat }, '', url);
      apply();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });

  // Sort button clicks
  document.querySelectorAll<HTMLButtonElement>('.sort-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const sort = btn.dataset.sort as SortKey | undefined;
      if (!sort || sort === currentSort) return;
      currentSort = sort;
      document.querySelectorAll<HTMLButtonElement>('.sort-btn').forEach((b) => {
        b.classList.toggle('active', b.dataset.sort === sort);
      });
      sortItems();
    });
  });

  window.addEventListener('popstate', apply);
  apply();
</script>

<style>
  .band {
    padding: 48px 0 80px;
  }

  .filter-rail {
    display: flex;
    gap: 8px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }

  .sort-rail {
    display: flex;
    gap: 6px;
    align-items: center;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }

  .sort-label {
    font-size: 13px;
    color: var(--text-2);
    margin-right: 4px;
  }

  .sort-btn {
    padding: 6px 12px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    color: var(--text-2);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }

  .sort-btn:hover {
    background: var(--surface-2);
    color: var(--text);
    border-color: var(--border-2);
  }

  .sort-btn.active {
    background: var(--text);
    color: var(--bg);
    border-color: var(--text);
  }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    background: var(--surface-2);
    border-radius: var(--radius-pill);
    text-decoration: none;
    color: var(--text);
    font-size: 13px;
    font-weight: 500;
    transition: background 0.15s;
  }

  .chip:hover {
    background: var(--surface);
    border: 1px solid var(--border-2);
    text-decoration: none;
    padding: 7px 13px;
  }

  .chip.active {
    background: var(--accent);
    color: var(--on-accent);
    border: none;
    padding: 8px 14px;
  }

  .chip.active .cnt {
    background: rgb(255 255 255 / 0.22);
    color: #ffffff;
  }

  .empty-msg {
    text-align: center;
    padding: 48px 16px;
    color: var(--text-2);
    font-size: 15px;
  }

  .cnt {
    background: var(--surface);
    color: var(--text-2);
    border-radius: var(--radius-pill);
    padding: 1px 8px;
    font-size: 12px;
    font-weight: 700;
    margin-left: 4px;
  }

  .subsidy-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
  }

  .subsidy-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 4px solid var(--cat-color, var(--border-2));
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: transform 0.18s var(--ease-standard), border-color 0.18s;
  }
  .subsidy-card:hover {
    transform: translateY(-3px);
    text-decoration: none;
  }

  .media {
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--surface-2);
  }

  .tint-주거 {
    background: rgb(0 113 227 / 0.12);
    color: var(--accent);
  }
  .tint-자산 {
    background: rgb(8 145 178 / 0.12);
    color: #0891b2;
  }
  .tint-교육 {
    background: rgb(139 92 246 / 0.12);
    color: #8b5cf6;
  }
  .tint-창업 {
    background: rgb(234 88 12 / 0.12);
    color: #ea580c;
  }
  .tint-복지 {
    background: rgb(236 72 153 / 0.12);
    color: #ec4899;
  }
  .tint-취업 {
    background: rgb(16 185 129 / 0.12);
    color: #10b981;
  }
  .tint-농업 {
    background: rgb(217 119 6 / 0.12);
    color: #d97706;
  }

  .body {
    padding: 18px 20px 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .meta-row {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .badge {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 6px;
  }

  .badge.neutral {
    background: var(--surface-2);
    color: var(--text-2);
  }
  .badge.warning {
    background: rgb(247 195 96 / 0.18);
    color: var(--color-warning);
  }
  .badge.accent {
    background: rgb(220 38 38 / 0.16);
    color: #dc2626;
  }

  .badge.new {
    background: rgb(0 113 227 / 0.14);
    color: var(--accent);
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .badge.open {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: rgb(0 133 89 / 0.14);
    color: var(--color-success);
  }

  .open-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-success);
    animation: pulse-open 1.6s ease-in-out infinite;
  }

  @keyframes pulse-open {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.55; transform: scale(1.18); }
  }

  @media (prefers-reduced-motion: reduce) {
    .open-dot { animation: none; }
  }

  .tag-row {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: 2px;
  }

  .tag-chip {
    font-size: 12px;
    color: var(--text-2);
    background: var(--surface-2);
    padding: 2px 8px;
    border-radius: var(--radius-pill);
    line-height: 1.4;
  }

  .amt-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-top: 6px;
    gap: 12px;
  }

  .arrow-cta {
    font-size: 18px;
    color: var(--text-3);
    font-weight: 600;
    transition: transform 0.18s var(--ease-standard), color 0.18s var(--ease-standard);
  }

  .subsidy-card:hover .arrow-cta {
    transform: translateX(4px);
    color: var(--accent);
  }

  .amt-hook {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 6px 12px;
    border-radius: var(--radius-pill);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .amt-hook-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: currentColor;
    animation: hook-dot-pulse 1.6s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes hook-dot-pulse {
    0%, 100% { opacity: 0.55; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.35); }
  }

  @media (prefers-reduced-motion: reduce) {
    .amt-hook-dot { animation: none; }
  }

  .amt-hook.tone-주거 {
    background: rgb(0 113 227 / 0.12);
    color: var(--accent);
  }
  .amt-hook.tone-자산 {
    background: rgb(8 145 178 / 0.12);
    color: #0891b2;
  }
  .amt-hook.tone-교육 {
    background: rgb(139 92 246 / 0.12);
    color: #8b5cf6;
  }
  .amt-hook.tone-창업 {
    background: rgb(234 88 12 / 0.12);
    color: #ea580c;
  }
  .amt-hook.tone-복지 {
    background: rgb(236 72 153 / 0.12);
    color: #ec4899;
  }
  .amt-hook.tone-취업 {
    background: rgb(16 185 129 / 0.12);
    color: #10b981;
  }
  .amt-hook.tone-농업 {
    background: rgb(217 119 6 / 0.12);
    color: #d97706;
  }

  .agency {
    font-size: 13px;
    color: var(--accent-link);
    font-weight: 500;
  }

  .t {
    font-size: 17px;
    font-weight: 600;
    line-height: 1.4;
    margin-bottom: 4px;
  }

  .sum {
    font-size: 13px;
    color: var(--text-2);
    line-height: 1.5;
    flex: 1;
  }

  .amt {
    font-size: 22px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .amt .unit {
    font-size: 13px;
    color: var(--text-2);
    font-weight: 500;
    margin-left: 4px;
  }
</style>
