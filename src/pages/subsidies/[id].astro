---
import BlufBox from '@/components/BlufBox.astro';
import Container from '@/components/Container.astro';
import Icon from '@/components/Icon.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { formatWon, CATEGORY_FAQS } from '@/data/site-data';
import { isNew, isStale, getRegDateISO, getLastVerifiedKR, STALE_THRESHOLD_DAYS } from '@/lib/subsidies-meta';
import { type GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';

export const getStaticPaths = (async () => {
  const subsidies = await getCollection('subsidies');
  return subsidies.map((s) => ({ params: { id: s.data.id }, props: { subsidy: s } }));
}) satisfies GetStaticPaths;

const { subsidy } = Astro.props;
const s = subsidy.data;

const personas = await getCollection('personas');
const matchedPersonas = s.targetPersonas
  .map((pid) => personas.find((p) => p.data.id === pid)?.data)
  .filter(Boolean);

const allSubsidies = await getCollection('subsidies');
const related = allSubsidies
  .filter((x) => x.data.category === s.category && x.data.id !== s.id)
  .slice(0, 3);

// "이 지원금 받는 사람들이 또 받는 것" — 같은 페르소나 교집합 + 다른 카테고리 우선
// (페르소나 매칭은 강한 신호, 카테고리는 너무 좁아서 다양성 확보 필요)
function personaOverlap(otherPersonas: string[]): number {
  if (!otherPersonas?.length || !s.targetPersonas.length) return 0;
  let n = 0;
  for (const p of otherPersonas) if (s.targetPersonas.includes(p)) n++;
  return n;
}

const alsoSeen = allSubsidies
  .filter((x) => {
    if (x.data.id === s.id) return false;
    if (x.data.category === s.category) return false; // related 와 중복 방지
    return personaOverlap(x.data.targetPersonas ?? []) > 0;
  })
  .map((x) => ({
    item: x,
    score:
      personaOverlap(x.data.targetPersonas ?? []) * 10 +
      (x.data.isHot ? 3 : 0) +
      (x.data.status === '신청 가능' ? 2 : 0),
  }))
  .sort((a, b) => b.score - a.score)
  .slice(0, 4)
  .map((x) => x.item);

const regDateISO = getRegDateISO(s.id);
const isNewItem = isNew(s.id);
const isStaleItem = isStale(s.id);
const lastVerifiedKR = getLastVerifiedKR(s.id);

// FAQ + rejectionReasons 매칭 — topics.json에서 (category 일치 + persona 교집합) 토픽 우선
const allTopics = await getCollection('topics');
const matchedTopic = allTopics.find((t) => {
  const sameCategory = t.data.category === s.category;
  const personaOverlap = (t.data.mainPersonas ?? []).some((p) => s.targetPersonas.includes(p));
  return sameCategory && personaOverlap;
})?.data ?? allTopics.find((t) => t.data.category === s.category)?.data;

// matchedTopic 0건일 때 카테고리 공통 FAQ로 fallback (Cycle #3 P0-3)
const subsidyFaqs = matchedTopic?.faq ?? CATEGORY_FAQS[s.category] ?? [];
const subsidyRejections = matchedTopic?.rejectionReasons ?? [];

// BLUF 자동 통계 (Cycle #3 P0-4) — schema와 본문 인용 단위 동시 확보
const personaLabels = matchedPersonas
  .map((p) => p?.label)
  .filter((x): x is string => Boolean(x));
const personaSummary = personaLabels.length > 0
  ? `${personaLabels.slice(0, 2).join('·')}${personaLabels.length > 2 ? ' 외' : ''}`
  : '대상 확인 필요';
const blufSummarySubsidy = `${s.title}은 ${s.agency}이 제공하는 ${s.category} 분야 지원금입니다. ${formatWon(s.amount)} ${s.amountLabel}, ${personaSummary}이 받을 수 있습니다.`;
const blufStatsSubsidy = [
  { value: `${formatWon(s.amount)}`, label: s.amountLabel || '지원 금액' },
  { value: s.deadline, label: '신청 마감' },
  { value: personaSummary, label: '매칭 페르소나' },
  { value: s.status, label: '신청 상태' },
];

const faqSchema = subsidyFaqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `https://awoo.or.kr/subsidies/${s.id}/#faq`,
  mainEntity: subsidyFaqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
} : null;

const govSchema = {
  '@context': 'https://schema.org',
  '@type': 'GovernmentService',
  name: s.title,
  serviceType: s.category,
  provider: {
    '@type': 'GovernmentOrganization',
    name: s.agency,
  },
  audience: {
    '@type': 'PeopleAudience',
    audienceType: matchedPersonas.map((p) => p?.label).filter(Boolean).join(', '),
  },
  description: s.summary,
  url: s.applyUrl,
  termsOfService: s.eligibility.join(' / '),
  // 1차 자료 — 정부 공식 신청처 URL을 schema 차원에서 명시 (GEO/AI 인용 핵심 신호)
  isBasedOn: s.applyUrl,
  availableChannel: {
    '@type': 'ServiceChannel',
    serviceUrl: s.applyUrl,
    availableLanguage: 'ko',
  },
  // 사이트와이드 Organization을 publisher로 참조 (Cycle #1 P0-2 자산)
  publisher: { '@id': 'https://awoo.or.kr/#organization' },
  ...(regDateISO ? { dateCreated: regDateISO } : {}),
};

const breadcrumbs = [
  { name: '홈', href: '/' },
  { name: '지원금', href: '/subsidies/' },
  { name: s.category, href: `/categories/${encodeURIComponent(s.category)}/` },
  { name: s.title, href: `/subsidies/${s.id}/` },
];
---

<BaseLayout
  title={`${s.title} — ${s.agency} | 지원금가이드`}
  description={s.summary}
  activeNav="/subsidies/"
  breadcrumbs={breadcrumbs}
>
  <section class="detail-hero">
    <Container size="wide">
      <a class="back-link" href="/subsidies/">← 둘러보기로</a>
      <div class="hero-grid">
        <div>
          <div class="agency">{s.agency} · {s.category}{isNewItem && <span class="new-pill"><span class="new-dot" aria-hidden="true" />NEW</span>}</div>
          <h1 class="title">{s.title}</h1>
          <div class="amount-row">
            <span class="amount">{formatWon(s.amount)}</span>
            <span class="unit">{s.amountLabel}</span>
          </div>
          {s.monthly && <div class="monthly">{s.monthly}</div>}
          <p class="summary">{s.summary}</p>
          <div class="tags">
            {s.tags.map((t) => <span class="tag">#{t}</span>)}
          </div>
        </div>

        <aside class="apply-rail">
          <div class="rail-row">
            <span>적용 대상</span>
          </div>
          <div class="persona-mini-row">
            {
              matchedPersonas.slice(0, 4).map((p) =>
                p ? (
                  <span class="persona-mini">
                    <Icon name={p.icon} size={13} strokeWidth={1.8} />
                    {p.label}
                  </span>
                ) : null,
              )
            }
          </div>
          <div class="rail-row dl-row">
            <span>마감</span>
            <strong>{s.deadline}</strong>
          </div>
          <div class="rail-row dl-row">
            <span>상태</span>
            <strong class={s.status === '곧 마감' ? 'st-warn' : 'st-ok'}>{s.status}</strong>
          </div>
          <a class="btn-primary" href={s.applyUrl} target="_blank" rel="noopener noreferrer">
            공식 신청처로 이동
            <Icon name="arrow-up-right" size={16} />
          </a>
          <p class="disclaimer">
            지원금가이드는 정보 안내 사이트로, 신청 대행은 하지 않습니다.
            실제 신청은 정부24·복지로 등 공식 사이트에서 진행됩니다.
          </p>
          {(lastVerifiedKR || isStaleItem) && (
            <p class={`verified-info ${isStaleItem ? 'stale' : ''}`}>
              {isStaleItem && <span class="verified-warn" aria-hidden="true">⚠</span>}
              마지막 동기화: <strong>{lastVerifiedKR ?? '확인 필요'}</strong>
              {isStaleItem && (
                <span class="verified-stale-msg">
                  · {STALE_THRESHOLD_DAYS}일 이상 미검증 — 공식 사이트 최신 정보 확인 권장
                </span>
              )}
            </p>
          )}
        </aside>
      </div>
    </Container>
  </section>

  <section class="band alt">
    <Container size="wide">
      <BlufBox summary={blufSummarySubsidy} stats={blufStatsSubsidy} basis={lastVerifiedKR ? `마지막 동기화: ${lastVerifiedKR}` : '보조금24 + 큐레이션'} />
      <div class="two-col">
        <div>
          <h2 class="utility">지원 대상</h2>
          <ul class="checklist">
            {
              s.eligibility.map((e) => (
                <li>
                  <span class="check"><Icon name="check" size={14} strokeWidth={2.4} /></span>
                  <span>{e}</span>
                </li>
              ))
            }
          </ul>
        </div>
        <div>
          <h2 class="utility">혜택 내용</h2>
          <ul class="checklist">
            {
              s.benefits.map((b) => (
                <li>
                  <span class="check check-success"><Icon name="check" size={14} strokeWidth={2.4} /></span>
                  <span>{b}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </Container>
  </section>

  <section class="band">
    <Container size="wide">
      <div class="two-col">
        <div>
          <h2 class="utility">신청 방법 & 일정</h2>
          <dl class="kv-grid">
            <dt>주관 기관</dt><dd>{s.agency}</dd>
            <dt>지원 기간</dt><dd>{s.period}</dd>
            <dt>마감일</dt><dd>{s.deadline}</dd>
            <dt>처리 기간</dt><dd>평균 14일</dd>
            <dt>신청 방법</dt><dd>온라인 / 방문 접수</dd>
          </dl>
        </div>
        <div>
          <h2 class="utility">필요 서류</h2>
          <ul class="doc-list">
            {
              s.documents.map((d) => (
                <li>
                  <Icon name="doc" size={18} />
                  <span>{d}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </Container>
  </section>

  {subsidyRejections.length > 0 && (
    <section class="band alt">
      <Container size="wide">
        <h2 class="display">자주 거절되는 사유와 해결</h2>
        <p class="section-lead">{s.category} 분야 지원금에서 자주 발생하는 거절 사례입니다. 신청 전 미리 확인하면 거절 가능성을 낮출 수 있습니다.</p>
        <ul class="rj-list">
          {subsidyRejections.map((r) => (
            <li class="rj-card">
              <div class="rj-cause"><span class="rj-tag">사유</span> {r.cause}</div>
              <div class="rj-fix"><span class="rj-tag fix">해결</span> {r.fix}</div>
            </li>
          ))}
        </ul>
      </Container>
    </section>
  )}

  {subsidyFaqs.length > 0 && (
    <section class="band">
      <Container size="wide">
        <h2 class="display">자주 묻는 질문</h2>
        <div class="faq-list">
          {subsidyFaqs.map((f) => (
            <details class="faq-item">
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </Container>
    </section>
  )}

  {
    related.length > 0 && (
      <section class="band alt">
        <Container size="wide">
          <h2 class="display">비슷한 지원금</h2>
          <ul class="related-grid">
            {related.map((r) => (
              <li>
                <a class="related-card" href={`/subsidies/${r.data.id}/`}>
                  <Icon name={r.data.icon} size={28} strokeWidth={1.6} />
                  <div>
                    <div class="r-agency">{r.data.agency}</div>
                    <div class="r-title">{r.data.title}</div>
                    <div class="r-amount">{formatWon(r.data.amount)} {r.data.amountLabel}</div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </Container>
      </section>
    )
  }

  {
    alsoSeen.length > 0 && (
      <section class="band">
        <Container size="wide">
          <div class="display-row">
            <h2 class="display">이 지원금 받는 분들이 또 보는 것</h2>
            <p class="display-sub">같은 페르소나에 매칭되는 다른 분야 지원금</p>
          </div>
          <ul class="also-grid">
            {alsoSeen.map((r) => (
              <li>
                <a class="also-card" href={`/subsidies/${r.data.id}/`}>
                  <div class={`also-tint tint-${r.data.category}`}>
                    <Icon name={r.data.icon} size={22} strokeWidth={1.6} />
                  </div>
                  <div class="also-body">
                    <div class="also-meta">
                      <span class="also-cat">{r.data.category}</span>
                      <span class="also-agency">{r.data.agency}</span>
                    </div>
                    <div class="also-title">{r.data.title}</div>
                    {r.data.amount > 0 && (
                      <div class="also-amount">
                        {formatWon(r.data.amount)} <span class="also-unit">{r.data.amountLabel}</span>
                      </div>
                    )}
                  </div>
                  <span class="also-arrow" aria-hidden="true">→</span>
                </a>
              </li>
            ))}
          </ul>
        </Container>
      </section>
    )
  }

  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(govSchema)}
  />

  {faqSchema && (
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(faqSchema)}
    />
  )}
</BaseLayout>

<style>
  .detail-hero {
    padding: 56px 0 48px;
    border-bottom: 1px solid var(--border);
  }

  .back-link {
    display: inline-block;
    margin-bottom: 16px;
    color: var(--text-2);
    text-decoration: none;
    font-size: 13px;
  }
  .back-link:hover {
    color: var(--text);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 48px;
  }
  @media (max-width: 880px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  .agency {
    font-size: 13px;
    color: var(--accent-link);
    font-weight: 500;
    margin-bottom: 6px;
  }

  .new-pill {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    margin-left: 8px;
    padding: 2px 9px;
    background: rgb(0 113 227 / 0.14);
    color: var(--accent);
    border-radius: var(--radius-pill);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .new-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: currentColor;
    animation: new-pulse 1.6s ease-in-out infinite;
  }

  @keyframes new-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.55; transform: scale(1.3); }
  }

  @media (prefers-reduced-motion: reduce) {
    .new-dot { animation: none; }
  }

  .title {
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 16px;
  }

  .amount-row {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    margin-bottom: 4px;
  }

  .amount {
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 700;
    color: var(--accent);
    letter-spacing: -0.025em;
    line-height: 1;
  }

  .unit {
    font-size: 14px;
    color: var(--text-2);
    font-weight: 500;
  }

  .monthly {
    font-size: 16px;
    color: var(--text-2);
    margin-bottom: 16px;
  }

  .summary {
    font-size: 16px;
    color: var(--text-2);
    line-height: 1.65;
    max-width: 520px;
    margin: 0 0 16px;
  }

  .tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 13px;
    color: var(--text-2);
  }

  .apply-rail {
    background: var(--surface-2);
    border-radius: var(--radius-xl);
    padding: 24px;
  }

  .rail-row {
    display: flex;
    justify-content: space-between;
    font-size: 13px;
    color: var(--text-2);
    margin-bottom: 8px;
  }

  .dl-row {
    border-top: 1px solid var(--border);
    padding-top: 8px;
    margin-bottom: 8px;
  }

  .dl-row strong {
    color: var(--text);
    font-weight: 600;
  }

  .st-warn {
    color: var(--color-warning);
  }
  .st-ok {
    color: var(--color-success);
  }

  .persona-mini-row {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }

  .persona-mini {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 10px;
    background: var(--surface);
    border-radius: var(--radius-pill);
    font-size: 13px;
  }

  .btn-primary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 20px;
    background: var(--accent);
    color: var(--on-accent);
    text-decoration: none;
    border-radius: var(--radius-pill);
    font-size: 16px;
    font-weight: 600;
    margin-top: 12px;
  }
  .btn-primary:hover {
    background: color-mix(in oklch, var(--accent), black 8%);
    text-decoration: none;
  }

  .disclaimer {
    font-size: 12px;
    color: var(--text-3);
    line-height: 1.5;
    margin: 12px 0 0;
    text-align: center;
  }

  .verified-info {
    font-size: 11px;
    color: var(--text-2);
    line-height: 1.5;
    margin: 8px 0 0;
    padding: 8px 12px;
    background: var(--surface);
    border-radius: var(--radius-sm);
    text-align: center;
  }

  .verified-info.stale {
    background: rgb(247 195 96 / 0.12);
    color: var(--text-2);
  }

  .verified-warn {
    color: var(--color-warning);
    font-weight: 700;
    margin-right: 4px;
  }

  .verified-stale-msg {
    display: block;
    margin-top: 2px;
    font-size: 10px;
  }

  .band {
    padding: 56px 0;
  }
  .band.alt {
    background: var(--bg-alt);
  }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }
  @media (max-width: 720px) {
    .two-col {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  .utility {
    font-size: 19px;
    font-weight: 600;
    margin: 0 0 16px;
  }

  .checklist {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .checklist li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 12px 16px;
    background: var(--surface);
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
    font-size: 15px;
    line-height: 1.55;
  }

  .check {
    width: 24px;
    height: 24px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--accent);
    color: var(--on-accent);
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .check-success {
    background: var(--color-success);
  }

  .kv-grid {
    margin: 0;
    display: grid;
    grid-template-columns: 100px 1fr;
    row-gap: 12px;
  }

  .kv-grid dt {
    font-size: 13px;
    color: var(--text-2);
  }

  .kv-grid dd {
    margin: 0;
    font-size: 14px;
    color: var(--text);
    font-weight: 500;
  }

  .doc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .doc-list li {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    font-size: 14px;
    color: var(--text);
    font-weight: 500;
  }

  .display {
    font-size: clamp(22px, 2.6vw, 30px);
    font-weight: 600;
    margin: 0 0 24px;
  }

  .related-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 12px;
  }

  .related-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: transform 0.18s var(--ease-standard);
  }
  .related-card:hover {
    transform: translateY(-2px);
    text-decoration: none;
  }

