---
// 마감 + 30일 경과로 sweep 된 지원금 안내 페이지
// 본 라우트는 _archived/ 데이터에서 빌드타임 생성됨 (collection 외부)
//
// 시청자에게: "이 지원금은 마감되었습니다 + 비슷한 지원금 N건"
// SEO: noindex (검색 인덱스에서는 제거)

import Container from '@/components/Container.astro';
import Icon from '@/components/Icon.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { type GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';

interface ArchivedSubsidy {
  id: string;
  title: string;
  agency: string;
  category: string;
  icon: string;
  summary: string;
}

export const getStaticPaths = (() => {
  const modules = import.meta.glob<{ default: ArchivedSubsidy }>(
    '/src/data/subsidies/_archived/*.json',
    { eager: true },
  );
  const paths = [];
  for (const [path, mod] of Object.entries(modules)) {
    const m = path.match(/_archived\/([^/]+)\.json$/);
    const slug = m?.[1];
    if (!slug || slug.startsWith('_')) continue;
    paths.push({
      params: { slug },
      props: { subsidy: mod.default },
    });
  }
  return paths;
}) satisfies GetStaticPaths;

const { subsidy } = Astro.props as { subsidy: ArchivedSubsidy };

// 같은 카테고리에서 활성 지원금 추천
const allActive = await getCollection('subsidies');
const similar = allActive
  .filter((s) => s.data.category === subsidy.category && s.data.id !== subsidy.id)
  .slice(0, 4);
---

<BaseLayout
  title={`${subsidy.title} (마감) — 지원금가이드`}
  description={`${subsidy.title}은 신청이 종료되었습니다. ${subsidy.category} 분야 활성 지원금을 확인하세요.`}
  activeNav="/subsidies/"
>
  <Fragment slot="head">
    <meta name="robots" content="noindex,follow" />
  </Fragment>

  <section class="band">
    <Container size="narrow">
      <div class="status-pill">
        <span class="dot" aria-hidden="true" />
        신청 종료
      </div>

      <h1 class="title">{subsidy.title}</h1>

      <p class="lead">
        본 지원금은 마감되어 더 이상 신청할 수 없습니다.
        본 페이지는 정보 보존을 위해 유지되며 검색엔진에는 노출되지 않습니다.
      </p>

      <dl class="meta">
        <dt>주관 기관</dt>
        <dd>{subsidy.agency}</dd>
        <dt>분야</dt>
        <dd>{subsidy.category}</dd>
      </dl>

      {subsidy.summary && <p class="summary">{subsidy.summary}</p>}

      <div class="actions">
        <a class="btn-primary" href={`/subsidies/?category=${encodeURIComponent(subsidy.category)}`}>
          {subsidy.category} 분야 활성 지원금 보기 →
        </a>
        <a class="btn-ghost" href="/subsidies/">전체 지원금</a>
        <a class="btn-ghost" href="/quick/">5분 진단으로 매칭</a>
      </div>

      {similar.length > 0 && (
        <section class="similar">
          <h2 class="similar-title">비슷한 활성 지원금</h2>
          <ul class="similar-list">
            {similar.map((s) => (
              <li>
                <a class="sim-card" href={`/subsidies/${s.data.id}/`}>
                  <div class={`media tint-${s.data.category}`}>
                    <Icon name={s.data.icon} size={22} strokeWidth={1.6} />
                  </div>
                  <div class="sim-body">
                    <div class="sim-cat">{s.data.category} · {s.data.agency}</div>
                    <div class="sim-title">{s.data.title}</div>
                  </div>
                  <span class="sim-arrow" aria-hidden="true">→</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}
    </Container>
  </section>
</BaseLayout>

<style>
  .band {
    padding: 64px 0 80px;
  }

  .status-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    background: var(--surface-2);
    color: var(--text-2);
    border-radius: var(--radius-pill);
    font-size: 13px;
    font-weight: 700;
    margin-bottom: 16px;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--text-3);
  }

  .title {
    font-size: clamp(26px, 3.6vw, 36px);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin: 0 0 16px;
    color: var(--text);
  }

  .lead {
    font-size: 16px;
    color: var(--text-2);
    line-height: 1.65;
    margin: 0 0 28px;
    padding: 14px 18px;
    background: var(--bg-alt);
    border-left: 3px solid var(--border-2);
    border-radius: var(--radius-md);
  }

  .meta {
    display: grid;
    grid-template-columns: 100px 1fr;
    row-gap: 8px;
    column-gap: 16px;
    margin: 0 0 24px;
  }

  .meta dt {
    font-size: 13px;
    color: var(--text-2);
  }

  .meta dd {
    margin: 0;
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
  }

  .summary {
    font-size: 14px;
    color: var(--text-2);
    line-height: 1.6;
    margin: 0 0 32px;
    padding: 16px 20px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }

  .actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 48px;
  }

  .btn-primary,
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: 10px 18px;
    border-radius: var(--radius-pill);
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
  }

  .btn-primary {
    background: var(--accent);
    color: var(--on-accent);
  }
  .btn-primary:hover {
    background: color-mix(in oklch, var(--accent), black 8%);
    text-decoration: none;
  }

  .btn-ghost {
    background: var(--surface-2);
    color: var(--text);
  }
  .btn-ghost:hover {
    background: var(--surface);
    border: 1px solid var(--border-2);
    padding: 9px 17px;
    text-decoration: none;
  }

  .similar-title {
    font-size: 18px;
    font-weight: 700;
    margin: 0 0 14px;
  }

  .similar-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .sim-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, transform 0.15s;
  }

  .sim-card:hover {
    border-color: var(--border-2);
    transform: translateY(-1px);
    text-decoration: none;
  }

  .media {
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }

  .tint-주거 { background: rgb(0 113 227 / 0.12); color: var(--accent); }
  .tint-자산 { background: rgb(8 145 178 / 0.12); color: #0891b2; }
  .tint-교육 { background: rgb(139 92 246 / 0.12); color: #8b5cf6; }
  .tint-창업 { background: rgb(234 88 12 / 0.12); color: #ea580c; }
  .tint-복지 { background: rgb(236 72 153 / 0.12); color: #ec4899; }
  .tint-취업 { background: rgb(16 185 129 / 0.12); color: #10b981; }
  .tint-농업 { background: rgb(217 119 6 / 0.12); color: #d97706; }

  .sim-body {
    flex: 1;
    min-width: 0;
  }

  .sim-cat {
    font-size: 12px;
    color: var(--text-2);
  }

  .sim-title {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.3;
    margin-top: 2px;
  }

  .sim-arrow {
    color: var(--text-3);
    flex-shrink: 0;
    transition: transform 0.15s, color 0.15s;
  }

  .sim-card:hover .sim-arrow {
    transform: translateX(3px);
    color: var(--accent);
  }
</style>
