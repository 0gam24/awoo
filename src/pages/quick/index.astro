---
import BlufBox from '@/components/BlufBox.astro';
import Container from '@/components/Container.astro';
import Icon from '@/components/Icon.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { MEDIAN_INCOME } from '@/data/site-data';
import { getCollection } from 'astro:content';

const subsidies = await getCollection('subsidies');
const personas = await getCollection('personas');

// 클라이언트 필터링용 압축 데이터 — 필수 필드만
// Cycle #4 P0-4: summary를 80자로 미리 잘라 페이로드 감축 (~10KB 추정 절감)
const compactSubsidies = subsidies.map((s) => ({
  id: s.data.id,
  title: s.data.title,
  agency: s.data.agency,
  category: s.data.category,
  amount: s.data.amount,
  amountLabel: s.data.amountLabel,
  status: s.data.status,
  // 결과 카드에 80자만 표시되므로 클라이언트에 80자만 전송
  summary: (s.data.summary ?? '').slice(0, 80),
  targetPersonas: s.data.targetPersonas ?? [],
  tags: s.data.tags ?? [],
  isHot: !!s.data.isHot,
}));

const compactPersonas = personas.map((p) => ({
  id: p.data.id,
  label: p.data.label,
  sub: p.data.sub,
  icon: p.data.icon,
  bg: p.data.bg,
}));

const STEP_LABELS = [
  { num: 1, label: '페르소나', sub: '나는 누구인가' },
  { num: 2, label: '가구·소득', sub: '얼마 버는가' },
  { num: 3, label: '관심 분야', sub: '뭐가 필요한가' },
  { num: 4, label: '라이프 이벤트', sub: '최근 일' },
];

const CATEGORIES = [
  { id: '주거', icon: 'cat-housing' },
  { id: '취업', icon: 'cat-employment' },
  { id: '창업', icon: 'cat-startup' },
  { id: '교육', icon: 'cat-education' },
  { id: '복지', icon: 'cat-welfare' },
  { id: '자산', icon: 'cat-wealth' },
  { id: '농업', icon: 'cat-farm' },
];

const EVENTS = [
  { key: '출산', icon: 'cat-baby', tags: ['출산', '육아', '아동', '부모', '맘'] },
  { key: '결혼', icon: 'p-newlywed-family', tags: ['신혼', '결혼', '부부'] },
  { key: '이사', icon: 'cat-housing', tags: ['주거', '월세', '전세', '임대', '주택'] },
  { key: '실직', icon: 'cat-employment', tags: ['실업', '구직', '취업', '재취업'] },
  { key: '창업', icon: 'cat-startup', tags: ['창업', '소상공인', '사업'] },
  { key: '은퇴', icon: 'p-senior', tags: ['노후', '은퇴', '중장년', '시니어'] },
  { key: '입학', icon: 'cat-education', tags: ['학자금', '교육', '장학', '학비', '입학'] },
];
---

<BaseLayout
  title="5분 만에 받을 수 있는 지원금 찾기 | 지원금가이드"
  description="간단한 4단계 진단으로 본인 상황에 맞는 정부 지원금을 즉시 매칭. 페르소나·소득·관심분야·라이프이벤트 기반 자동 추천."
  activeNav="/subsidies/"
  breadcrumbs={[
    { name: '홈', href: '/' },
    { name: '5분 진단', href: '/quick/' },
  ]}
>
  <section class="hero">
    <Container size="wide">
      <div class="head">
        <span class="badge"><span class="dot" aria-hidden="true" />5분 진단</span>
        <h1 class="title">받을 수 있는 지원금을<br />5분 안에 찾아드려요</h1>
        <p class="lead">
          4가지 질문에 답하면, 정부 지원금 <strong>{subsidies.length}건</strong> 중 본인 상황에 가장 적합한 것들을 자동 매칭합니다.<br />
          <span class="lead-pii">개인정보 저장 0 — 모든 결과는 브라우저에서만 계산</span>
        </p>
      </div>

      <BlufBox
        summary={`정부 지원금 ${subsidies.length}건을 페르소나·소득·관심분야 4질문으로 매칭합니다. 5분 내 본인 상황에 맞는 지원금을 자동 추천하며 개인정보는 저장되지 않습니다.`}
        stats={[
          { value: '5분', label: '평균 진단 시간' },
          { value: '4질문', label: '입력 단계' },
          { value: `${subsidies.length}건`, label: '매칭 후보' },
          { value: '저장 0', label: '개인정보 처리' },
        ]}
        basis="브라우저 내 계산 · 서버 전송 X"
      />

      <div class="quick-app" data-quick-app>
        <!-- 진행 스텝퍼 -->
        <ol class="stepper" aria-label="진행 단계">
          {
            STEP_LABELS.map((s) => (
              <li class="stepper-item" data-stepper-item={s.num}>
                <div class="step-circle">
                  <span class="step-circle-num">{s.num}</span>
                  <span class="step-circle-check" aria-hidden="true">✓</span>
                </div>
                <div class="step-meta">
                  <div class="step-name">{s.label}</div>
                  <div class="step-sub">{s.sub}</div>
                </div>
              </li>
            ))
          }
          <li class="stepper-item stepper-result" data-stepper-item="result">
            <div class="step-circle">
              <span class="step-circle-num">★</span>
            </div>
            <div class="step-meta">
              <div class="step-name">결과</div>
              <div class="step-sub">매칭 지원금</div>
            </div>
          </li>
        </ol>

        <!-- Step 1: 페르소나 -->
        <div class="step active" data-step="1">
          <div class="q-row">
            <h2 class="q">현재 상황과 가장 가까운 것은?</h2>
            <p class="q-sub">하나만 선택해주세요 · 매칭 정확도 가장 큰 영향</p>
          </div>
          <div class="persona-grid">
            {
              compactPersonas.map((p) => (
                <label class="persona-card" data-persona-card>
                  <input type="radio" name="persona" value={p.id} />
                  <div class={`p-icon bg-${p.bg}`}>
                    <Icon name={p.icon} size={28} strokeWidth={1.5} />
                  </div>
                  <div class="p-text">
                    <div class="p-label">{p.label}</div>
                    <div class="p-sub">{p.sub}</div>
                  </div>
                  <span class="p-check" aria-hidden="true">✓</span>
                </label>
              ))
            }
          </div>
          <div class="error-msg" data-error-msg hidden>페르소나를 하나 선택해주세요</div>
        </div>

        <!-- Step 2: 가구·소득 -->
        <div class="step" data-step="2">
          <div class="q-row">
            <h2 class="q">가구원 수와 월 소득을 알려주세요</h2>
            <p class="q-sub">소득 구간별 자격 기준 매칭에 사용됩니다 (저장 X)</p>
          </div>

          <div class="field">
            <label class="field-label">가구원 수</label>
            <div class="size-row">
              {[1, 2, 3, 4, 5, 6].map((n) => (
                <label class="size-btn">
                  <input type="radio" name="hh-size" value={n} checked={n === 1} />
                  <span>{n}인</span>
                </label>
              ))}
            </div>
          </div>

          <div class="field">
            <div class="income-label-row">
              <label class="field-label" for="income-input">월 소득 (세전)</label>
              <div class="income-input-wrap">
                <input
                  id="income-input"
                  type="number"
                  min="0"
                  max="2000"
                  step="10"
                  value="250"
                  class="income-input"
                  data-income-input
                />
                <span class="income-input-unit">만원</span>
              </div>
            </div>
            <input
              type="range"
              min="0"
              max="1000"
              step="10"
              value="250"
              class="income-slider"
              data-income-slider
              aria-label="월 소득 슬라이더"
            />
            <div class="income-meta">
              <div class="income-pct" data-income-pct>중위 100%</div>
              <div class="income-tier" data-income-tier>중간 소득 구간</div>
            </div>
          </div>
        </div>

        <!-- Step 3: 관심 분야 -->
        <div class="step" data-step="3">
          <div class="q-row">
            <h2 class="q">관심 있는 분야를 모두 선택하세요</h2>
            <p class="q-sub">여러 개 선택 가능 · 비워두면 모든 분야 대상</p>
          </div>
          <div class="cat-grid">
            {
              CATEGORIES.map((c) => (
                <label class={`cat-chip tint-${c.id}`}>
                  <input type="checkbox" name="category" value={c.id} />
                  <Icon name={c.icon} size={16} strokeWidth={1.7} />
                  <span>{c.id}</span>
                </label>
              ))
            }
          </div>
        </div>

        <!-- Step 4: 이벤트 (선택) -->
        <div class="step" data-step="4">
          <div class="q-row">
            <h2 class="q">최근 또는 곧 있을 일이 있나요?</h2>
            <p class="q-sub">선택사항 · 라이프 이벤트별 지원금 추가 매칭</p>
          </div>
          <div class="cat-grid">
            {
              EVENTS.map((e) => (
                <label class="cat-chip">
                  <input type="checkbox" name="event" value={e.key} data-tags={e.tags.join(',')} />
                  <Icon name={e.icon} size={16} strokeWidth={1.7} />
                  <span>{e.key}</span>
                </label>
              ))
            }
          </div>
        </div>

        <!-- 결과 -->
        <div class="step result" data-step="result">
          <div class="result-head">
            <h2 class="result-title">당신에게 추천하는 지원금</h2>
            <div class="result-summary" data-result-summary></div>
          </div>

          <ul class="result-list" data-result-list></ul>

          <div class="result-empty" data-result-empty hidden>
            <div class="empty-mark">🤔</div>
            <h3>매칭된 지원금이 없어요</h3>
            <p>조건이 너무 좁을 수 있어요. 아래에서 다음 단계를 선택해 주세요.</p>
            <div class="empty-actions">
              <button type="button" class="btn-primary" data-btn-relax>조건 완화 다시 시도</button>
              <a class="btn-ghost" href="/subsidies/">전체 지원금 둘러보기</a>
            </div>
          </div>

          <div class="result-followups">
            <div class="result-personas" data-result-personas></div>
            <div class="result-actions">
              <button type="button" class="btn-ghost" data-btn-restart>← 다시 진단</button>
              <button type="button" class="btn-ghost" data-btn-share aria-live="polite">🔗 결과 링크 복사</button>
              <a class="btn-link" href="/situations/">상황별 보기 →</a>
              <a class="btn-link" href="/categories/">분야별 보기 →</a>
            </div>
          </div>
        </div>

        <!-- 하단 네비 -->
        <div class="nav-row" data-nav-row>
          <button type="button" class="btn-ghost" data-btn-prev hidden>← 이전</button>
          <span class="nav-spacer"></span>
          <button type="button" class="btn-primary" data-btn-next>다음 →</button>
          <button type="button" class="btn-primary btn-submit" data-btn-submit hidden>★ 결과 보기</button>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

<script is:inline define:vars={{ compactSubsidies, compactPersonas, MEDIAN_INCOME }}>
  // ============================================================
  // 5분 진단 — 클라이언트 사이드 폼 + 매칭
  // ============================================================

  const TOTAL_STEPS = 4;
  let current = 1;

  const root = document.querySelector('[data-quick-app]');
  if (!root) throw new Error('quick app root missing');

  const stepEls = root.querySelectorAll('[data-step]');
  const stepperItems = root.querySelectorAll('[data-stepper-item]');
  const btnPrev = root.querySelector('[data-btn-prev]');
  const btnNext = root.querySelector('[data-btn-next]');
  const btnSubmit = root.querySelector('[data-btn-submit]');
  const btnRestart = root.querySelector('[data-btn-restart]');
  const btnRelax = root.querySelector('[data-btn-relax]');
  const btnShare = root.querySelector('[data-btn-share]');
  const errorMsg = root.querySelector('[data-error-msg]');
  const navRow = root.querySelector('[data-nav-row]');

  // 슬라이더 + 직접 입력 동기화
  const slider = root.querySelector('[data-income-slider]');
  const incomeInput = root.querySelector('[data-income-input]');
  const pctEl = root.querySelector('[data-income-pct]');
  const tierEl = root.querySelector('[data-income-tier]');

  function getIncome() {
    return parseInt(incomeInput?.value || '250', 10);
  }
  function getSize() {
    const sizeInput = root.querySelector('input[name="hh-size"]:checked');
    return sizeInput ? parseInt(sizeInput.value, 10) : 1;
  }
  function updateIncome() {
    const income = getIncome();
    if (slider) slider.value = String(Math.min(income, 1000));
    const size = getSize();
    const median = MEDIAN_INCOME[size] || 239;
    const pct = Math.round((income / median) * 100);
    if (pctEl) pctEl.textContent = `중위 ${pct}%`;
    if (tierEl) {
      let tier = '중간 소득 구간';
      if (pct <= 30) tier = '기초생활 수급권 구간';
      else if (pct <= 50) tier = '차상위 구간';
      else if (pct <= 70) tier = '청년 월세·EITC 등 구간';
      else if (pct <= 100) tier = '중위소득 100% 이내';
      else if (pct <= 150) tier = '신혼 특공·일부 지원 구간';
      else tier = '대부분 소득 기준 외 (보편 지원 가능)';
      tierEl.textContent = tier;
    }
  }
  slider?.addEventListener('input', () => {
    if (incomeInput) incomeInput.value = slider.value;
    updateIncome();
  });
  incomeInput?.addEventListener('input', updateIncome);
  root.querySelectorAll('input[name="hh-size"]').forEach((el) => {
    el.addEventListener('change', updateIncome);
  });
  updateIncome();

  // 페르소나 카드 선택 시 에러 메시지 즉시 제거
  root.querySelectorAll('input[name="persona"]').forEach((el) => {
    el.addEventListener('change', () => {
      if (errorMsg) errorMsg.hidden = true;
    });
  });

  // ============================================================
  // 단계 전환 + 스텝퍼
  // ============================================================
  function showStep(n) {
    stepEls.forEach((el) => {
      const s = el.getAttribute('data-step');
      el.classList.toggle('active', s === String(n) || (n === 'result' && s === 'result'));
    });

    stepperItems.forEach((el) => {
      const s = el.getAttribute('data-stepper-item');
      el.classList.remove('current', 'done');
      if (n === 'result') {
        if (s !== 'result') el.classList.add('done');
        else el.classList.add('current');
      } else {
        const sNum = Number(s);
        if (sNum < n) el.classList.add('done');
        else if (sNum === n) el.classList.add('current');
      }
    });

    if (n === 'result') {
      btnPrev.hidden = true;
      btnNext.hidden = true;
      btnSubmit.hidden = true;
      navRow.hidden = true;
    } else {
      navRow.hidden = false;
      btnPrev.hidden = n === 1;
      btnNext.hidden = n === TOTAL_STEPS;
      btnSubmit.hidden = n !== TOTAL_STEPS;
    }
    window.scrollTo({ top: root.offsetTop - 80, behavior: 'smooth' });
  }

  function validateStep(n) {
    if (n === 1) {
      const checked = root.querySelector('input[name="persona"]:checked');
      if (!checked) {
        if (errorMsg) errorMsg.hidden = false;
        return false;
      }
    }
    return true;
  }

  btnNext?.addEventListener('click', () => {
    if (!validateStep(current)) return;
    if (current < TOTAL_STEPS) {
      current++;
      showStep(current);
    }
  });
  btnPrev?.addEventListener('click', () => {
    if (current > 1) {
      current--;
      showStep(current);
    }
  });

  btnSubmit?.addEventListener('click', () => {
    if (!validateStep(1)) {
      current = 1;
      showStep(1);
      return;
    }
    runMatch();
    writeHashState(true);
    showStep('result');
  });

  btnRestart?.addEventListener('click', () => {
    current = 1;
    root.querySelectorAll('input').forEach((i) => {
      if (i.type === 'radio' || i.type === 'checkbox') i.checked = false;
    });
    const firstSize = root.querySelector('input[name="hh-size"][value="1"]');
    if (firstSize) firstSize.checked = true;
    if (slider) slider.value = '250';
    if (incomeInput) incomeInput.value = '250';
    if (errorMsg) errorMsg.hidden = true;
    updateIncome();
    history.replaceState(null, '', window.location.pathname);
    showStep(1);
  });

  // 조건 완화 = 카테고리·이벤트 모두 해제하고 페르소나만으로 재매칭
  btnRelax?.addEventListener('click', () => {
    root.querySelectorAll('input[name="category"], input[name="event"]').forEach((i) => {
      i.checked = false;
    });
    runMatch();
    writeHashState(true);
  });

  // 결과 링크 복사 — clipboard API
  btnShare?.addEventListener('click', async () => {
    writeHashState(true);
    const url = window.location.href;
    const original = btnShare.textContent;
    try {
      await navigator.clipboard.writeText(url);
      btnShare.textContent = '✓ 링크 복사됨';
    } catch {
      // clipboard 실패 fallback — prompt
      window.prompt('복사할 링크', url);
    }
    setTimeout(() => {
      btnShare.textContent = original;
    }, 2000);
  });

  // ============================================================
  // URL hash 직렬화 — 결과 공유·딥링크 (개인정보 저장 X — URL 자체에만)
  // ============================================================
  function readHashState() {
    const hash = window.location.hash.replace(/^#/, '');
    if (!hash) return null;
    const params = new URLSearchParams(hash);
    return {
      persona: params.get('persona') || '',
      size: params.get('size') || '1',
      income: params.get('income') || '250',
      cats: (params.get('cats') || '').split(',').filter(Boolean),
      events: (params.get('events') || '').split(',').filter(Boolean),
      result: params.get('result') === '1',
    };
  }

  function writeHashState(showResult) {
    const personaInput = root.querySelector('input[name="persona"]:checked');
    const persona = personaInput?.value || '';
    if (!persona) {
      // 페르소나 없으면 hash 비움
      history.replaceState(null, '', window.location.pathname);
      return;
    }
    const cats = Array.from(root.querySelectorAll('input[name="category"]:checked')).map((i) => i.value);
    const events = Array.from(root.querySelectorAll('input[name="event"]:checked')).map((i) => i.value);
    const params = new URLSearchParams();
    params.set('persona', persona);
    params.set('size', String(getSize()));
    params.set('income', String(getIncome()));
    if (cats.length > 0) params.set('cats', cats.join(','));
    if (events.length > 0) params.set('events', events.join(','));
    if (showResult) params.set('result', '1');
    history.replaceState(null, '', `${window.location.pathname}#${params.toString()}`);
  }

  function applyHashState() {
    const st = readHashState();
    if (!st) return;
    if (st.persona) {
      const el = root.querySelector(`input[name="persona"][value="${CSS.escape(st.persona)}"]`);
      if (el) el.checked = true;
    }
    if (st.size) {
      const el = root.querySelector(`input[name="hh-size"][value="${st.size}"]`);
      if (el) el.checked = true;
    }
    if (st.income && incomeInput) {
      incomeInput.value = st.income;
    }
    for (const c of st.cats) {
      const el = root.querySelector(`input[name="category"][value="${CSS.escape(c)}"]`);
      if (el) el.checked = true;
    }
    for (const e of st.events) {
      const el = root.querySelector(`input[name="event"][value="${CSS.escape(e)}"]`);
      if (el) el.checked = true;
    }
    updateIncome();
    if (st.result && st.persona) {
      runMatch();
      showStep('result');
    }
  }

  // 페이지 로드 시 hash 적용
  applyHashState();

  // ============================================================
  // 매칭 로직
  // ============================================================
  function runMatch() {
    const personaInput = root.querySelector('input[name="persona"]:checked');
    const persona = personaInput?.value;
    const size = getSize();
    const income = getIncome();
    const cats = Array.from(root.querySelectorAll('input[name="category"]:checked')).map((i) => i.value);
    const events = Array.from(root.querySelectorAll('input[name="event"]:checked'));
    const eventKeys = events.map((e) => e.value);
    const eventTags = new Set();
    for (const ev of events) {
      const tags = ev.getAttribute('data-tags');
      if (tags) tags.split(',').forEach((t) => eventTags.add(t.trim()));
    }

    const median = MEDIAN_INCOME[size] || 239;
    const pct = (income / median) * 100;

    // 스코어링 — 항목별 매칭 이유도 같이 기록
    const scored = compactSubsidies.map((s) => {
      let score = 0;
      const reasons = [];
      if (persona && s.targetPersonas.includes(persona)) {
        score += 30;
        reasons.push('페르소나 직접 매칭');
      }
      if (cats.includes(s.category)) {
        score += 20;
        reasons.push(`${s.category} 분야`);
      }
      let eventHit = false;
      for (const t of s.tags) {
        if (eventTags.has(t)) {
          score += 8;
          eventHit = true;
        } else {
          for (const et of eventTags) {
            if (t.includes(et) || et.includes(t)) {
              score += 4;
              eventHit = true;
            }
          }
        }
      }
      if (eventHit && eventKeys.length > 0) reasons.push(`라이프 이벤트 (${eventKeys.join('·')})`);
      if (s.status === '신청 가능') {
        score += 5;
      } else if (s.status === '곧 마감') {
        score += 3;
      }
      if (s.isHot) {
        score += 5;
      }
      return { s, score, reasons };
    });

    const top = scored
      .filter((x) => x.score > 0)
      .sort((a, b) => b.score - a.score)
      .slice(0, 12);

    renderResult(top, {
      persona,
      cats,
      eventKeys,
      pct: Math.round(pct),
      size,
      income,
    });
  }

  function fitLabel(score) {
    if (score >= 50) return { label: '매우 적합', cls: 'fit-strong' };
    if (score >= 30) return { label: '적합', cls: 'fit-good' };
    return { label: '관련', cls: 'fit-soft' };
  }

  function renderResult(items, ctx) {
    const list = root.querySelector('[data-result-list]');
    const summary = root.querySelector('[data-result-summary]');
    const personasEl = root.querySelector('[data-result-personas]');
    const emptyEl = root.querySelector('[data-result-empty]');

    // 결과 요약 (사용자 입력 echo)
    const personaLabel = ctx.persona
      ? compactPersonas.find((p) => p.id === ctx.persona)?.label
      : null;
    const summaryParts = [];
    if (personaLabel) summaryParts.push(`<strong>${escapeHtml(personaLabel)}</strong>`);
    summaryParts.push(`${ctx.size}인 가구 · 월 ${ctx.income}만원 (중위 ${ctx.pct}%)`);
    if (ctx.cats.length > 0) summaryParts.push(`관심: ${ctx.cats.map(escapeHtml).join('·')}`);
    if (ctx.eventKeys.length > 0)
      summaryParts.push(`이벤트: ${ctx.eventKeys.map(escapeHtml).join('·')}`);
    summary.innerHTML = summaryParts.join(' · ');

    if (items.length === 0) {
      list.innerHTML = '';
      personasEl.innerHTML = '';
      emptyEl.hidden = false;
      return;
    }
    emptyEl.hidden = true;

    list.innerHTML = items
      .map(({ s, score, reasons }, i) => {
        const fit = fitLabel(score);
        const amtText =
          s.amount > 0
            ? formatWon(s.amount) + ' <span class="ru">' + escapeHtml(s.amountLabel) + '</span>'
            : '<span class="amt-na">내용 확인</span>';
        const reasonText = reasons.length > 0
          ? reasons.map((r) => '<span class="reason-pill">' + escapeHtml(r) + '</span>').join('')
          : '';
        return (
          '<li class="result-item">' +
          '<a class="result-card" href="/subsidies/' + encodeURIComponent(s.id) + '/">' +
          '<div class="rc-rank">' + (i + 1) + '</div>' +
          '<div class="rc-body">' +
          '<div class="rc-meta">' +
          '<span class="rc-fit ' + fit.cls + '">' + fit.label + '</span>' +
          '<span class="rc-cat">' + escapeHtml(s.category) + '</span>' +
          (s.status === '곧 마감' ? '<span class="rc-warn">곧 마감</span>' : '') +
          (s.isHot ? '<span class="rc-hot">HOT</span>' : '') +
          '</div>' +
          '<div class="rc-agency">' + escapeHtml(s.agency) + '</div>' +
          '<div class="rc-title">' + escapeHtml(s.title) + '</div>' +
          '<div class="rc-sum">' + escapeHtml(s.summary) + '</div>' +
          (reasonText ? '<div class="rc-reasons">' + reasonText + '</div>' : '') +
          '<div class="rc-amt">' + amtText + '</div>' +
          '</div>' +
          '<span class="rc-arrow" aria-hidden="true">→</span>' +
          '</a>' +
          '</li>'
        );
      })
      .join('');

    if (ctx.persona) {
      const p = compactPersonas.find((x) => x.id === ctx.persona);
      if (p) {
        personasEl.innerHTML =
          '<a class="persona-link" href="/personas/' + encodeURIComponent(p.id) + '/">' +
          '★ <strong>' + escapeHtml(p.label) + '</strong> 페르소나 페이지에서 더 자세히 보기 →' +
          '</a>';
      }
    } else {
      personasEl.innerHTML = '';
    }
  }

  function formatWon(n) {
    if (n >= 100_000_000) {
      const eok = n / 100_000_000;
      return (eok % 1 === 0 ? eok : eok.toFixed(1)) + '억원';
    }
    if (n >= 10_000) {
      const man = Math.round(n / 10_000);
      return man.toLocaleString('ko-KR') + '만원';
    }
    return n.toLocaleString('ko-KR') + '원';
  }

  function escapeHtml(s) {
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }
</script>

