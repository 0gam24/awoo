---
import BlufBox from '@/components/BlufBox.astro';
import Container from '@/components/Container.astro';
import CrossRefRail from '@/components/CrossRefRail.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { type GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';

export const getStaticPaths = (async () => {
  const items = await getCollection('glossary');
  return items.map((item) => ({
    params: { id: item.data.id },
    props: { item },
  }));
}) satisfies GetStaticPaths;

const { item } = Astro.props;
const term = item.data;

const allItems = await getCollection('glossary');
const relatedItems = (term.related ?? [])
  .map((id) => allItems.find((x) => x.data.id === id)?.data)
  .filter((x): x is NonNullable<typeof x> => x !== undefined);

// 본 용어가 등장하는 지원금 매칭
const subsidies = await getCollection('subsidies');
const matched = subsidies
  .filter((s) => {
    const text = `${s.data.title} ${s.data.summary} ${s.data.eligibility.join(' ')} ${s.data.benefits.join(' ')}`;
    return [term.term, ...(term.synonyms ?? [])].some((kw) => text.includes(kw));
  })
  .slice(0, 6);

// DefinedTerm schema — AI 답변 엔진 인용 친화 1문단 정의
// Cycle #21: longDef 본문 + relatedTerms cross-link 보강
const longDef = (term as { longDef?: string }).longDef;
const definedTermSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTerm',
  '@id': `https://awoo.or.kr/glossary/${term.id}/#term`,
  name: term.term,
  description: longDef && longDef.length > term.shortDef.length ? longDef : term.shortDef,
  url: `https://awoo.or.kr/glossary/${term.id}/`,
  inLanguage: 'ko-KR',
  inDefinedTermSet: { '@id': 'https://awoo.or.kr/glossary/#dts' },
  alternateName: term.synonyms,
  termCode: term.id,
};
// related — 동의어·관련 용어 cross-link (entity 그래프 강화)
if (term.related && term.related.length > 0) {
  definedTermSchema.sameAs = term.related.map(
    (rid: string) => `https://awoo.or.kr/glossary/${rid}/#term`,
  );
}
// 본 용어가 적용되는 GovernmentService cross-link
if (matched.length > 0) {
  definedTermSchema.subjectOf = matched.slice(0, 5).map((s) => ({
    '@type': 'GovernmentService',
    '@id': `https://awoo.or.kr/subsidies/${s.data.id}/#govservice`,
    name: s.data.title,
  }));
}

const breadcrumbs = [
  { name: '홈', href: '/' },
  { name: '신청 가이드', href: '/guide/' },
  { name: '용어 사전', href: '/glossary/' },
  { name: term.term, href: `/glossary/${term.id}/` },
];

// 4축 cross-ref — 본 용어 카테고리 매칭 토픽
const allTopics = await getCollection('topics');
const matchedTopics = allTopics
  .filter((t) => (t.data.relatedGlossary ?? []).includes(term.id))
  .slice(0, 3);

// BLUF 자동 통계
const blufStatsGlossary = [
  { value: `${matched.length}건`, label: '관련 지원금' },
  ...((term.synonyms?.length ?? 0) > 0 ? [{ value: `${term.synonyms!.length}개`, label: '동의어' }] : []),
  ...(matchedTopics.length > 0 ? [{ value: `${matchedTopics.length}건`, label: '주제별 가이드' }] : []),
];
const blufSummaryGlossary = `${term.term} — ${term.shortDef}${matched.length > 0 ? ` 본 용어가 적용되는 정부 지원금 ${matched.length}건을 정리했습니다.` : ''}`;

const crossRefItems = [
  ...matchedTopics.map((t) => ({
    href: `/topics/${t.data.id}/`,
    label: t.data.title,
    sub: '주제별 종합 가이드',
  })),
  { href: `/categories/${encodeURIComponent(term.category)}/`, label: `${term.category} 분야 전체`, sub: '관련 분야 지원금 모아보기' },
  { href: '/glossary/', label: '용어 사전 전체', sub: '다른 용어 찾기' },
];
---

<BaseLayout
  title={`${term.term} — 정부 지원금 용어 정의 | 지원금가이드`}
  description={term.shortDef.slice(0, 160)}
  activeNav="/guide/"
  breadcrumbs={breadcrumbs}
>
  <script type="application/ld+json" set:html={JSON.stringify(definedTermSchema)} />

  <article class="band">
    <Container size="narrow">
      <a class="back-link" href="/glossary/">← 용어 사전으로</a>

      <header class="hero">
        <div class="cat-pill">{term.category}</div>
        <h1 class="title">{term.term}</h1>
        {term.synonyms && term.synonyms.length > 0 && (
          <div class="synonyms">
            <span class="syn-label">동의어</span>
            {term.synonyms.map((s) => <span class="syn-chip">{s}</span>)}
          </div>
        )}
      </header>

      <BlufBox summary={blufSummaryGlossary} stats={blufStatsGlossary} basis="용어 사전 · 정부 부처 공식 정의 인용" />

      <section class="def-card">
        <h2>한 줄 정의</h2>
        <p class="short-def">{term.shortDef}</p>
      </section>

      <section class="def-card">
        <h2>자세한 설명</h2>
        <p class="long-def">{term.longDef}</p>
      </section>

      {relatedItems.length > 0 && (
        <section class="related">
          <h2>관련 용어</h2>
          <ul class="rel-list">
            {relatedItems.map((r) => (
              <li>
                <a class="rel-card" href={`/glossary/${r.id}/`}>
                  <div class="rel-term">{r.term}</div>
                  <div class="rel-def">{r.shortDef}</div>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      {matched.length > 0 && (
        <section class="related">
          <h2>이 용어가 적용되는 지원금</h2>
          <ul class="sub-list">
            {matched.map((s) => (
              <li>
                <a class="sub-card" href={`/subsidies/${s.data.id}/`}>
                  <span class="sub-cat">{s.data.category}</span>
                  <span class="sub-title">{s.data.title}</span>
                  <span class="sub-arrow" aria-hidden="true">→</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      <CrossRefRail title="함께 보면 좋은 다른 관점" items={crossRefItems} />
    </Container>
  </article>
</BaseLayout>

<style>
  .band {
    padding: 32px 0 80px;
  }

  .back-link {
    display: inline-block;
    color: var(--text-2);
    font-size: 14px;
    text-decoration: none;
    margin-bottom: 20px;
  }
  .back-link:hover { text-decoration: underline; }

  .hero {
    margin-bottom: 28px;
  }

  .cat-pill {
    display: inline-block;
    padding: 4px 12px;
    background: rgb(0 113 227 / 0.12);
    color: var(--accent);
    border-radius: var(--radius-pill);
    font-size: 12px;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .title {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin: 0 0 14px;
  }

  .synonyms {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .syn-label {
    font-size: 12px;
    color: var(--text-2);
    font-weight: 600;
  }

  .syn-chip {
    padding: 3px 10px;
    background: var(--surface-2);
    color: var(--text);
    border-radius: var(--radius-pill);
    font-size: 12px;
  }

  .def-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 20px 24px;
    margin-bottom: 16px;
  }

  .def-card h2 {
    font-size: 13px;
    font-weight: 700;
    color: var(--text-2);
    margin: 0 0 8px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .short-def {
    font-size: 18px;
    font-weight: 600;
    line-height: 1.5;
    margin: 0;
    color: var(--text);
  }

  .long-def {
    font-size: 15px;
    line-height: 1.7;
    color: var(--text);
    margin: 0;
  }

  .related {
    margin-top: 32px;
  }

  .related h2 {
    font-size: 18px;
    font-weight: 700;
    margin: 0 0 14px;
  }

  .rel-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 8px;
  }

  .rel-card {
    display: block;
    padding: 12px 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, transform 0.15s;
  }

  .rel-card:hover {
    border-color: var(--border-2);
    transform: translateY(-1px);
    text-decoration: none;
  }

  .rel-term {
    font-size: 14px;
    font-weight: 700;
    margin-bottom: 4px;
  }

  .rel-def {
    font-size: 12px;
    color: var(--text-2);
    line-height: 1.5;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .sub-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .sub-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s;
  }

  .sub-card:hover {
    border-color: var(--border-2);
    text-decoration: none;
  }

  .sub-cat {
    flex-shrink: 0;
    font-size: 11px;
    font-weight: 700;
    padding: 3px 8px;
    background: var(--surface-2);
    color: var(--text-2);
    border-radius: var(--radius-pill);
  }

  .sub-title {
    flex: 1;
    font-size: 14px;
    font-weight: 600;
  }

  .sub-arrow {
    color: var(--text-3);
    font-size: 16px;
    transition: transform 0.15s, color 0.15s;
  }

  .sub-card:hover .sub-arrow {
    transform: translateX(3px);
    color: var(--accent);
  }
</style>
