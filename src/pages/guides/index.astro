---
import Container from '@/components/Container.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { buildCollectionPage } from '@/lib/schema';
import { getCollection } from 'astro:content';

const guides = await getCollection('guides');
guides.sort((a, b) => {
  const ad = a.data.updatedAt ?? a.data.publishedAt;
  const bd = b.data.updatedAt ?? b.data.publishedAt;
  return ad < bd ? 1 : -1;
});

const flagship = guides.filter((g) => g.data.isFlagship);
const others = guides.filter((g) => !g.data.isFlagship);

const collectionSchema = buildCollectionPage({
  name: `심층 가이드 ${guides.length}건`,
  description: `정부 지원금을 페르소나별·상황별로 정리한 심층 가이드 모음. 자격·금액·신청 절차·자주 묻는 질문까지 한 페이지에서 확인.`,
  pageUrl: '/guides/',
  items: guides.map((g) => ({ url: `/guides/${g.id}/`, name: g.data.title })),
});
---

<BaseLayout
  title={`심층 가이드 ${guides.length}건 — 지원금가이드`}
  description="정부 지원금을 페르소나별·상황별로 정리한 심층 가이드. 자격·금액·신청 절차·자주 묻는 질문 한 페이지 정리."
  activeNav="/guide/"
  breadcrumbs={[
    { name: '홈', href: '/' },
    { name: '심층 가이드', href: '/guides/' },
  ]}
>
  {collectionSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />}

  <article class="band">
    <Container size="wide">
      <header class="head">
        <h1 class="title">심층 가이드</h1>
        <p class="lead">
          정부 지원금을 신청 절차·자격 기준·자주 묻는 질문까지 한 페이지에서 정리.
          {guides.length}건 발행 중.
        </p>
      </header>

      {guides.length === 0 ? (
        <div class="empty">
          <p>심층 가이드를 준비 중입니다.</p>
          <a class="empty-link" href="/issues/">오늘의 이슈 →</a>
        </div>
      ) : (
        <>
          {flagship.length > 0 && (
            <section class="section">
              <h2 class="sect-title">flagship 가이드</h2>
              <ul class="grid">
                {flagship.map((g) => (
                  <li>
                    <a class="card flagship" href={`/guides/${g.id}/`}>
                      <div class="card-meta">
                        <span class="flagship-pill">flagship</span>
                        <span class="card-cat">{g.data.category}</span>
                      </div>
                      <h3 class="card-title">{g.data.title}</h3>
                      <p class="card-desc">{g.data.description}</p>
                      <div class="card-tldr">
                        {g.data.tldr.slice(0, 3).map((t) => <span class="tldr-chip">{t}</span>)}
                      </div>
                      <span class="card-cta">자세히 보기 →</span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}

          {others.length > 0 && (
            <section class="section">
              <h2 class="sect-title">전체 가이드</h2>
              <ul class="grid">
                {others.map((g) => (
                  <li>
                    <a class="card" href={`/guides/${g.id}/`}>
                      <div class="card-meta">
                        <span class="card-cat">{g.data.category}</span>
                        <span class="card-date">{(g.data.updatedAt ?? g.data.publishedAt).slice(0, 10)}</span>
                      </div>
                      <h3 class="card-title">{g.data.title}</h3>
                      <p class="card-desc">{g.data.description}</p>
                      <span class="card-cta">자세히 보기 →</span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}
        </>
      )}
    </Container>
  </article>
</BaseLayout>

<style>
  .band {
    padding: 48px 0 80px;
  }
  .head {
    margin-bottom: 36px;
    max-width: 720px;
  }
  .title {
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 12px;
  }
  .lead {
    font-size: 16px;
    color: var(--text-2);
    line-height: 1.65;
    margin: 0;
  }

  .empty {
    text-align: center;
    padding: 80px 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }
  .empty p { color: var(--text-2); }
  .empty-link {
    display: inline-block;
    margin-top: 12px;
    color: var(--accent-link);
    text-decoration: none;
    font-weight: 600;
  }
  .empty-link:hover { text-decoration: underline; }

  .section {
    margin-bottom: 36px;
  }
  .sect-title {
    font-size: 20px;
    font-weight: 700;
    margin: 0 0 16px;
  }
  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 14px;
  }
  .card {
    display: block;
    padding: 22px 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: transform 0.18s var(--ease-standard), border-color 0.18s;
  }
  .card:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
    text-decoration: none;
  }
  .card.flagship {
    background: linear-gradient(135deg, rgb(0 113 227 / 0.06) 0%, rgb(0 113 227 / 0.02) 100%);
    border-color: rgb(0 113 227 / 0.18);
  }
  .card-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 8px;
    flex-wrap: wrap;
    font-size: 11px;
  }
  .flagship-pill {
    padding: 3px 10px;
    background: var(--accent);
    color: var(--on-accent);
    border-radius: var(--radius-pill);
    font-weight: 700;
    text-transform: uppercase;
  }
  .card-cat {
    padding: 2px 10px;
    background: var(--surface-2);
    color: var(--text-2);
    border-radius: var(--radius-pill);
    font-weight: 600;
  }
  .card-date {
    color: var(--text-3);
    font-variant-numeric: tabular-nums;
  }
  .card-title {
    font-size: 17px;
    font-weight: 700;
    line-height: 1.35;
    margin: 0 0 8px;
    letter-spacing: -0.01em;
  }
  .card-desc {
    font-size: 13px;
    color: var(--text-2);
    line-height: 1.55;
    margin: 0 0 12px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-tldr {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
    margin-bottom: 10px;
  }
  .tldr-chip {
    font-size: 11px;
    padding: 3px 9px;
    background: var(--surface-2);
    color: var(--text-2);
    border-radius: var(--radius-pill);
  }
  .card-cta {
    color: var(--accent-link);
    font-size: 13px;
    font-weight: 600;
  }
</style>
