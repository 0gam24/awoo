---
import Container from '@/components/Container.astro';
import Icon from '@/components/Icon.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="문의 — 지원금가이드"
  description="지원금가이드 문의처. 콘텐츠 정정 제보·새 지원금 추가 요청·페르소나 분류 의견·언론 인터뷰까지, 24~48시간 내 답변 드립니다. 신청 대행은 받지 않으며 정부 공식 사이트로 안내합니다."
  breadcrumbs={[
    { name: '홈', href: '/' },
    { name: '문의', href: '/contact/' },
  ]}
>
  <Container size="narrow">
    <article class="page">
      <header class="head">
        <div class="eyebrow">문의</div>
        <h1>도움이 필요하시면 언제든지 알려주세요</h1>
        <p class="lead">
          본 사이트는 정보 안내 사이트로, 지원금 신청은 받지 않습니다.
          콘텐츠 정정·갱신 제보·제휴 문의 환영합니다.
        </p>
      </header>

      <section class="card">
        <h2>문의 폼</h2>
        <form id="contact-form" class="contact-form" novalidate>
          <div class="row">
            <div class="field">
              <label for="cf-name">이름</label>
              <input id="cf-name" name="name" type="text" required minlength="1" maxlength="60" autocomplete="name" />
            </div>
            <div class="field">
              <label for="cf-email">이메일</label>
              <input id="cf-email" name="email" type="email" required maxlength="120" autocomplete="email" />
            </div>
          </div>
          <div class="field">
            <label for="cf-subject">제목</label>
            <input id="cf-subject" name="subject" type="text" required minlength="2" maxlength="120" />
          </div>
          <div class="field">
            <label for="cf-message">내용</label>
            <textarea id="cf-message" name="message" required minlength="10" maxlength="4000" rows="6" placeholder="구체적으로 알려주시면 더 정확히 답변드릴 수 있어요."></textarea>
            <span class="hint" id="cf-counter" aria-live="polite">0 / 4000</span>
          </div>
          {/* honeypot */}
          <input type="text" name="_hp" tabindex="-1" autocomplete="off" class="cf-hp" aria-hidden="true" />
          <div class="form-actions">
            <button type="submit" class="cf-submit" id="cf-submit">전송</button>
            <p class="form-note">전송하시면 <a href="/privacy/">개인정보처리방침</a>에 동의하는 것으로 간주됩니다.</p>
          </div>
          <p class="cf-thanks" id="cf-thanks" hidden role="status">문의가 접수됐습니다. 24~48시간 내 답변드릴게요.</p>
          <p class="cf-error" id="cf-error" hidden role="alert">전송 실패. 잠시 후 다시 시도하거나 직접 smartdatashop@gmail.com 로 보내주세요.</p>
        </form>
      </section>

      <section class="card">
        <h2>이메일 직접 발송</h2>
        <a class="email" href="mailto:smartdatashop@gmail.com">
          smartdatashop@gmail.com
          <Icon name="arrow-up-right" size={16} />
        </a>
        <p class="card-desc">위 폼이 안 되면 이메일로 직접 보내주세요.</p>
      </section>

      <section class="card">
        <h2>이런 문의를 환영해요</h2>
        <ul>
          <li>오류·낡은 정보 제보 (지원 금액·자격 기준 변경 등)</li>
          <li>새로운 정부 지원금 추가 요청</li>
          <li>페르소나 분류 의견·실제 신청 경험 공유</li>
          <li>접근성·사용성 피드백</li>
          <li>언론 보도·인터뷰 요청</li>
        </ul>
      </section>

      <section class="card">
        <h2>이런 문의는 처리할 수 없어요</h2>
        <ul>
          <li>지원금 신청 대행 — 본 사이트는 정보 안내만 합니다. 신청은 정부 공식 사이트에서.</li>
          <li>개별 자격 판정 — 정확한 자격은 복지로(welfare.go.kr) 모의계산을 이용하세요.</li>
          <li>심사 결과 문의·이의 신청 — 신청한 정부 부처에 직접 문의 바랍니다.</li>
        </ul>
      </section>

      <section class="card biz-card">
        <h2>운영 주체</h2>
        <dl>
          <dt>상호</dt><dd>스마트데이터샵</dd>
          <dt>대표자</dt><dd>김준혁</dd>
          <dt>사업자등록번호</dt><dd>406-06-34485</dd>
          <dt>소재지</dt><dd>인천광역시 계양구 새벌로 88, 효성동</dd>
        </dl>
      </section>
    </article>
  </Container>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const thanks = document.getElementById('cf-thanks');
    const errorEl = document.getElementById('cf-error');
    const submitBtn = document.getElementById('cf-submit') as HTMLButtonElement | null;
    const counter = document.getElementById('cf-counter');
    const message = document.getElementById('cf-message') as HTMLTextAreaElement | null;

    message?.addEventListener('input', () => {
      if (counter) counter.textContent = `${message.value.length} / 4000`;
    });

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = '전송 중...';
      }
      errorEl && (errorEl.hidden = true);

      const data = Object.fromEntries(new FormData(form));
      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        form.hidden = true;
        thanks && (thanks.hidden = false);
      } catch {
        errorEl && (errorEl.hidden = false);
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = '전송';
        }
      }
    });
  </script>
</BaseLayout>

<style>
  .page {
    padding: 64px 0 96px;
  }

  .head {
    margin-bottom: 32px;
  }

  .eyebrow {
    font-size: 13px;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 12px;
  }

  h1 {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
    line-height: 1.15;
    margin: 0 0 12px;
  }

  .lead {
    font-size: 16px;
    color: var(--text-2);
    line-height: 1.65;
    margin: 0;
  }

  .card {
    padding: 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    margin-bottom: 16px;
  }

  .card h2 {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 12px;
  }

  .email {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 22px;
    font-weight: 700;
    color: var(--accent);
    text-decoration: none;
    letter-spacing: -0.01em;
  }

  .email:hover {
    text-decoration: underline;
  }

  .card-desc {
    font-size: 13px;
    color: var(--text-2);
    margin: 8px 0 0;
  }

  ul {
    color: var(--text-2);
    line-height: 1.7;
    margin: 0;
    padding-left: 20px;
  }

  li {
    margin-bottom: 4px;
  }

  .biz-card dl {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 8px 16px;
    margin: 0;
    font-size: 14px;
  }

  .biz-card dt {
    color: var(--text-2);
  }

  .biz-card dd {
    margin: 0;
    color: var(--text);
  }

  /* Contact form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .contact-form .row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  @media (max-width: 480px) {
    .contact-form .row {
      grid-template-columns: 1fr;
    }
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .field label {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-2);
  }

  .field input,
  .field textarea {
    padding: 10px 14px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-family: inherit;
    font-size: 15px;
    color: var(--text);
    min-height: 40px;
  }

  .field textarea {
    resize: vertical;
    line-height: 1.6;
  }

  .field input:focus-visible,
  .field textarea:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 1px;
    border-color: var(--accent);
  }

  .hint {
    font-size: 12px;
    color: var(--text-3);
    align-self: flex-end;
  }

  .form-actions {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .cf-submit {
    padding: 12px 28px;
    background: var(--accent);
    color: var(--on-accent);
    border: 0;
    border-radius: var(--radius-pill);
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    min-height: 44px;
  }

  .cf-submit:hover:not(:disabled) {
    background: color-mix(in oklch, var(--accent), black 8%);
  }

  .cf-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .form-note {
    font-size: 13px;
    color: var(--text-3);
    margin: 0;
  }

  .cf-thanks {
    color: var(--color-success);
    font-weight: 600;
    font-size: 14px;
  }

  .cf-error {
    color: var(--color-danger);
    font-weight: 600;
    font-size: 14px;
  }

  .cf-hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
  }
</style>
