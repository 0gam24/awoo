---
import CategoriesGrid from '@/components/home/CategoriesGrid.astro';
import IncomeChecker from '@/components/home/IncomeChecker.astro';
import NewsHero from '@/components/home/NewsHero.astro';
import OtherIssuesSection from '@/components/home/OtherIssuesSection.astro';
import PersonaPicker from '@/components/home/PersonaPicker.astro';
import QuickCheckCTA from '@/components/home/QuickCheckCTA.astro';
import RecentlyAdded from '@/components/home/RecentlyAdded.astro';
import UrgencyHook from '@/components/home/UrgencyHook.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';

// WebSite + SearchAction — Google Sitelinks Search Box
// 사이트 자체 검색 페이지 미보유 → /subsidies/?category= 패턴이 검색 결과 역할
// (단순 카테고리 필터지만 정성스러운 알림은 가능)
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': 'https://awoo.or.kr/#website',
  url: 'https://awoo.or.kr/',
  name: '지원금가이드',
  alternateName: ['awoo.or.kr', '지원금 안내', '정부 지원금 가이드'],
  inLanguage: 'ko-KR',
  description: '정부 지원금을 페르소나(생애·상황) 단위로 정리한 정보 안내 사이트.',
  publisher: {
    '@type': 'Organization',
    name: '스마트데이터샵',
    url: 'https://awoo.or.kr',
  },
};

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': 'https://awoo.or.kr/#organization',
  name: '스마트데이터샵',
  alternateName: '지원금가이드',
  url: 'https://awoo.or.kr/',
  logo: 'https://awoo.or.kr/og-default.png',
  description: '정부 지원금 정보 안내 사이트 운영. 신청 대행 X.',
  founder: {
    '@type': 'Person',
    name: '김준혁',
  },
  contactPoint: [
    {
      '@type': 'ContactPoint',
      contactType: 'customer support',
      email: 'contact@awoo.or.kr',
      availableLanguage: ['ko'],
    },
  ],
  address: {
    '@type': 'PostalAddress',
    streetAddress: '새벌로 88',
    addressLocality: '계양구',
    addressRegion: '인천광역시',
    addressCountry: 'KR',
  },
  taxID: '406-06-34485',
};
---

<BaseLayout
  title="지원금가이드 — 나에게 맞는 정부 지원금 찾기"
  description="청년 월세부터 신혼 특공, 청년도약계좌, 소상공인 정책자금까지. 페르소나별로 매칭하는 정부 지원금 정보 안내. 신청 대행 없이 정부 공식 사이트로 연결합니다."
  activeNav="home"
>
  <UrgencyHook />
  <NewsHero />
  <QuickCheckCTA />
  <RecentlyAdded />
  <IncomeChecker />
  <OtherIssuesSection />
  <PersonaPicker />
  <CategoriesGrid />

  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(websiteSchema)}
  />
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(orgSchema)}
  />
</BaseLayout>
