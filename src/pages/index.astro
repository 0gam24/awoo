---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="지원금가이드 — 나에게 맞는 정부 지원금 찾기"
  description="청년 월세부터 신혼 특공, 청년도약계좌, 소상공인 정책자금까지. 정부 지원금을 페르소나별로 찾아보세요. 신청 대행 없는 정보 안내 사이트입니다."
>
  <section class="container">
    <div class="hero">
      <div class="eyebrow">부트스트랩 검증</div>
      <h1>지원금가이드</h1>
      <p>
        정부 지원금을 페르소나별로 정리한 정보 안내 사이트.
        본 페이지는 빌드 파이프라인 검증용입니다.
      </p>
      <div class="actions">
        <a class="btn btn-primary" href="/about">사이트 소개</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .container {
    max-width: 980px;
    margin: 0 auto;
    padding: 80px 24px;
  }

  .hero {
    max-width: 720px;
  }

  .eyebrow {
    font-size: 13px;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 16px;
  }

  h1 {
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 0 0 20px;
  }

  p {
    font-size: 19px;
    color: var(--text-2);
    margin: 0 0 32px;
    line-height: 1.5;
  }

  .actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 17px;
    font-weight: 500;
    padding: 12px 22px;
    border-radius: var(--radius-pill);
    transition:
      transform 0.15s var(--ease-standard),
      background 0.2s var(--ease-standard);
  }

  .btn:active {
    transform: scale(0.97);
  }

  .btn-primary {
    background: var(--accent);
    color: var(--on-accent);
  }

  .btn-primary:hover {
    text-decoration: none;
    background: color-mix(in oklch, var(--accent), black 8%);
  }
</style>
