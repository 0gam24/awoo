---
import Container from '@/components/Container.astro';
import Icon from '@/components/Icon.astro';
import PageHeader from '@/components/PageHeader.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { buildCollectionPage } from '@/lib/schema';
import { getCollection } from 'astro:content';

const topics = await getCollection('topics');

// 각 토픽의 매칭 지원금 수 추정 (relatedSubsidyKeywords 기반)
const allSubsidies = await getCollection('subsidies');
const topicCounts = topics.reduce<Record<string, number>>((acc, t) => {
  const kws = t.data.relatedSubsidyKeywords ?? [];
  acc[t.data.id] = kws.length === 0
    ? 0
    : allSubsidies.filter((s) => {
        const text = `${s.data.title} ${s.data.summary} ${(s.data.tags ?? []).join(' ')}`;
        return kws.some((kw) => text.includes(kw));
      }).length;
  return acc;
}, {});

const collectionSchema = buildCollectionPage({
  name: `주제별 종합 가이드 ${topics.length}개`,
  description: '청년 주거·신혼 출산 등 한 번에 결정해야 할 주제를 한 페이지에 정리.',
  pageUrl: '/topics/',
  items: topics.map((t) => ({ url: `/topics/${t.data.id}/`, name: t.data.title })),
});
---

<BaseLayout
  title={`주제별 종합 가이드 ${topics.length}개 — 지원금가이드`}
  description="청년 주거·신혼 출산·중장년 재취업 등 인생 단계별로 받을 수 있는 정부 지원금을 한 페이지에서 비교·검토하세요."
  activeNav="/guide/"
  breadcrumbs={[
    { name: '홈', href: '/' },
    { name: '신청 가이드', href: '/guide/' },
    { name: '주제별 종합', href: '/topics/' },
  ]}
>
  {collectionSchema && <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />}

  <section class="band">
    <Container size="wide">
      <PageHeader
        eyebrow="주제별 종합"
        title="한 주제, 한 페이지로 정리"
        lead={`청년 주거·신혼 출산처럼 한 번에 결정해야 할 주제를 모아<br />비교표·신청 순서·자주 떨어지는 이유까지 함께 안내합니다.`}
      />

      <ul class="grid">
        {topics.map((t) => (
          <li>
            <a class={`tile bg-${t.data.bg}`} href={`/topics/${t.data.id}/`}>
              <div class="tile-icon">
                <Icon name={t.data.icon} size={32} strokeWidth={1.5} />
              </div>
              <div class="tile-body">
                <div class="tile-title">{t.data.title}</div>
                <div class="tile-def">{t.data.shortDef}</div>
                {(topicCounts[t.data.id] ?? 0) > 0 && (
                  <div class="tile-meta">관련 지원금 {topicCounts[t.data.id]}건 안내</div>
                )}
              </div>
              <span class="tile-arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>
    </Container>
  </section>
</BaseLayout>

<style>
  .band { padding: 48px 0 80px; }

  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 16px;
  }

  .tile {
    display: flex;
    align-items: flex-start;
    gap: 18px;
    padding: 28px;
    border-radius: var(--radius-xl);
    text-decoration: none;
    color: #fff;
    overflow: hidden;
    position: relative;
    transition: transform 0.2s var(--ease-standard);
  }

  .tile:hover {
    transform: translateY(-3px);
    text-decoration: none;
  }

  .bg-persona-blue   { background: linear-gradient(135deg, #0066cc 0%, #2997ff 100%); }
  .bg-persona-orange { background: linear-gradient(135deg, #d97706 0%, #f97316 100%); }
  .bg-persona-pink   { background: linear-gradient(135deg, #be185d 0%, #ec4899 100%); }
  .bg-persona-green  { background: linear-gradient(135deg, #047857 0%, #10b981 100%); }
  .bg-persona-purple { background: linear-gradient(135deg, #6d28d9 0%, #a855f7 100%); }
  .bg-persona-amber  { background: linear-gradient(135deg, #b45309 0%, #f59e0b 100%); }

  .tile-icon {
    width: 56px;
    height: 56px;
    background: rgb(255 255 255 / 0.18);
    border-radius: var(--radius-md);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .tile-body {
    flex: 1;
    min-width: 0;
  }

  .tile-title {
    font-size: 19px;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 8px;
  }

  .tile-def {
    font-size: 14px;
    color: rgb(255 255 255 / 0.92);
    line-height: 1.55;
    margin-bottom: 8px;
  }

  .tile-meta {
    display: inline-block;
    padding: 3px 10px;
    background: rgb(255 255 255 / 0.18);
    border-radius: var(--radius-pill);
    font-size: 12px;
    font-weight: 700;
    color: #fff;
  }

  .tile-arrow {
    position: absolute;
    top: 28px;
    right: 28px;
    font-size: 22px;
    color: rgb(255 255 255 / 0.85);
    transition: transform 0.18s var(--ease-standard);
  }
  .tile:hover .tile-arrow {
    transform: translateX(4px);
    color: #fff;
  }
</style>
