---
import Container from '@/components/Container.astro';
import Icon from '@/components/Icon.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { formatWon } from '@/data/site-data';
import { type GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';

export const getStaticPaths = (async () => {
  const PERSONA_ORDER = ['office-rookie', 'self-employed', 'newlywed-family', 'senior', 'low-income', 'farmer'];
  const personas = await getCollection('personas');
  const sorted = [...personas].sort(
    (a, b) => PERSONA_ORDER.indexOf(a.data.id) - PERSONA_ORDER.indexOf(b.data.id),
  );
  return sorted.map((p, i) => {
    const prev = sorted[(i - 1 + sorted.length) % sorted.length];
    const next = sorted[(i + 1) % sorted.length];
    return {
      params: { id: p.data.id },
      props: {
        persona: p,
        all: sorted.map((x) => ({
          id: x.data.id,
          label: x.data.label,
          icon: x.data.icon,
          bg: x.data.bg,
        })),
        prev: { id: prev.data.id, label: prev.data.label },
        next: { id: next.data.id, label: next.data.label },
      },
    };
  });
}) satisfies GetStaticPaths;

const { persona, all, prev, next } = Astro.props as {
  persona: Awaited<ReturnType<typeof getCollection<'personas'>>>[number];
  all: Array<{ id: string; label: string; icon: string; bg: string }>;
  prev: { id: string; label: string };
  next: { id: string; label: string };
};
const p = persona.data;

const allSubsidies = await getCollection('subsidies');
const matched = allSubsidies.filter((s) => s.data.targetPersonas.includes(p.id));

// 카테고리별 카운트 — cross-ref hub 가 존재하는 (≥2건) 카테고리만 노출
const HUB_MIN = 2;
const byCategory: Record<string, number> = {};
for (const s of matched) {
  byCategory[s.data.category] = (byCategory[s.data.category] ?? 0) + 1;
}
const hubCategories = Object.entries(byCategory)
  .filter(([, n]) => n >= HUB_MIN)
  .sort((a, b) => b[1] - a[1]);

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: 'https://awoo.or.kr/' },
    { '@type': 'ListItem', position: 2, name: '지원금', item: 'https://awoo.or.kr/subsidies/' },
    { '@type': 'ListItem', position: 3, name: '페르소나', item: 'https://awoo.or.kr/personas/' },
    { '@type': 'ListItem', position: 4, name: p.label, item: `https://awoo.or.kr/personas/${p.id}/` },
  ],
};
---

<BaseLayout
  title={`${p.label} — 지원금가이드`}
  description={`${p.label}(${p.sub})에게 매칭되는 정부 지원금 ${matched.length}개. ${p.pains.join(', ')} 문제 해결을 위한 정보 안내.`}
  activeNav="/subsidies/"
>
  <section class="persona-hero" data-bg={p.bg}>
    <Container size="wide">
      <a class="back-link" href="/">← 홈</a>
      <div class="hero-grid">
        <div class="hero-glyph">
          <Icon name={p.icon} size={56} strokeWidth={1.5} />
        </div>
        <div>
          <h1 class="hero-title">{p.label}</h1>
          <p class="hero-sub">{p.sub}</p>
          <div class="hero-meta">
            <span>{p.age}</span>
            <span aria-hidden="true">·</span>
            <span>{p.income}</span>
            <span aria-hidden="true">·</span>
            <span>{p.living}</span>
          </div>
        </div>
      </div>
      <div class="pains">
        <span class="pains-label">주요 고민</span>
        {p.pains.map((pain) => <span class="pain-chip">{pain}</span>)}
      </div>
    </Container>
  </section>

  <section class="band">
    <Container size="wide">
      <h2 class="display">{p.label}이 받을 수 있는 지원금 {matched.length}개</h2>
      <ul class="subsidy-grid">
        {
          matched.map((s) => (
            <li>
              <a class="subsidy-card" href={`/subsidies/${s.data.id}/`}>
                <div class={`media tint-${s.data.category}`}>
                  <Icon name={s.data.icon} size={44} strokeWidth={1.5} />
                </div>
                <div class="body">
                  <div class="meta-row">
                    <span class="badge neutral">{s.data.category}</span>
                    {s.data.status === '곧 마감' && <span class="badge warning">곧 마감</span>}
                  </div>
                  <div class="agency">{s.data.agency}</div>
                  <div class="title">{s.data.title}</div>
                  <div class="summary">{s.data.summary.slice(0, 60)}{s.data.summary.length > 60 ? '…' : ''}</div>
                  <div class="amount">
                    {formatWon(s.data.amount)} <span class="unit">{s.data.amountLabel}</span>
                  </div>
                </div>
              </a>
            </li>
          ))
        }
      </ul>

      {hubCategories.length > 0 && (
        <section class="hub-section">
          <h3 class="hub-title">카테고리별로 좁혀 보기</h3>
          <ul class="hub-grid">
            {hubCategories.map(([cat, n]) => (
              <li>
                <a class="hub-card" href={`/subsidies/category/${encodeURIComponent(cat)}/persona/${p.id}/`}>
                  <span class="hub-cat">{cat}</span>
                  <span class="hub-count">{n}건</span>
                  <span class="hub-arrow" aria-hidden="true">→</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      <nav class="persona-nav" aria-label="다른 페르소나">
        <div class="pn-eyebrow">다른 페르소나로 보기</div>
        <ul class="pn-grid">
          {all.map((other) => (
            <li>
              <a
                class={`pn-card ${other.id === p.id ? 'active' : ''} bg-${other.bg}`}
                href={`/personas/${other.id}/`}
                aria-current={other.id === p.id ? 'page' : undefined}
              >
                <Icon name={other.icon} size={22} strokeWidth={1.6} />
                <span>{other.label}</span>
              </a>
            </li>
          ))}
        </ul>
        <div class="pn-prev-next">
          <a class="pn-pn-link" href={`/personas/${prev.id}/`}>← {prev.label}</a>
          <a class="pn-pn-link" href={`/personas/${next.id}/`}>{next.label} →</a>
        </div>
      </nav>
    </Container>
  </section>

  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbSchema)}
  />
</BaseLayout>

<style>
  .persona-hero {
    color: #fff;
    padding: 56px 0 40px;
    background: var(--accent);
  }

  [data-bg='persona-blue'] {
    background: linear-gradient(135deg, #0066cc 0%, #2997ff 100%);
  }
  [data-bg='persona-orange'] {
    background: linear-gradient(135deg, #d97706 0%, #f97316 100%);
  }
  [data-bg='persona-pink'] {
    background: linear-gradient(135deg, #be185d 0%, #ec4899 100%);
  }
  [data-bg='persona-green'] {
    background: linear-gradient(135deg, #047857 0%, #10b981 100%);
  }
  [data-bg='persona-purple'] {
    background: linear-gradient(135deg, #6d28d9 0%, #a855f7 100%);
  }
  [data-bg='persona-amber'] {
    background: linear-gradient(135deg, #b45309 0%, #f59e0b 100%);
  }

  .back-link {
    display: inline-block;
    margin-bottom: 16px;
    color: rgb(255 255 255 / 0.85);
    text-decoration: none;
    font-size: 13px;
  }
  .back-link:hover {
    color: #fff;
    text-decoration: none;
  }

  .hero-grid {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 20px;
  }

  .hero-glyph {
    width: 88px;
    height: 88px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgb(255 255 255 / 0.18);
    border-radius: var(--radius-lg);
    flex-shrink: 0;
  }

  .hero-title {
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 700;
    margin: 0 0 6px;
    letter-spacing: -0.02em;
  }

  .hero-sub {
    font-size: 17px;
    color: rgb(255 255 255 / 0.9);
    margin: 0 0 8px;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    font-size: 13px;
    color: rgb(255 255 255 / 0.85);
  }

  .pains {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .pains-label {
    font-size: 13px;
    color: rgb(255 255 255 / 0.8);
  }

  .pain-chip {
    padding: 4px 12px;
    background: rgb(255 255 255 / 0.18);
    border-radius: var(--radius-pill);
    font-size: 13px;
    font-weight: 500;
  }

  .band {
    padding: 56px 0 80px;
  }

  .display {
    font-size: clamp(22px, 2.6vw, 30px);
    font-weight: 600;
    margin: 0 0 24px;
  }

  .subsidy-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
  }

  .subsidy-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: transform 0.18s var(--ease-standard);
  }
  .subsidy-card:hover {
    transform: translateY(-3px);
    text-decoration: none;
  }

  .media {
    aspect-ratio: 16 / 7;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--surface-2);
    color: var(--accent);
  }

  .tint-주거 {
    background: rgb(0 113 227 / 0.12);
    color: var(--accent);
  }
  .tint-자산 {
    background: rgb(8 145 178 / 0.12);
    color: #0891b2;
  }
  .tint-교육 {
    background: rgb(139 92 246 / 0.12);
    color: #8b5cf6;
  }
  .tint-창업 {
    background: rgb(234 88 12 / 0.12);
    color: #ea580c;
  }
  .tint-복지 {
    background: rgb(236 72 153 / 0.12);
    color: #ec4899;
  }
  .tint-취업 {
    background: rgb(16 185 129 / 0.12);
    color: #10b981;
  }

  .body {
    padding: 18px 20px 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .meta-row {
    display: flex;
    gap: 6px;
  }

  .badge {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 6px;
  }

  .badge.neutral {
    background: var(--surface-2);
    color: var(--text-2);
  }

  .badge.warning {
    background: rgb(247 195 96 / 0.18);
    color: var(--color-warning);
  }

  .agency {
    font-size: 13px;
    color: var(--accent-link);
    font-weight: 500;
  }

  .title {
    font-size: 17px;
    font-weight: 600;
    line-height: 1.4;
    margin-bottom: 4px;
  }

  .summary {
    font-size: 13px;
    color: var(--text-2);
    line-height: 1.5;
    flex: 1;
  }

  .amount {
    font-size: 22px;
    font-weight: 700;
    color: var(--accent);
    margin-top: 6px;
    letter-spacing: -0.02em;
  }

  .amount .unit {
    font-size: 13px;
    color: var(--text-2);
    font-weight: 500;
    margin-left: 4px;
  }

  /* Cross-reference hub section */
  .hub-section {
    margin-top: 48px;
    padding: 28px 28px;
    background: var(--bg-alt);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
  }

  .hub-title {
    font-size: 18px;
    font-weight: 700;
    margin: 0 0 16px;
    letter-spacing: -0.01em;
  }

  .hub-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 10px;
  }

  .hub-card {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, transform 0.15s;
  }

  .hub-card:hover {
    border-color: var(--border-2);
    transform: translateY(-1px);
    text-decoration: none;
  }

  .hub-cat {
    font-size: 14px;
    font-weight: 600;
    flex: 1;
  }

  .hub-count {
    font-size: 12px;
    font-weight: 700;
    color: var(--accent);
    background: rgb(0 113 227 / 0.1);
    padding: 2px 8px;
    border-radius: var(--radius-pill);
  }

  .hub-arrow {
    color: var(--text-3);
    font-size: 16px;
    transition: transform 0.15s, color 0.15s;
  }

  .hub-card:hover .hub-arrow {
    transform: translateX(3px);
    color: var(--accent);
  }

  /* 다른 페르소나 horizontal nav */
  .persona-nav {
    margin-top: 40px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }

  .pn-eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--text-2);
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .pn-grid {
    list-style: none;
    margin: 0 0 20px;
    padding: 0;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .pn-card {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    border-radius: var(--radius-pill);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    color: #fff;
    opacity: 0.62;
    transition: opacity 0.15s, transform 0.15s;
    min-height: 44px; /* WCAG 2.2 target-size */
  }

  .pn-card:hover {
    opacity: 1;
    transform: translateY(-1px);
    text-decoration: none;
  }

  .pn-card.active {
    opacity: 1;
    cursor: default;
    box-shadow: 0 0 0 2px var(--accent);
  }

  .pn-card.bg-persona-blue   { background: linear-gradient(135deg, #0066cc 0%, #2997ff 100%); }
  .pn-card.bg-persona-orange { background: linear-gradient(135deg, #d97706 0%, #f97316 100%); }
  .pn-card.bg-persona-pink   { background: linear-gradient(135deg, #be185d 0%, #ec4899 100%); }
  .pn-card.bg-persona-green  { background: linear-gradient(135deg, #047857 0%, #10b981 100%); }
  .pn-card.bg-persona-purple { background: linear-gradient(135deg, #6d28d9 0%, #a855f7 100%); }
  .pn-card.bg-persona-amber  { background: linear-gradient(135deg, #b45309 0%, #f59e0b 100%); }

  .pn-prev-next {
    display: flex;
    justify-content: space-between;
    gap: 12px;
  }

  .pn-pn-link {
    display: inline-flex;
    align-items: center;
    padding: 10px 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--text);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    min-height: 44px;
  }

  .pn-pn-link:hover {
    border-color: var(--border-2);
    text-decoration: none;
  }
</style>
