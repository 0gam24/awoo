---
import BlufBox from '@/components/BlufBox.astro';
import Container from '@/components/Container.astro';
import CrossRefRail from '@/components/CrossRefRail.astro';
import Icon from '@/components/Icon.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { formatWon } from '@/data/site-data';
import situationsData from '@/data/situations.json';
import { getDeadlineBadge } from '@/lib/deadline-format';
import { buildCollectionPage } from '@/lib/schema';
import { type GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';

export const getStaticPaths = (async () => {
  const PERSONA_ORDER = ['office-rookie', 'self-employed', 'newlywed-family', 'senior', 'low-income', 'farmer'];
  const personas = await getCollection('personas');
  const sorted = [...personas].sort(
    (a, b) => PERSONA_ORDER.indexOf(a.data.id) - PERSONA_ORDER.indexOf(b.data.id),
  );
  return sorted.map((p, i) => {
    const prev = sorted[(i - 1 + sorted.length) % sorted.length]!;
    const next = sorted[(i + 1) % sorted.length]!;
    return {
      params: { id: p.data.id },
      props: {
        persona: p,
        all: sorted.map((x) => ({
          id: x.data.id,
          label: x.data.label,
          icon: x.data.icon,
          bg: x.data.bg,
        })),
        prev: { id: prev.data.id, label: prev.data.label },
        next: { id: next.data.id, label: next.data.label },
      },
    };
  });
}) satisfies GetStaticPaths;

const { persona, all, prev, next } = Astro.props as {
  persona: Awaited<ReturnType<typeof getCollection<'personas'>>>[number];
  all: Array<{ id: string; label: string; icon: string; bg: string }>;
  prev: { id: string; label: string };
  next: { id: string; label: string };
};
const p = persona.data;

const allSubsidies = await getCollection('subsidies');
const matched = allSubsidies.filter((s) => s.data.targetPersonas.includes(p.id));

// 카테고리별 카운트 + 대표 지원금 — cross-ref hub 가 존재하는 (≥2건) 카테고리만 노출
const HUB_MIN = 2;
const byCategory: Record<string, { count: number; flagshipTitle: string }> = {};
for (const s of matched) {
  const cat = s.data.category;
  if (!byCategory[cat]) {
    byCategory[cat] = { count: 0, flagshipTitle: '' };
  }
  byCategory[cat]!.count++;
  // 대표: HOT 우선, 그다음 금액 큰 순
  if (
    !byCategory[cat].flagshipTitle ||
    s.data.isHot ||
    (s.data.amount ?? 0) > 0
  ) {
    // 점수 비교를 위해 잠시 보관 — 마지막 패스에서 정렬 결정
  }
}
// 대표 결정 — 정렬해서 첫번째
for (const cat of Object.keys(byCategory)) {
  const inCat = matched
    .filter((s) => s.data.category === cat)
    .sort((a, b) => {
      const ah = a.data.isHot ? 1 : 0;
      const bh = b.data.isHot ? 1 : 0;
      if (ah !== bh) return bh - ah;
      return (b.data.amount ?? 0) - (a.data.amount ?? 0);
    });
  byCategory[cat]!.flagshipTitle = inCat[0]?.data.title ?? '';
}

const hubCategories = Object.entries(byCategory)
  .filter(([, v]) => v.count >= HUB_MIN)
  .sort((a, b) => b[1].count - a[1].count);

// BLUF — 자동 통계 (추측 X, 매칭 데이터 기반)
const topCategoryEntry = hubCategories[0];
const totalAmount = matched.reduce((sum, s) => sum + (s.data.amount ?? 0), 0);
const avgAmountWon = matched.length > 0 ? Math.round(totalAmount / matched.length) : 0;
const avgAmountLabel =
  avgAmountWon >= 100000000
    ? `${(avgAmountWon / 100000000).toFixed(1)}억원`
    : avgAmountWon >= 10000
      ? `${Math.round(avgAmountWon / 10000)}만원`
      : avgAmountWon > 0
        ? `${avgAmountWon}원`
        : null;
const blufSummary = topCategoryEntry
  ? `${p.label}이 받을 수 있는 정부 지원금은 ${matched.length}건이고, 이 중 ${topCategoryEntry[0]} 분야가 ${topCategoryEntry[1].count}건으로 가장 많습니다.`
  : `${p.label}에게 매칭되는 정부 지원금 ${matched.length}건을 정리했습니다.`;
const blufStats = [
  { value: `${matched.length}건`, label: '받을 수 있는 지원금' },
  ...(topCategoryEntry ? [{ value: `${topCategoryEntry[1].count}건`, label: `${topCategoryEntry[0]} 분야` }] : []),
  ...(avgAmountLabel ? [{ value: avgAmountLabel, label: '평균 지원 규모' }] : []),
];

const breadcrumbs = [
  { name: '홈', href: '/' },
  { name: '지원금', href: '/subsidies/' },
  { name: '페르소나', href: '/personas/' },
  { name: p.label, href: `/personas/${p.id}/` },
];

// 4축 cross-ref — 본 페르소나 매칭 상황·토픽 추출
interface Situation { id: string; label: string; sub: string; matchedPersonas: string[] }
const matchedSituations = (situationsData as Situation[])
  .filter((s) => s.matchedPersonas.includes(p.id))
  .slice(0, 3);

const allTopics = await getCollection('topics');
const matchedTopics = allTopics
  .filter((t) => (t.data.mainPersonas ?? []).includes(p.id))
  .slice(0, 2);

const crossRefItems = [
  ...matchedSituations.map((s) => ({
    href: `/situations/${s.id}/`,
    label: s.label,
    sub: `상황별 안내 — ${s.sub}`,
  })),
  ...matchedTopics.map((t) => ({
    href: `/topics/${t.data.id}/`,
    label: t.data.title,
    sub: '주제별 종합 가이드',
  })),
  { href: '/quick/', label: '5분 진단으로 정확 매칭', sub: '내 상황에 맞춰 자동 추천' },
];

// Cycle #14 P0-1: CollectionPage + ItemList schema — 페르소나별 매칭 지원금 entity 그래프
const collectionSchema = buildCollectionPage({
  name: `${p.label} 정부 지원금 ${matched.length}건`,
  description: `${p.label}(${p.age}, ${p.income})에게 매칭되는 정부 지원금 모음`,
  pageUrl: `/personas/${p.id}/`,
  items: matched.slice(0, 100).map((s) => ({
    url: `/subsidies/${s.data.id}/`,
    name: s.data.title,
  })),
});
---

<BaseLayout
  title={`${p.label} 정부 지원금 ${matched.length}건 — ${p.sub}`}
  description={`${p.label}(${p.age}, ${p.income}, ${p.living})에게 매칭되는 정부 지원금 ${matched.length}건. ${p.pains.slice(0, 3).join(' · ')} 같은 고민을 위한 페르소나별 정리.`}
  activeNav="/subsidies/"
  breadcrumbs={breadcrumbs}
>
  <section class="persona-hero" data-bg={p.bg}>
    <Container size="wide">
      <a class="back-link" href="/">← 홈</a>
      <div class="hero-grid">
        <div class="hero-glyph">
          <Icon name={p.icon} size={56} strokeWidth={1.5} />
        </div>
        <div>
          <h1 class="hero-title">{p.label}</h1>
          <p class="hero-sub">{p.sub}</p>
          <div class="hero-meta">
            <span>{p.age}</span>
            <span aria-hidden="true">·</span>
            <span>{p.income}</span>
            <span aria-hidden="true">·</span>
            <span>{p.living}</span>
          </div>
        </div>
      </div>
      <div class="pains">
        <span class="pains-label">주요 고민</span>
        {p.pains.map((pain) => <span class="pain-chip">{pain}</span>)}
      </div>
    </Container>
  </section>

  <section class="band">
    <Container size="wide">
      <BlufBox summary={blufSummary} stats={blufStats} basis="2026년 4월 기준 · 보조금24 + 큐레이션" />

      {p.pains.length > 0 && (
        <section class="key-section">
          <h2 class="key-h2">{p.label}이 자주 겪는 어려움</h2>
          <p class="key-lead">정부 지원금을 찾는 사람들이 가장 많이 호소하는 고민입니다. 페이지 아래에서 분야별로 매칭되는 지원금을 정리했습니다.</p>
          <ul class="pain-list">
            {p.pains.map((pain) => <li>{pain}</li>)}
          </ul>
        </section>
      )}

      <section class="key-section">
        <h2 class="key-h2">{p.label} 자격 요건 한눈에</h2>
        <ul class="cond-list">
          <li><strong>연령대</strong>: {p.age}</li>
          <li><strong>소득 기준</strong>: {p.income}</li>
          <li><strong>주거·환경</strong>: {p.living}</li>
        </ul>
        <p class="key-note">개별 지원금마다 세부 조건은 다릅니다. 각 지원금 상세에서 정확한 자격 요건을 확인하세요.</p>
      </section>

      <h2 class="display">{p.label}이 받을 수 있는 지원금 {matched.length}개</h2>
      <ul class="subsidy-grid">
        {
          matched.map((s) => {
            const dl = getDeadlineBadge(s.data.deadline);
            const eligibilityHint = s.data.eligibility?.[0];
            return (
              <li>
                <a class="subsidy-card" href={`/subsidies/${s.data.id}/`}>
                  <div class={`media tint-${s.data.category}`}>
                    <Icon name={s.data.icon} size={44} strokeWidth={1.5} />
                  </div>
                  <div class="body">
                    <div class="meta-row">
                      <span class="badge neutral">{s.data.category}</span>
                      {dl.tone !== 'unknown' && (
                        <span class={`badge dl-${dl.tone}`} title={`마감: ${s.data.deadline}`}>
                          {dl.label}
                        </span>
                      )}
                    </div>
                    <div class="agency">{s.data.agency}</div>
                    <div class="title">{s.data.title}</div>
                    {eligibilityHint && (
                      <div class="elig-hint">
                        <span class="elig-icon" aria-hidden="true">✓</span>
                        {eligibilityHint.length > 32 ? `${eligibilityHint.slice(0, 32)}…` : eligibilityHint}
                      </div>
                    )}
                    <div class="amount">
                      {formatWon(s.data.amount)} <span class="unit">{s.data.amountLabel}</span>
                    </div>
                  </div>
                </a>
              </li>
            );
          })
        }
      </ul>

      {hubCategories.slice(0, 3).length > 0 && (
        <section class="cat-h2-section">
          <h2>{p.label}이 자주 받는 분야 Top 3</h2>
          <ul class="cat-h2-list">
            {hubCategories.slice(0, 3).map(([cat, v]) => (
              <li>
                <a href={`/subsidies/category/${encodeURIComponent(cat)}/persona/${p.id}/`}>
                  <strong>{cat}</strong> 분야 <span>{v.count}건</span>
                  {v.flagshipTitle && <em> · 대표: {v.flagshipTitle}</em>}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      {hubCategories.length > 0 && (
        <section class="hub-section">
          <h3 class="hub-title">카테고리별로 좁혀 보기</h3>
          <ul class="hub-grid">
            {hubCategories.map(([cat, v]) => (
              <li>
                <a class="hub-card" href={`/subsidies/category/${encodeURIComponent(cat)}/persona/${p.id}/`}>
                  <div class="hub-row-1">
                    <span class="hub-cat">{cat}</span>
                    <span class="hub-count">{v.count}건</span>
                  </div>
                  {v.flagshipTitle && (
                    <div class="hub-flagship">
                      <span class="hub-flag-label">대표</span>
                      <span class="hub-flag-title">{v.flagshipTitle}</span>
                    </div>
                  )}
                  <span class="hub-arrow" aria-hidden="true">→</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      <CrossRefRail title="함께 보면 좋은 다른 관점" items={crossRefItems} />

      <nav class="persona-nav" aria-label="다른 페르소나">
        <div class="pn-eyebrow">다른 페르소나로 보기</div>
        <ul class="pn-grid">
          {all.map((other) => (
            <li>
              <a
                class={`pn-card ${other.id === p.id ? 'active' : ''} bg-${other.bg}`}
                href={`/personas/${other.id}/`}
                aria-current={other.id === p.id ? 'page' : undefined}
              >
                <Icon name={other.icon} size={22} strokeWidth={1.6} />
                <span>{other.label}</span>
              </a>
            </li>
          ))}
        </ul>
        <div class="pn-prev-next">
          <a class="pn-pn-link" href={`/personas/${prev.id}/`}>← {prev.label}</a>
          <a class="pn-pn-link" href={`/personas/${next.id}/`}>{next.label} →</a>
        </div>
      </nav>
    </Container>
  </section>

  {collectionSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />}
</BaseLayout>

<style>
  .persona-hero {
    color: #fff;
    padding: 56px 0 40px;
    background: var(--accent);
  }

  [data-bg='persona-blue'] {
    background: linear-gradient(135deg, #0066cc 0%, #2997ff 100%);
  }
  [data-bg='persona-orange'] {
    background: linear-gradient(135deg, #d97706 0%, #f97316 100%);
  }
  [data-bg='persona-pink'] {
    background: linear-gradient(135deg, #be185d 0%, #ec4899 100%);
  }
  [data-bg='persona-green'] {
    background: linear-gradient(135deg, #047857 0%, #10b981 100%);
  }
  [data-bg='persona-purple'] {
    background: linear-gradient(135deg, #6d28d9 0%, #a855f7 100%);
  }
  [data-bg='persona-amber'] {
    background: linear-gradient(135deg, #b45309 0%, #f59e0b 100%);
  }

  .back-link {
    display: inline-block;
    margin-bottom: 16px;
    color: rgb(255 255 255 / 0.85);
    text-decoration: none;
    font-size: 13px;
  }
  .back-link:hover {
    color: #fff;
    text-decoration: none;
  }

  .hero-grid {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 20px;
  }

  .hero-glyph {
    width: 88px;
    height: 88px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgb(255 255 255 / 0.18);
    border-radius: var(--radius-lg);
    flex-shrink: 0;
  }

  .hero-title {
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 700;
    margin: 0 0 6px;
    letter-spacing: -0.02em;
  }

  .hero-sub {
    font-size: 17px;
    color: rgb(255 255 255 / 0.9);
    margin: 0 0 8px;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    font-size: 13px;
    color: rgb(255 255 255 / 0.85);
  }

  .pains {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .pains-label {
    font-size: 13px;
    color: rgb(255 255 255 / 0.8);
  }

  .pain-chip {
    padding: 4px 12px;
    background: rgb(255 255 255 / 0.18);
    border-radius: var(--radius-pill);
    font-size: 13px;
    font-weight: 500;
  }

  .band {
    padding: 56px 0 80px;
  }

  .display {
    font-size: clamp(22px, 2.6vw, 30px);
    font-weight: 600;
    margin: 0 0 24px;
  }

  .cat-h2-section {
    margin: 32px 0;
    max-width: 820px;
  }
  .cat-h2-section h2 {
    font-size: clamp(20px, 2.4vw, 26px);
    font-weight: 700;
    margin: 0 0 14px;
    color: var(--text);
    letter-spacing: -0.01em;
  }
  .cat-h2-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 8px;
  }
  .cat-h2-list a {
    display: block;
    padding: 12px 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--text);
    font-size: 15px;
    transition: border-color 0.18s ease;
  }
  .cat-h2-list a:hover { border-color: var(--accent); }
  .cat-h2-list strong { color: var(--accent); }
  .cat-h2-list span { color: var(--text-2); font-size: 13px; }
  .cat-h2-list em { color: var(--text-2); font-size: 13px; font-style: normal; }

  .key-section {
    margin: 0 0 28px;
    max-width: 820px;
  }
  .key-h2 {
    font-size: clamp(20px, 2.4vw, 26px);
    font-weight: 700;
    margin: 0 0 12px;
    color: var(--text);
    letter-spacing: -0.01em;
  }
  .key-lead {
    font-size: 15px;
    color: var(--text-2);
    margin: 0 0 14px;
    line-height: 1.65;
  }
  .key-note {
    font-size: 13px;
    color: var(--text-2);
    margin: 12px 0 0;
  }
  .pain-list, .cond-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 10px;
  }
  .pain-list li, .cond-list li {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 12px 16px;
    font-size: 14.5px;
    color: var(--text);
    line-height: 1.5;
  }
  .cond-list li strong {
    color: var(--accent);
    font-weight: 700;
    margin-right: 6px;
  }

  .subsidy-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
  }

  .subsidy-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: transform 0.18s var(--ease-standard);
  }
  .subsidy-card:hover {
    transform: translateY(-3px);
    text-decoration: none;
  }

  .media {
    aspect-ratio: 16 / 7;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--surface-2);
    color: var(--accent);
  }

  .tint-주거 {
    background: rgb(0 113 227 / 0.12);
    color: var(--accent);
  }
  .tint-자산 {
    background: rgb(8 145 178 / 0.12);
    color: #0891b2;
  }
  .tint-교육 {
    background: rgb(139 92 246 / 0.12);
    color: #8b5cf6;
  }
  .tint-창업 {
    background: rgb(234 88 12 / 0.12);
    color: #ea580c;
  }
  .tint-복지 {
    background: rgb(236 72 153 / 0.12);
    color: #ec4899;
  }
  .tint-취업 {
    background: rgb(16 185 129 / 0.12);
    color: #10b981;
  }

  .body {
    padding: 18px 20px 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .meta-row {
    display: flex;
    gap: 6px;
  }

  .badge {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 6px;
  }

  .badge.neutral {
    background: var(--surface-2);
    color: var(--text-2);
  }

  .badge.warning {
    background: rgb(247 195 96 / 0.18);
    color: var(--color-warning);
  }

  /* Cycle #49: 마감 D-day 배지 — 톤별 색상 */
  .badge.dl-urgent {
    background: rgb(214 44 26 / 0.12);
    color: var(--color-danger);
  }
  .badge.dl-soon {
    background: rgb(247 195 96 / 0.18);
    color: var(--color-warning);
  }
  .badge.dl-normal {
    background: rgb(0 113 227 / 0.1);
    color: var(--accent);
  }
  .badge.dl-open {
    background: rgb(16 185 129 / 0.12);
    color: var(--color-success);
  }
  :global([data-theme='dark']) .badge.dl-urgent {
    background: rgb(255 75 75 / 0.18);
  }
  :global([data-theme='dark']) .badge.dl-normal {
    background: rgb(41 151 255 / 0.18);
  }

  /* Cycle #49: 자격 hint — eligibility[0] 첫 줄 */
  .elig-hint {
    display: flex;
    align-items: flex-start;
    gap: 5px;
    font-size: 13px;
    color: var(--text-2);
    line-height: 1.45;
    margin-top: 2px;
    flex: 1;
  }
  .elig-icon {
    flex-shrink: 0;
    color: var(--color-success);
    font-weight: 700;
    font-size: 12px;
    margin-top: 1px;
  }

  .agency {
    font-size: 13px;
    color: var(--accent-link);
    font-weight: 500;
  }

  .title {
    font-size: 17px;
    font-weight: 600;
    line-height: 1.4;
    margin-bottom: 4px;
  }

  .summary {
    font-size: 13px;
    color: var(--text-2);
    line-height: 1.5;
    flex: 1;
  }

  .amount {
    font-size: 22px;
    font-weight: 700;
    color: var(--accent);
    margin-top: 6px;
    letter-spacing: -0.02em;
  }

