---
import Container from '@/components/Container.astro';
import Icon from '@/components/Icon.astro';
import PageHeader from '@/components/PageHeader.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { formatWon } from '@/data/site-data';
import { buildCollectionPage } from '@/lib/schema';
import { getCollection } from 'astro:content';

const personas = await getCollection('personas');
const subsidies = await getCollection('subsidies');

// 페르소나별 매칭 + 대표 지원금 (HOT > 금액 큰 순)
const ctxByPersona = personas.reduce<
  Record<string, { count: number; flagship?: { id: string; title: string; agency: string; amount: number; amountLabel: string } }>
>((acc, p) => {
  const matched = subsidies.filter((s) => (s.data.targetPersonas ?? []).includes(p.data.id));
  const sorted = [...matched].sort((a, b) => {
    const ah = a.data.isHot ? 1 : 0;
    const bh = b.data.isHot ? 1 : 0;
    if (ah !== bh) return bh - ah;
    return (b.data.amount ?? 0) - (a.data.amount ?? 0);
  });
  const top = sorted[0]?.data;
  acc[p.data.id] = {
    count: matched.length,
    flagship: top
      ? {
          id: top.id,
          title: top.title,
          agency: top.agency,
          amount: top.amount,
          amountLabel: top.amountLabel,
        }
      : undefined,
  };
  return acc;
}, {});

const collectionSchema = buildCollectionPage({
  name: '페르소나별 지원금',
  description: '6가지 페르소나 단위로 정리된 정부 지원금 안내.',
  pageUrl: '/personas/',
  items: personas.map((p) => ({ url: `/personas/${p.data.id}/`, name: p.data.label })),
});
---

<BaseLayout
  title="페르소나별 지원금 — 사회초년생·자영업·신혼·중장년·저소득·농업"
  description="6가지 페르소나(생애·상황) 단위로 정리된 정부 지원금 안내. 본인과 가까운 페르소나를 선택하면 매칭 지원금을 즉시 확인할 수 있습니다."
  activeNav="/subsidies/"
  breadcrumbs={[
    { name: '홈', href: '/' },
    { name: '지원금', href: '/subsidies/' },
    { name: '페르소나', href: '/personas/' },
  ]}
>
  <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />

  <section class="band">
    <Container size="wide">
      <PageHeader
        eyebrow="페르소나별 지원금"
        title="본인과 가장 가까운 그룹을 선택하세요"
        lead={`정체성·생애 단계에 가장 가까운 <strong>페르소나 6가지</strong> 중 하나를 클릭하면 매칭 지원금이 즉시 보입니다.<br />정확한 매칭은 <a href="/quick/" style="color:var(--accent-link);font-weight:600">5분 진단</a>으로 확인하세요.`}
      />

      <ul class="grid">
        {
          personas.map((p) => {
            const ctx = ctxByPersona[p.data.id];
            return (
              <li>
                <a class="tile" href={`/personas/${p.data.id}/`}>
                  <div class="tile-top">
                    <div class={`p-icon bg-${p.data.bg}`}>
                      <Icon name={p.data.icon} size={32} strokeWidth={1.5} />
                    </div>
                    <div class="p-body">
                      <div class="p-label">{p.data.label}</div>
                      <div class="p-sub">{p.data.sub}</div>
                      <ul class="p-meta">
                        <li>연령: {p.data.age}</li>
                        <li>소득: {p.data.income}</li>
                        <li>주거: {p.data.living}</li>
                      </ul>
                      {p.data.pains && p.data.pains.length > 0 && (
                        <div class="p-pains">
                          {p.data.pains.slice(0, 3).map((pp) => (
                            <span class="pain">{pp}</span>
                          ))}
                        </div>
                      )}
                    </div>
                    <div class="p-meta-right">
                      <span class="cnt">{ctx?.count ?? 0}건</span>
                      <span class="arrow" aria-hidden="true">→</span>
                    </div>
                  </div>
                  {ctx?.flagship && (
                    <div class="flagship">
                      <span class="flag-label">대표</span>
                      <div class="flag-body">
                        <div class="flag-title">{ctx.flagship.title}</div>
                        <div class="flag-meta">
                          <span class="flag-agency">{ctx.flagship.agency}</span>
                          {ctx.flagship.amount > 0 && (
                            <span class="flag-amount">
                              {formatWon(ctx.flagship.amount)}
                              <span class="flag-unit">{ctx.flagship.amountLabel}</span>
                            </span>
                          )}
                        </div>
                      </div>
                    </div>
                  )}
                </a>
              </li>
            );
          })
        }
      </ul>
    </Container>
  </section>
</BaseLayout>

<style>
  .band { padding: 48px 0 80px; }

  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 16px;
  }

  .tile {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 22px 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    transition: transform 0.18s var(--ease-standard), border-color 0.18s var(--ease-standard);
  }
  .tile:hover {
    transform: translateY(-3px);
    border-color: var(--border-2);
    text-decoration: none;
  }

  .tile-top {
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }

  .flagship {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 12px 14px;
    background: var(--surface-2);
    border-radius: var(--radius-md);
  }

  .flag-label {
    flex-shrink: 0;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--accent);
    background: rgb(0 113 227 / 0.12);
    padding: 3px 8px;
    border-radius: var(--radius-pill);
    line-height: 1.3;
  }

  .flag-body {
    flex: 1;
    min-width: 0;
  }

  .flag-title {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.4;
    color: var(--text);
    margin-bottom: 4px;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
  }

  .flag-meta {
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-wrap: wrap;
  }

  .flag-agency {
    font-size: 12px;
    color: var(--text-2);
  }

  .flag-amount {
    font-size: 14px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: -0.01em;
  }

  .flag-unit {
    font-size: 11px;
    color: var(--text-2);
    font-weight: 500;
    margin-left: 2px;
  }

  .p-icon {
    width: 56px; height: 56px;
    border-radius: var(--radius-md);
    display: inline-flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .bg-persona-blue   { background: rgb(0 113 227 / 0.16); color: var(--accent); }
  .bg-persona-orange { background: rgb(234 88 12 / 0.16); color: #ea580c; }
  .bg-persona-pink   { background: rgb(236 72 153 / 0.16); color: #ec4899; }
  .bg-persona-green  { background: rgb(16 185 129 / 0.16); color: #10b981; }
  .bg-persona-purple { background: rgb(139 92 246 / 0.16); color: #8b5cf6; }
  .bg-persona-amber  { background: rgb(217 119 6 / 0.16); color: #d97706; }

  .p-body { flex: 1; min-width: 0; }
  .p-label {
    font-size: 17px;
    font-weight: 600;
    line-height: 1.3;
  }
  .p-sub {
    font-size: 13px;
    color: var(--text-2);
    margin-top: 2px;
    margin-bottom: 8px;
  }
  .p-meta {
    list-style: none;
    margin: 0 0 8px;
    padding: 0;
    font-size: 12px;
    color: var(--text-3);
    line-height: 1.6;
  }
  .p-pains {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }
  .pain {
    font-size: 11px;
    padding: 2px 8px;
    background: var(--surface-2);
    color: var(--text-2);
    border-radius: 6px;
  }

  .p-meta-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
    flex-shrink: 0;
  }
  .cnt {
    background: rgb(0 113 227 / 0.12);
    color: var(--accent);
    border-radius: var(--radius-pill);
    padding: 3px 10px;
    font-size: 12px;
    font-weight: 700;
  }
  .arrow {
    color: var(--text-3);
    font-size: 18px;
    transition: transform 0.18s var(--ease-standard), color 0.18s;
  }
  .tile:hover .arrow {
    transform: translateX(3px);
    color: var(--accent);
  }
</style>
