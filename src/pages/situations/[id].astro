---
import Container from '@/components/Container.astro';
import CrossRefRail from '@/components/CrossRefRail.astro';
import Icon from '@/components/Icon.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { formatWon } from '@/data/site-data';
import situations from '@/data/situations.json';
import { type GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';

interface Situation {
  id: string;
  label: string;
  sub: string;
  icon: string;
  tone: string;
  description: string;
  keywords: string[];
  primaryCategories: string[];
  matchedPersonas: string[];
}

export const getStaticPaths = (() => {
  return (situations as Situation[]).map((s) => ({
    params: { id: s.id },
    props: { situation: s },
  }));
}) satisfies GetStaticPaths;

const { situation } = Astro.props as { situation: Situation };

const allSubsidies = await getCollection('subsidies');
const personas = await getCollection('personas');

// 매칭 — 키워드 + 카테고리 + 페르소나 점수화
const scored = allSubsidies.map((s) => {
  const text = `${s.data.title} ${s.data.summary ?? ''} ${(s.data.tags ?? []).join(' ')}`;
  let score = 0;
  for (const kw of situation.keywords) {
    if (text.includes(kw)) score += 10;
  }
  if (situation.primaryCategories.includes(s.data.category)) score += 8;
  for (const pid of situation.matchedPersonas) {
    if ((s.data.targetPersonas ?? []).includes(pid)) score += 12;
  }
  if (s.data.status === '신청 가능') score += 3;
  return { s, score };
});

const matched = scored
  .filter((x) => x.score > 0)
  .sort((a, b) => b.score - a.score)
  .slice(0, 12)
  .map((x) => x.s);

const matchedPersonaData = personas.filter((p) => situation.matchedPersonas.includes(p.data.id));

// 다른 라이프 이벤트 (네비게이션)
const otherSituations = (situations as Situation[]).filter((s) => s.id !== situation.id).slice(0, 8);

// 4축 cross-ref — 매칭 페르소나·카테고리·토픽
const allTopics = await getCollection('topics');
const matchedTopics = allTopics
  .filter((t) => (t.data.mainSituations ?? []).includes(situation.id))
  .slice(0, 2);

const crossRefItems = [
  ...matchedPersonaData.slice(0, 2).map((p) => ({
    href: `/personas/${p.data.id}/`,
    label: p.data.label,
    sub: p.data.sub,
  })),
  ...matchedTopics.map((t) => ({
    href: `/topics/${t.data.id}/`,
    label: t.data.title,
    sub: '주제별 종합 가이드',
  })),
  ...situation.primaryCategories.slice(0, 2).map((cat) => ({
    href: `/categories/${encodeURIComponent(cat)}/`,
    label: `${cat} 분야`,
    sub: '분야별 전체 지원금',
  })),
  { href: '/quick/', label: '5분 진단으로 정확 매칭', sub: '내 상황에 맞춰 자동 추천' },
];
---

<BaseLayout
  title={`${situation.label} — 받을 수 있는 정부 지원금 ${matched.length}건`}
  description={situation.description}
  activeNav="/subsidies/"
  breadcrumbs={[
    { name: '홈', href: '/' },
    { name: '지원금', href: '/subsidies/' },
    { name: '상황별', href: '/situations/' },
    { name: situation.label, href: `/situations/${situation.id}/` },
  ]}
>
  <section class="band">
    <Container size="wide">
      <a class="back-link" href="/situations/">← 모든 상황 보기</a>

      <header class="hero">
        <div class={`hero-icon tone-${situation.tone}`}>
          <Icon name={situation.icon} size={40} strokeWidth={1.5} />
        </div>
        <div class="hero-text">
          <div class="cat-pill">{situation.sub}</div>
          <h1 class="title">{situation.label}</h1>
          <p class="lead">{situation.description}</p>
        </div>
      </header>

      <div class="body-grid">
        <main class="body">
          <section class="post-section">
            <h2>이 상황에 매칭된 지원금 {matched.length}건</h2>
            {matched.length === 0 && (
              <p class="empty">현재 매칭된 지원금이 없습니다. <a href="/subsidies/">전체 지원금</a>에서 직접 확인해 주세요.</p>
            )}
            <ul class="match-list">
              {
                matched.map((s, i) => (
                  <li>
                    <a class="match-card" href={`/subsidies/${s.data.id}/`}>
                      <div class="rank">{i + 1}</div>
                      <div class="rc-body">
                        <div class="rc-meta">
                          <span class="b neutral">{s.data.category}</span>
                          {s.data.status === '곧 마감' && <span class="b warn">곧 마감</span>}
                          {s.data.isHot && <span class="b hot">HOT</span>}
                        </div>
                        <div class="rc-agency">{s.data.agency}</div>
                        <div class="rc-title">{s.data.title}</div>
                        <div class="rc-sum">{(s.data.summary ?? '').slice(0, 80)}{(s.data.summary ?? '').length > 80 ? '…' : ''}</div>
                        <div class="rc-amt">
                          {s.data.amount > 0 ? (
                            <>
                              {formatWon(s.data.amount)}
                              <span class="ru">{s.data.amountLabel}</span>
                            </>
                          ) : (
                            <span class="amt-na">내용 확인</span>
                          )}
                        </div>
                      </div>
                      <span class="rc-arrow" aria-hidden="true">→</span>
                    </a>
                  </li>
                ))
              }
            </ul>
          </section>

          <CrossRefRail title="함께 보면 좋은 다른 관점" items={crossRefItems} />

          <section class="post-section">
            <h2>다른 라이프 이벤트도 보기</h2>
            <ul class="event-row">
              {
                otherSituations.map((s) => (
                  <li>
                    <a class={`event-chip tone-${s.tone}`} href={`/situations/${s.id}/`}>
                      <Icon name={s.icon} size={16} strokeWidth={1.7} />
                      <span>{s.label}</span>
                      <span class="rc-arrow" aria-hidden="true">→</span>
                    </a>
                  </li>
                ))
              }
            </ul>
          </section>
        </main>

        <aside class="rail">
          {matchedPersonaData.length > 0 && (
            <div class="rail-card">
              <div class="rail-eyebrow">관련 페르소나</div>
              <div class="rail-title">이 상황에 가까운 사용자 분류</div>
              <ul class="persona-list">
                {
                  matchedPersonaData.map((p) => (
                    <li>
                      <a class="persona-link" href={`/personas/${p.data.id}/`}>
                        <Icon name={p.data.icon} size={14} strokeWidth={1.7} />
                        <span>{p.data.label}</span>
                        <span class="rc-arrow" aria-hidden="true">→</span>
                      </a>
                    </li>
                  ))
                }
              </ul>
            </div>
          )}

          <div class="rail-card">
            <div class="rail-eyebrow">5분 진단</div>
            <div class="rail-title">본인 상황 정확히 매칭</div>
            <a class="rail-cta" href="/quick/">진단 시작하기 →</a>
          </div>
          <div class="rail-card">
            <div class="rail-eyebrow">신청 흐름</div>
            <div class="rail-title">정부 지원금 신청 단계</div>
            <a class="rail-cta" href="/guide/">신청 가이드 →</a>
          </div>
        </aside>
      </div>
    </Container>
  </section>
</BaseLayout>

<style>
  .band { padding: 32px 0 80px; }

  .back-link {
    display: inline-block;
    color: var(--text-2);
    font-size: 14px;
    text-decoration: none;
    margin-bottom: 20px;
  }
  .back-link:hover { text-decoration: underline; }

  .hero {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 32px;
    max-width: 720px;
  }
  @media (max-width: 600px) {
    .hero { flex-direction: column; align-items: flex-start; gap: 16px; }
  }

  .hero-icon {
    width: 72px;
    height: 72px;
    border-radius: var(--radius-md);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .tone-주거 .hero-icon, .tone-주거 .tile-icon { background: rgb(0 113 227 / 0.12); color: var(--accent); }
  .tone-자산 .hero-icon { background: rgb(8 145 178 / 0.12); color: #0891b2; }
  .tone-교육 .hero-icon { background: rgb(139 92 246 / 0.12); color: #8b5cf6; }
  .tone-창업 .hero-icon { background: rgb(234 88 12 / 0.12); color: #ea580c; }
  .tone-복지 .hero-icon { background: rgb(236 72 153 / 0.12); color: #ec4899; }
  .tone-취업 .hero-icon { background: rgb(16 185 129 / 0.12); color: #10b981; }
  .tone-농업 .hero-icon { background: rgb(217 119 6 / 0.12); color: #d97706; }

  .hero-text { flex: 1; min-width: 0; }
  .cat-pill {
    display: inline-block;
    padding: 3px 10px;
    background: var(--surface-2);
    color: var(--text-2);
    border-radius: var(--radius-pill);
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .title {
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 10px;
  }
  .lead {
    font-size: 15px;
    color: var(--text-2);
    line-height: 1.65;
    margin: 0;
  }

  .body-grid {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 32px;
  }
  @media (max-width: 880px) { .body-grid { grid-template-columns: 1fr; } }

  .body { min-width: 0; }

  .post-section { margin-bottom: 36px; }
  .post-section h2 {
    font-size: clamp(20px, 2.4vw, 26px);
    font-weight: 700;
    margin: 0 0 16px;
    letter-spacing: -0.01em;
  }

  .empty {
    color: var(--text-2);
    font-size: 14px;
  }
  .empty a { color: var(--accent-link); }

  .match-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .match-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: transform 0.18s var(--ease-standard), border-color 0.18s;
  }
  .match-card:hover {
    transform: translateY(-2px);
    border-color: var(--border-2);
    text-decoration: none;
  }
  .rank {
    width: 32px; height: 32px;
    background: rgb(0 113 227 / 0.12);
    color: var(--accent);
    border-radius: 50%;
    display: inline-flex; align-items: center; justify-content: center;
    font-weight: 700;
    flex-shrink: 0;
  }
  .rc-body { flex: 1; min-width: 0; }
  .rc-meta { display: flex; gap: 6px; margin-bottom: 4px; }
  .b {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 6px;
  }
  .b.neutral { background: var(--surface-2); color: var(--text-2); }
  .b.warn { background: rgb(247 195 96 / 0.18); color: var(--color-warning); }
  .b.hot { background: rgb(220 38 38 / 0.16); color: #dc2626; }
  .rc-agency { font-size: 13px; color: var(--accent-link); font-weight: 500; }
  .rc-title { font-size: 16px; font-weight: 600; line-height: 1.35; margin: 2px 0; }
  .rc-sum { font-size: 13px; color: var(--text-2); line-height: 1.5; }
  .rc-amt { font-size: 18px; font-weight: 700; color: var(--accent); margin-top: 6px; }
  .rc-amt .ru { font-size: 12px; color: var(--text-2); font-weight: 500; margin-left: 4px; }
  .rc-amt .amt-na {
    font-size: 14px;
    color: var(--text-2);
    background: var(--surface-2);
    padding: 3px 10px;
    border-radius: var(--radius-sm);
    font-weight: 600;
  }
  .rc-arrow {
    color: var(--text-3);
    font-size: 18px;
    flex-shrink: 0;
    transition: transform 0.18s var(--ease-standard), color 0.18s;
  }
  .match-card:hover .rc-arrow {
    transform: translateX(3px);
    color: var(--accent);
  }

  .event-row {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .event-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    font-size: 14px;
    color: var(--text);
    text-decoration: none;
  }
  .event-chip:hover {
    border-color: var(--border-2);
    text-decoration: none;
  }

  /* Sidebar */
  .rail { display: flex; flex-direction: column; gap: 12px; }
  .rail-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 16px 18px;
  }
  .rail-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .rail-title {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.4;
    margin-bottom: 8px;
  }
  .rail-cta {
    color: var(--accent-link);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
  }
  .rail-cta:hover { text-decoration: underline; }

  .persona-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .persona-link {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 0;
    color: var(--text);
    font-size: 14px;
    text-decoration: none;
  }
  .persona-link:hover .rc-arrow { transform: translateX(3px); color: var(--accent); }
</style>
