---
import Container from '@/components/Container.astro';
import Icon from '@/components/Icon.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { CATEGORIES } from '@/data/site-data';
import { getCollection } from 'astro:content';

const subsidies = await getCollection('subsidies');
const personas = await getCollection('personas');
const personaLabels = new Map(personas.map((p) => [p.data.id, p.data.label]));

// 카테고리별 통계 — 카운트 + Top 태그 3 + Top 페르소나 2
function statsForCategory(cat: string) {
  const matched = subsidies.filter((s) => s.data.category === cat);
  const tagCount: Record<string, number> = {};
  const personaCount: Record<string, number> = {};
  for (const s of matched) {
    for (const tag of s.data.tags ?? []) {
      // 카테고리명 자체는 제외 (잡음)
      if (tag === cat) continue;
      tagCount[tag] = (tagCount[tag] ?? 0) + 1;
    }
    for (const pid of s.data.targetPersonas ?? []) {
      personaCount[pid] = (personaCount[pid] ?? 0) + 1;
    }
  }
  const topTags = Object.entries(tagCount)
    .sort((a, b) => b[1] - a[1])
    .slice(0, 3)
    .map(([t]) => t);
  const topPersonas = Object.entries(personaCount)
    .sort((a, b) => b[1] - a[1])
    .slice(0, 2)
    .map(([pid]) => personaLabels.get(pid) ?? pid);
  return { count: matched.length, topTags, topPersonas };
}

const cats = CATEGORIES.slice(1).map((c) => ({
  ...c,
  ...statsForCategory(c.id),
}));
---

<BaseLayout
  title="분야별 지원금 가이드 — 주거·취업·창업·교육·자산·복지·농업"
  description="정부 지원금 7개 분야별 안내. 분야 개요, 자격 일반론, 대표 지원금까지 한 페이지에서 확인."
  activeNav="/subsidies/"
>
  <section class="band">
    <Container size="wide">
      <div class="head">
        <h1 class="title">분야별 지원금 가이드</h1>
        <p class="lead">
          정부 지원금을 7개 분야로 나눠 한눈에 정리했습니다.<br />
          분야를 클릭하면 그 분야의 자격 요건 일반론과 대표 지원금을 함께 볼 수 있습니다.
        </p>
      </div>

      <ul class="grid">
        {
          cats.map((c) => (
            <li>
              <a class={`tile tint-${c.id}`} href={`/categories/${encodeURIComponent(c.id)}/`}>
                <div class="tile-top">
                  <div class="tile-icon">
                    <Icon name={c.icon} size={32} strokeWidth={1.5} />
                  </div>
                  <div class="tile-body">
                    <div class="tile-name">{c.name}</div>
                    <div class="tile-desc">{(c.description ?? '').slice(0, 80)}…</div>
                  </div>
                  <div class="tile-meta">
                    <span class="cnt">{c.count}건</span>
                    <span class="arrow" aria-hidden="true">→</span>
                  </div>
                </div>
                {(c.topTags.length > 0 || c.topPersonas.length > 0) && (
                  <div class="tile-stats">
                    {c.topTags.length > 0 && (
                      <div class="tile-stat-row">
                        <span class="tile-stat-label">자주 등장</span>
                        <div class="tile-stat-pills">
                          {c.topTags.map((t) => <span class="stat-pill">#{t}</span>)}
                        </div>
                      </div>
                    )}
                    {c.topPersonas.length > 0 && (
                      <div class="tile-stat-row">
                        <span class="tile-stat-label">주요 대상</span>
                        <div class="tile-stat-pills">
                          {c.topPersonas.map((p) => <span class="stat-pill persona">{p}</span>)}
                        </div>
                      </div>
                    )}
                  </div>
                )}
              </a>
            </li>
          ))
        }
      </ul>
    </Container>
  </section>
</BaseLayout>

<style>
  .band { padding: 48px 0 80px; }

  .head {
    margin-bottom: 28px;
    max-width: 720px;
  }
  .title {
    font-size: clamp(28px, 3.6vw, 44px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 12px;
  }
  .lead {
    font-size: 16px;
    color: var(--text-2);
    line-height: 1.65;
    margin: 0;
  }

  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 16px;
  }

  .tile {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 22px 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    transition: transform 0.18s var(--ease-standard), border-color 0.18s var(--ease-standard);
  }

  .tile-top {
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }
  .tile:hover {
    transform: translateY(-3px);
    border-color: var(--border-2);
    text-decoration: none;
  }

  .tile-icon {
    width: 56px; height: 56px;
    border-radius: var(--radius-md);
    display: inline-flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .tint-주거 .tile-icon { background: rgb(0 113 227 / 0.12); color: var(--accent); }
  .tint-자산 .tile-icon { background: rgb(8 145 178 / 0.12); color: #0891b2; }
  .tint-교육 .tile-icon { background: rgb(139 92 246 / 0.12); color: #8b5cf6; }
  .tint-창업 .tile-icon { background: rgb(234 88 12 / 0.12); color: #ea580c; }
  .tint-복지 .tile-icon { background: rgb(236 72 153 / 0.12); color: #ec4899; }
  .tint-취업 .tile-icon { background: rgb(16 185 129 / 0.12); color: #10b981; }
  .tint-농업 .tile-icon { background: rgb(217 119 6 / 0.12); color: #d97706; }

  .tile-body { flex: 1; min-width: 0; }
  .tile-name {
    font-size: 17px;
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: 4px;
  }
  .tile-desc {
    font-size: 13px;
    color: var(--text-2);
    line-height: 1.55;
  }

  .tile-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
    flex-shrink: 0;
  }
  .cnt {
    background: var(--surface-2);
    color: var(--text-2);
    border-radius: var(--radius-pill);
    padding: 3px 10px;
    font-size: 12px;
    font-weight: 700;
  }
  .arrow {
    color: var(--text-3);
    font-size: 18px;
    transition: transform 0.18s var(--ease-standard), color 0.18s;
  }
  .tile:hover .arrow {
    transform: translateX(3px);
    color: var(--accent);
  }

  .tile-stats {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-top: 12px;
    border-top: 1px solid var(--border);
  }

  .tile-stat-row {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .tile-stat-label {
    font-size: 11px;
    font-weight: 700;
    color: var(--text-2);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    flex-shrink: 0;
    min-width: 56px;
  }

  .tile-stat-pills {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
  }

  .stat-pill {
    padding: 2px 8px;
    background: var(--surface-2);
    color: var(--text-2);
    border-radius: var(--radius-pill);
    font-size: 11px;
    font-weight: 500;
  }

  .stat-pill.persona {
    background: rgb(0 113 227 / 0.1);
    color: var(--accent);
    font-weight: 600;
  }
</style>
