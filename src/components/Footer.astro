---
import { CATEGORIES } from '@/data/site-data';

const SITE = {
  name: '지원금가이드',
  legalName: '스마트데이터샵',
  founder: '김준혁',
  taxId: '406-06-34485',
  address: '인천광역시 계양구 새벌로 88, 효성동',
  email: 'smartdatashop@gmail.com',
};

// CATEGORIES에서 'all' 제외한 7종 — Footer 분야별 hub 진입점
const categoryLinks = CATEGORIES.filter((c) => c.id !== 'all').map((c) => ({
  href: `/categories/${encodeURIComponent(c.id)}/`,
  label: c.id, // 짧은 라벨 (주거·자산 등)
}));

// Cycle #52: 그룹 레이블 추가 — 정보 위계 명시화
const linkGroups: Array<{ label: string; items: Array<{ href: string; label: string }> }> = [
  {
    label: '메인',
    items: [
      { href: '/', label: '홈' },
      { href: '/issues/', label: '오늘의 이슈' },
      { href: '/issues/all/', label: '분석 포스트 전체' },
      { href: '/subsidies/', label: '지원금 둘러보기' },
      { href: '/guide/', label: '신청 가이드' },
    ],
  },
  {
    label: '내 상황으로 찾기',
    items: [
      { href: '/personas/', label: '페르소나별' },
      { href: '/situations/', label: '상황별' },
      { href: '/topics/', label: '주제별' },
      { href: '/guides/', label: '심층 가이드' },
      { href: '/glossary/', label: '용어 사전' },
    ],
  },
  {
    label: '분야별 지원금',
    items: categoryLinks,
  },
  {
    label: '사이트',
    items: [
      { href: '/about/', label: '사이트 소개' },
      { href: '/editorial-policy/', label: '편집 정책' },
      { href: '/contact/', label: '문의' },
    ],
  },
  {
    label: '법적 고지',
    items: [
      { href: '/privacy/', label: '개인정보처리방침' },
      { href: '/terms/', label: '이용약관' },
      { href: '/cookies/', label: '쿠키 정책' },
    ],
  },
];

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="brand-block">
        <div class="brand">
          <span class="brand-mark" aria-hidden="true">지</span>
          <span class="brand-name">{SITE.name}</span>
        </div>
        <p class="tagline">
          정부 지원금을 페르소나별로 정리한 정보 안내 사이트.
          신청 대행은 하지 않으며 정부 공식 사이트로 안내합니다.
        </p>
        {/* Cycle #52: 5분 진단을 Footer 강조 CTA로 격상 — 사이트 어디서든 1-click 도달 */}
        <a class="footer-quick-cta" href="/quick/">
          <span class="fqc-icon" aria-hidden="true">⚡</span>
          <span class="fqc-text">
            <span class="fqc-title">5분 진단으로 빠른 매칭</span>
            <span class="fqc-sub">개인정보 저장 0 · 브라우저 내 계산</span>
          </span>
          <span class="fqc-arrow" aria-hidden="true">→</span>
        </a>
      </div>

      {
        linkGroups.map((g) => (
          <div class="link-col">
            <h3 class="link-col-label">{g.label}</h3>
            <ul>
              {g.items.map((l) => (
                <li>
                  <a href={l.href}>{l.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="legal">
      <div class="trust-badge">
        <span class="trust-mark" aria-hidden="true">✓</span>
        AI 보조로 작성, <strong>김준혁 편집책임자</strong>가 검수합니다.
        <a href="/editorial-policy/">편집 정책 →</a>
      </div>
      <div class="legal-row">
        <span>{SITE.legalName}</span>
        <span class="dot">·</span>
        <span>대표 {SITE.founder}</span>
        <span class="dot">·</span>
        <span>사업자등록 {SITE.taxId}</span>
      </div>
      <div class="legal-row">
        <span>{SITE.address}</span>
        <span class="dot">·</span>
        <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
      </div>
      <div class="copy">© {year} {SITE.name}. 정보 안내 사이트 · 신청 대행 없음.</div>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: 80px;
    border-top: 1px solid var(--border);
    background: var(--bg-alt);
    /* 스크롤 진입 전까지 layout/paint 스킵 — 초기 LCP·Style&Layout 비용 절감 */
    content-visibility: auto;
    contain-intrinsic-size: 1px 480px;
  }

  .footer-inner {
    max-width: 1200px;
    margin-inline: auto;
    padding: 48px 24px 32px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    gap: 32px;
    margin-bottom: 40px;
  }

  @media (max-width: 960px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr 1fr;
      gap: 32px 24px;
    }
    .brand-block {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 700;
    font-size: 18px;
    color: var(--text);
    margin-bottom: 12px;
  }

  .brand-mark {
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--accent);
    color: var(--on-accent);
    border-radius: 8px;
    font-size: 18px;
    font-weight: 700;
  }

  .tagline {
    font-size: 14px;
    color: var(--text-2);
    line-height: 1.6;
    max-width: 380px;
    margin: 0;
  }

  .link-col {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  /* Cycle #52: 그룹 레이블 — 정보 위계 명시 */
  .link-col-label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text);
    margin: 0;
    padding-bottom: 4px;
  }

  .link-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  /* WCAG 2.2 target-size: 24×24px 이상 보장 */
  .link-col a {
    display: inline-block;
    font-size: 14px;
    color: var(--text-2);
    text-decoration: none;
    padding: 6px 0;
    min-height: 24px;
    line-height: 1.5;
  }

  .link-col a:hover {
    color: var(--text);
    text-decoration: underline;
  }

  /* Cycle #52: Footer 5분 진단 강조 CTA */
  .footer-quick-cta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-top: 16px;
    padding: 12px 16px;
    background: rgb(0 113 227 / 0.08);
    border: 1px solid rgb(0 113 227 / 0.18);
    border-radius: var(--radius-md);
    color: var(--text);
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s, transform 0.15s;
  }
  :global([data-theme='dark']) .footer-quick-cta {
    background: rgb(41 151 255 / 0.1);
    border-color: rgb(41 151 255 / 0.22);
  }
  .footer-quick-cta:hover {
    text-decoration: none;
    border-color: var(--accent);
    transform: translateY(-1px);
  }
  .fqc-icon {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--accent);
    color: var(--on-accent);
    border-radius: var(--radius-sm);
    font-size: 14px;
  }
  .fqc-text {
    display: flex;
    flex-direction: column;
    line-height: 1.35;
  }
  .fqc-title {
    font-size: 14px;
    font-weight: 700;
    color: var(--text);
  }
  .fqc-sub {
    font-size: 12px;
    color: var(--text-2);
    margin-top: 2px;
  }
  .fqc-arrow {
    margin-left: auto;
    color: var(--accent);
    font-size: 16px;
    transition: transform 0.15s;
  }
  .footer-quick-cta:hover .fqc-arrow {
    transform: translateX(3px);
  }

  .legal {
    border-top: 1px solid var(--border);
    padding-top: 24px;
    font-size: 13px;
    color: var(--text-2);
    line-height: 1.6;
  }

  .trust-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    background: rgb(0 113 227 / 0.06);
    border: 1px solid rgb(0 113 227 / 0.16);
    border-radius: var(--radius-md);
    font-size: 13px;
    color: var(--text);
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .trust-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    background: var(--accent);
    color: var(--on-accent);
    border-radius: 50%;
    font-size: 11px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .trust-badge a {
    color: var(--accent-link);
    font-weight: 500;
  }

  .legal-row {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 4px;
  }

  .legal-row a {
    color: var(--text-2);
  }

  .dot {
    color: var(--text-3);
  }

  .copy {
    margin-top: 12px;
    color: var(--text-3);
  }
</style>
