---
/**
 * Lucide-style 인라인 SVG 아이콘 세트
 * 프로토타입 icons.jsx 이식 (lucide.dev — ISC 라이선스, 인라인 재구현)
 */
interface Props {
  name: string;
  size?: number;
  strokeWidth?: number;
  class?: string;
  ariaHidden?: boolean;
}

const { name, size = 18, strokeWidth = 1.8, class: className = '', ariaHidden = true } = Astro.props;

const common = {
  width: size,
  height: size,
  viewBox: '0 0 24 24',
  fill: 'none',
  stroke: 'currentColor',
  'stroke-width': strokeWidth,
  'stroke-linecap': 'round' as const,
  'stroke-linejoin': 'round' as const,
  class: className,
  ...(ariaHidden ? { 'aria-hidden': 'true' as const } : {}),
};
---

{
  /* prettier-ignore */ name === 'search' && (
    <svg {...common}><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
  )
}
{
  name === 'arrow-right' && (
    <svg {...common}><path d="M5 12h14M13 5l7 7-7 7"/></svg>
  )
}
{
  name === 'arrow-up-right' && (
    <svg {...common}><path d="M7 17 17 7M7 7h10v10"/></svg>
  )
}
{
  name === 'arrow-left' && (
    <svg {...common}><path d="M19 12H5M11 19l-7-7 7-7"/></svg>
  )
}
{
  name === 'check' && (
    <svg {...common}><path d="M5 12l5 5L20 7"/></svg>
  )
}
{
  name === 'sparkles' && (
    <svg {...common}><path d="M12 3l1.9 5.6L19.5 10.5 13.9 12.4 12 18l-1.9-5.6L4.5 10.5l5.6-1.9L12 3z"/><path d="M19 17l.7 1.8L21.5 19.5l-1.8.7L19 22l-.7-1.8L16.5 19.5l1.8-.7L19 17z"/></svg>
  )
}
{
  name === 'menu' && (
