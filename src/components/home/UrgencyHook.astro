---
import Container from '@/components/Container.astro';
---

<section class="urgency-hook">
  <div class="urgency-glow" aria-hidden="true"></div>
  <Container size="wide">
    <div class="urgency-pulse">
      <span class="urgency-dot" aria-hidden="true"></span>
      <span class="urgency-pulse-label">FACT CHECK</span>
    </div>

    <div class="urgency-message">
      <div class="urgency-headline">
        <span class="urgency-warn uh-fade">국가 예산은 한정되어 있습니다.</span>
        <span class="urgency-rest">
          <span class="uh-word" style="--i:0">당신이</span>
          <span class="uh-word" style="--i:1">망설이는</span>
          <span class="uh-word" style="--i:2">지금</span>
          <span class="uh-word" style="--i:3">이</span>
          <span class="uh-word" style="--i:4">순간에도,</span>
          <span class="uh-word" style="--i:5">누군가의</span>
          <span class="uh-word" style="--i:6">통장에는</span>
          <em class="uh-word uh-pulse" style="--i:7">지원금이</em>
          <span class="uh-word" style="--i:8">꽂히고</span>
          <span class="uh-word" style="--i:9">있습니다.</span>
        </span>
      </div>

      <div class="urgency-stats">
        <div class="urgency-stat">
          <div class="urgency-stat-label">2025년 정부 지원금 누적 지급액</div>
          <div class="urgency-stat-value money">38조 4,200억원</div>
          <div class="urgency-stat-src">출처: 기획재정부 2025 결산</div>
        </div>
        <div class="urgency-stat">
          <div class="urgency-stat-label">2026년 정부 지원사업 총예산</div>
          <div class="urgency-stat-value people">42조 9,000억원</div>
          <div class="urgency-stat-src">출처: 기획재정부 2026 예산서</div>
        </div>
        <div class="urgency-stat">
          <div class="urgency-stat-label">한도형 지원금 평균 예산 소진</div>
          <div class="urgency-stat-value budget">9월 중순</div>
          <div class="urgency-stat-src">출처: 정부 부처 평균 (최근 3년)</div>
        </div>
      </div>
    </div>
  </Container>
</section>

<style>
  .urgency-hook {
    position: relative;
    background: linear-gradient(135deg, #0a0a0c 0%, #1a1a1f 100%);
    color: #f5f5f7;
    padding: 72px 0 64px;
    overflow: hidden;
    isolation: isolate;
  }

  .urgency-glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 30%, rgb(220 38 38 / 0.18), transparent 40%),
      radial-gradient(circle at 80% 70%, rgb(0 113 227 / 0.15), transparent 45%);
    z-index: -1;
    pointer-events: none;
  }

  .urgency-pulse {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    background: rgb(220 38 38 / 0.18);
    border: 1px solid rgb(220 38 38 / 0.32);
    border-radius: var(--radius-pill);
    margin-bottom: 24px;
  }

  .urgency-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #ef4444;
    box-shadow: 0 0 0 4px rgb(220 38 38 / 0.32);
  }

  .urgency-pulse-label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: #fca5a5;
    text-transform: uppercase;
  }

  .urgency-message {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 56px;
    align-items: center;
  }

  @media (max-width: 880px) {
    .urgency-message {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  .urgency-headline {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .urgency-warn {
    font-size: 18px;
    font-weight: 600;
    color: #fca5a5;
    letter-spacing: -0.01em;
  }

  .urgency-rest {
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.02em;
  }

  .urgency-rest em {
    font-style: normal;
    color: #ef4444;
    font-weight: 800;
  }

  /* 단어 페이드인 애니메이션 — CSS only, JS 없음 */
  .uh-fade {
    opacity: 0;
    animation: uh-fade-in 0.5s ease-out 0.05s forwards;
  }

  .uh-word {
    display: inline-block;
    opacity: 0;
    transform: translateY(8px);
    animation: uh-word-in 0.45s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    animation-delay: calc(0.25s + var(--i, 0) * 0.07s);
  }

  .uh-pulse {
    animation:
      uh-word-in 0.45s cubic-bezier(0.2, 0.8, 0.2, 1) forwards,
      uh-pulse-glow 1.6s ease-in-out 1.4s infinite;
    animation-delay: calc(0.25s + var(--i, 0) * 0.07s), 1.4s;
  }

  @keyframes uh-fade-in {
    to {
      opacity: 1;
    }
  }

  @keyframes uh-word-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes uh-pulse-glow {
    0%, 100% {
      text-shadow: none;
    }
    50% {
      text-shadow: 0 0 24px rgb(239 68 68 / 0.5);
    }
  }

  /* 모션 감소 선호 시 즉시 표시 */
  @media (prefers-reduced-motion: reduce) {
    .uh-fade,
    .uh-word,
    .uh-pulse {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }

  .urgency-stats {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .urgency-stat {
    padding: 18px 20px;
    background: rgb(255 255 255 / 0.04);
    border: 1px solid rgb(255 255 255 / 0.08);
    border-radius: var(--radius-md);
  }

  .urgency-stat-label {
    font-size: 12px;
    color: rgb(255 255 255 / 0.6);
    margin-bottom: 6px;
  }

  .urgency-stat-value {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 4px;
  }

  .urgency-stat-value.money {
    color: #4ade80;
  }
  .urgency-stat-value.people {
    color: #ef4444;
  }
  .urgency-stat-value.budget {
    color: #fbbf24;
  }

  .urgency-stat-src {
    font-size: 11px;
    color: rgb(255 255 255 / 0.45);
  }
</style>
