---
import Container from '@/components/Container.astro';
---

<section class="urgency-hook">
  <Container size="wide">
    <div class="urgency-card">
      <div class="urgency-pulse">
        <span class="urgency-dot" aria-hidden="true"></span>
        <span class="urgency-pulse-label">FACT CHECK</span>
      </div>

      <div class="urgency-headline">
        <span class="urgency-warn uh-fade">국가 예산은 한정되어 있습니다.</span>
        <span class="urgency-rest">
          <span class="uh-word" style="--i:0">당신이</span>
          <span class="uh-word" style="--i:1">망설이는</span>
          <span class="uh-word" style="--i:2">지금</span>
          <span class="uh-word" style="--i:3">이</span>
          <span class="uh-word" style="--i:4">순간에도,</span>
          <br />
          <span class="uh-word" style="--i:5">누군가의</span>
          <span class="uh-word" style="--i:6">통장에는</span>
          <em class="uh-word uh-pulse" style="--i:7">지원금이</em>
          <span class="uh-word" style="--i:8">꽂히고</span>
          <span class="uh-word" style="--i:9">있습니다.</span>
        </span>
      </div>

      <div class="urgency-stats">
        <div class="urgency-stat">
          <div class="urgency-stat-label">2025년 정부 지원금 누적 지급액</div>
          <div class="urgency-stat-value">38조 4,200억원</div>
          <div class="urgency-stat-src">출처: 기획재정부 2025 결산</div>
        </div>
        <div class="urgency-stat">
          <div class="urgency-stat-label">2026년 정부 지원사업 총예산</div>
          <div class="urgency-stat-value danger">42조 9,000억원</div>
          <div class="urgency-stat-src">출처: 기획재정부 2026 예산서</div>
        </div>
        <div class="urgency-stat">
          <div class="urgency-stat-label">한도형 지원금 평균 예산 소진</div>
          <div class="urgency-stat-value warning">9월 중순</div>
          <div class="urgency-stat-src">출처: 정부 부처 평균 (최근 3년)</div>
        </div>
      </div>
    </div>
  </Container>
</section>

<style>
  .urgency-hook {
    padding: 32px 0 16px;
  }

  .urgency-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 36px 40px 32px;
  }

  @media (max-width: 600px) {
    .urgency-card {
      padding: 24px;
    }
  }

  .urgency-pulse {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 5px 12px;
    background: rgb(0 113 227 / 0.1);
    border-radius: var(--radius-pill);
    margin-bottom: 20px;
  }

  :global([data-theme='dark']) .urgency-pulse {
    background: rgb(41 151 255 / 0.16);
  }

  .urgency-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
  }

  .urgency-pulse-label {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--accent);
    text-transform: uppercase;
  }

  .urgency-headline {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 28px;
  }

  .urgency-warn {
    font-size: clamp(15px, 1.5vw, 17px);
    font-weight: 700;
    color: var(--accent);
    letter-spacing: -0.01em;
  }

  .urgency-rest {
    font-size: clamp(22px, 2.6vw, 32px);
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .urgency-rest em {
    font-style: normal;
    color: var(--color-danger);
    font-weight: 800;
  }

  /* 단어 페이드인 애니메이션 — CSS only, JS 없음 */
  .uh-fade {
    opacity: 0;
    animation: uh-fade-in 0.5s ease-out 0.05s forwards;
  }

  .uh-word {
    display: inline-block;
    opacity: 0;
    transform: translateY(8px);
    animation: uh-word-in 0.45s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    animation-delay: calc(0.25s + var(--i, 0) * 0.07s);
  }

  .uh-pulse {
    animation:
      uh-word-in 0.45s cubic-bezier(0.2, 0.8, 0.2, 1) forwards,
      uh-pulse-glow 1.6s ease-in-out 1.4s infinite;
    animation-delay: calc(0.25s + var(--i, 0) * 0.07s), 1.4s;
    /* text-shadow 펄스 paint 격리 — LCP 직후 메인 스레드 reflow 비용 0 */
    contain: layout style;
  }

  @keyframes uh-fade-in {
    to {
      opacity: 1;
    }
  }

  @keyframes uh-word-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes uh-pulse-glow {
    0%, 100% {
      text-shadow: none;
    }
    50% {
      text-shadow: 0 0 18px rgb(214 44 26 / 0.32);
    }
  }

  /* 모션 감소 선호 시 즉시 표시 */
  @media (prefers-reduced-motion: reduce) {
    .uh-fade,
    .uh-word,
    .uh-pulse {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }

  .urgency-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
  }

  @media (max-width: 720px) {
    .urgency-stats {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }

  .urgency-stat-label {
    font-size: 13px;
    color: var(--text-2);
    margin-bottom: 4px;
  }

  .urgency-stat-value {
    font-size: clamp(20px, 2.2vw, 24px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 4px;
    line-height: 1.2;
  }

  .urgency-stat-value.danger {
    color: var(--color-danger);
  }

  .urgency-stat-value.warning {
    color: var(--color-warning);
  }

  .urgency-stat-src {
    font-size: 12px;
    color: var(--text-3);
  }
</style>
