---
import Container from '@/components/Container.astro';
import Icon from '@/components/Icon.astro';
import { getCollection } from 'astro:content';

const personas = (await getCollection('personas')).sort((a, b) => {
  const order = ['office-rookie', 'self-employed', 'newlywed-family', 'senior', 'low-income', 'farmer'];
  return order.indexOf(a.data.id) - order.indexOf(b.data.id);
});

const allSubsidies = await getCollection('subsidies');

// 페르소나별 매칭 + 대표 지원금 (HOT > 금액 큰 순)
const personaContext = personas.reduce<Record<string, { count: number; flagship?: { title: string; agency: string } }>>(
  (acc, p) => {
    const matched = allSubsidies.filter((s) => (s.data.targetPersonas ?? []).includes(p.data.id));
    const sorted = [...matched].sort((a, b) => {
      const ah = a.data.isHot ? 1 : 0;
      const bh = b.data.isHot ? 1 : 0;
      if (ah !== bh) return bh - ah;
      return (b.data.amount ?? 0) - (a.data.amount ?? 0);
    });
    acc[p.data.id] = {
      count: matched.length,
      flagship: sorted[0]
        ? { title: sorted[0].data.title, agency: sorted[0].data.agency }
        : undefined,
    };
    return acc;
  },
  {},
);
---

<section class="band">
  <Container size="wide">
    <div class="section-head">
      <div class="eyebrow">나 같은 사람은?</div>
      <h2 class="display">본인과 가장 비슷한 상황을 골라보세요</h2>
      <p class="lead">
        클릭만 하면 그 그룹이 받는 지원금이 즉시 나옵니다.
        입력·로그인 없이, 개인정보도 묻지 않습니다.
      </p>
    </div>

    <div class="persona-grid">
      {
        personas.map((p) => {
          const ctx = personaContext[p.data.id];
          return (
            <a class={`persona-card ${p.data.bg}`} href={`/personas/${p.data.id}/`}>
              <div class="card-top">
                <div class="persona-glyph">
                  <Icon name={p.data.icon} size={32} strokeWidth={1.6} />
                </div>
                {ctx && ctx.count > 0 && (
                  <span class="count-pill">매칭 {ctx.count}건</span>
                )}
              </div>
              <div class="persona-label">{p.data.label}</div>
              <div class="persona-sub">{p.data.sub}</div>
              <div class="persona-meta">
                <span>{p.data.age}</span>
                <span aria-hidden="true">·</span>
                <span>{p.data.income}</span>
              </div>
              {ctx?.flagship && (
                <div class="flagship">
                  <span class="flag-label">대표</span>
                  <span class="flag-title">{ctx.flagship.title}</span>
                </div>
              )}
            </a>
          );
        })
      }
    </div>
  </Container>
</section>

<style>
  .band {
    padding: 64px 0;
  }

  .section-head {
    max-width: 720px;
    margin-bottom: 32px;
  }

  .eyebrow {
    font-size: 13px;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 10px;
  }

  .display {
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.018em;
    margin: 0 0 12px;
  }

  .lead {
    font-size: 16px;
    color: var(--text-2);
    margin: 0;
    line-height: 1.6;
  }

  .persona-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }

  .persona-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 24px 24px 22px;
    border-radius: var(--radius-lg);
    color: #fff;
    text-decoration: none;
    overflow: hidden;
    transition: transform 0.2s var(--ease-standard), box-shadow 0.2s var(--ease-standard);
  }

  .persona-card:hover {
    transform: translateY(-4px);
    text-decoration: none;
  }

  .persona-blue {
    background: linear-gradient(135deg, #0066cc 0%, #2997ff 100%);
  }
  .persona-orange {
    background: linear-gradient(135deg, #d97706 0%, #f97316 100%);
  }
  .persona-pink {
    background: linear-gradient(135deg, #be185d 0%, #ec4899 100%);
  }
  .persona-green {
    background: linear-gradient(135deg, #047857 0%, #10b981 100%);
  }
  .persona-purple {
    background: linear-gradient(135deg, #6d28d9 0%, #a855f7 100%);
  }
  .persona-amber {
    background: linear-gradient(135deg, #b45309 0%, #f59e0b 100%);
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 6px;
  }

  .persona-glyph {
    width: 52px;
    height: 52px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgb(255 255 255 / 0.15);
    border-radius: var(--radius-md);
  }

  .count-pill {
    padding: 4px 10px;
    background: rgb(255 255 255 / 0.22);
    color: #fff;
    border-radius: var(--radius-pill);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .persona-label {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.015em;
  }

  .persona-sub {
    font-size: 14px;
    color: rgb(255 255 255 / 0.85);
    margin-bottom: 6px;
  }

  .persona-meta {
    display: flex;
    gap: 6px;
    align-items: center;
    font-size: 13px;
    color: rgb(255 255 255 / 0.85);
    margin-bottom: 10px;
  }

  .flagship {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    padding: 10px 12px;
    background: rgb(255 255 255 / 0.14);
    border-radius: var(--radius-md);
    margin-top: 4px;
  }

  .flag-label {
    flex-shrink: 0;
    font-size: 11px;
    font-weight: 700;
    color: rgb(255 255 255 / 0.85);
    background: rgb(255 255 255 / 0.18);
    padding: 2px 7px;
    border-radius: var(--radius-pill);
    letter-spacing: 0.04em;
  }

  .flag-title {
    font-size: 13px;
    font-weight: 600;
    color: #fff;
    line-height: 1.4;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .persona-card::after {
    content: '→';
    position: absolute;
    bottom: 22px;
    right: 22px;
    color: rgb(255 255 255 / 0.7);
    font-size: 18px;
    font-weight: 600;
    transition: transform 0.2s var(--ease-standard), color 0.2s;
  }

  .persona-card:hover::after {
    transform: translateX(4px);
    color: #fff;
  }
</style>
