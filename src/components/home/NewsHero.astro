---
import Container from '@/components/Container.astro';
import { TODAY_NEWS } from '@/data/site-data';

const n = TODAY_NEWS;
const w = 520;
const h = 130;
const pad = 8;
const max = Math.max(...n.trend);
const min = Math.min(...n.trend);
const pts = n.trend.map((v, i) => {
  const x = pad + (i * (w - pad * 2)) / (n.trend.length - 1);
  const y = h - pad - ((v - min) / (max - min)) * (h - pad * 2);
  return [x, y] as const;
});
const linePath = pts.map((p, i) => `${i === 0 ? 'M' : 'L'} ${p[0]} ${p[1]}`).join(' ');
const last = pts[pts.length - 1] ?? [0, 0];
const first = pts[0] ?? [0, 0];
const areaPath = `${linePath} L ${last[0]} ${h - pad} L ${first[0]} ${h - pad} Z`;
---

<section class="news-band">
  <Container size="wide">
    <div class="news-meta">
      <span class="news-pulse"><span class="dot" aria-hidden="true"></span>{n.badge}</span>
      <span class="news-meta-text">{n.date}</span>
      <span class="news-meta-dot">·</span>
      <span class="news-meta-text">{n.source}</span>
    </div>

    <div class="news-grid">
      <div class="news-big-card">
        <div class="news-big-head">
          <h1 class="news-headline">{n.headline}</h1>
          <p class="news-subhead">{n.subhead}</p>
        </div>

        <div class="news-big-number-row">
          <div class="news-big-label">{n.bigLabel}</div>
          <div class="news-big-number">
            <span class="prev-val">{n.prevValue}</span>
            <span class="arrow" aria-hidden="true">→</span>
            <span class="cur-val">{n.bigNumber}</span>
          </div>
          <div class="news-delta-pill">{n.deltaPct} 인상</div>
        </div>

        <div class="news-actions">
          <a class="cta-primary" href="/issues/main/">이 이슈 자세히 →</a>
          {n.related[0] && <a class="cta-ghost" href={`/subsidies/${n.related[0]}/`}>지원금 상세</a>}
        </div>

        <div class="news-trend-graph">
          <svg viewBox={`0 0 ${w} ${h}`} preserveAspectRatio="none" width="100%" height={h} aria-hidden="true">
            <defs>
              <linearGradient id="trendFill" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="var(--accent)" stop-opacity="0.35"></stop>
                <stop offset="100%" stop-color="var(--accent)" stop-opacity="0"></stop>
              </linearGradient>
            </defs>
            <path d={areaPath} fill="url(#trendFill)"></path>
            <path d={linePath} fill="none" stroke="var(--accent)" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round"></path>
            <circle cx={last[0]} cy={last[1]} r="5" fill="var(--accent)"></circle>
            <circle cx={last[0]} cy={last[1]} r="11" fill="var(--accent)" opacity="0.18"></circle>
          </svg>
          <div class="news-trend-axis">
            <span>1월</span><span>4월</span><span>7월</span><span>10월</span><span>12월</span>
          </div>
          <div class="news-trend-label">{n.trendLabel}</div>
        </div>
      </div>

      <aside class="news-trend-card">
        <div class="news-trend-card-head">
          <div class="trend-eyebrow">실시간 인기</div>
          <div class="trend-title">최근 1시간 급상승</div>
        </div>

        <ol class="news-trend-list">
          {
            n.trending.map((t) => (
              <li class:list={['news-trend-item', t.hot && 'hot']}>
                {t.related ? (
                  <a href={`/subsidies/${t.related}/`} class="trend-link">
                    <span class="rank">{t.rank}</span>
                    <span class="title">{t.title}</span>
                    <span class="delta">↑ {t.delta}</span>
                  </a>
                ) : (
                  <>
                    <span class="rank">{t.rank}</span>
                    <span class="title">{t.title}</span>
                    <span class="delta">↑ {t.delta}</span>
                  </>
                )}
              </li>
            ))
          }
        </ol>

        <div class="news-trend-card-foot">매시간 업데이트 · 검색량 기준</div>
      </aside>
    </div>

    <div class="news-stat-strip">
      {
        n.publicStats.map((s) => (
          <div class:list={['news-stat-cell', `tone-${s.tone}`]}>
            <div class="label">{s.label}</div>
            <div class="value">{s.value}</div>
            <div class="sub">{s.sub}</div>
          </div>
        ))
      }
    </div>
  </Container>
</section>

<style>
  .news-band {
    padding: 56px 0 64px;
    border-bottom: 1px solid var(--border);
  }

  .news-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }

  .news-pulse {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 5px 12px;
    background: rgb(220 38 38 / 0.12);
    color: #c11216;
    border-radius: var(--radius-pill);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  :global([data-theme='dark']) .news-pulse {
    background: rgb(220 38 38 / 0.2);
    color: #fca5a5;
  }

  .news-pulse .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
  }

  .news-meta-text {
    font-size: 13px;
    color: var(--text-2);
  }

  .news-meta-dot {
    color: var(--text-3);
  }

  .news-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 24px;
    margin-bottom: 32px;
  }

  @media (max-width: 880px) {
    .news-grid {
      grid-template-columns: 1fr;
    }
  }

  .news-big-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 36px;
  }

  .news-headline {
    font-size: clamp(28px, 3.6vw, 44px);
    font-weight: 700;
    line-height: 1.18;
    letter-spacing: -0.02em;
    margin: 0 0 14px;
  }

  .news-subhead {
    font-size: 17px;
    color: var(--text-2);
    line-height: 1.55;
    margin: 0 0 24px;
  }

  .news-big-number-row {
    padding: 20px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin-bottom: 24px;
  }

  .news-big-label {
    font-size: 13px;
    color: var(--text-2);
    margin-bottom: 6px;
  }

  .news-big-number {
    display: inline-flex;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }

  .prev-val {
    font-size: 24px;
    font-weight: 600;
    color: var(--text-3);
    text-decoration: line-through;
    text-decoration-thickness: 1.5px;
  }

  .arrow {
    font-size: 22px;
    color: var(--text-2);
  }

  .cur-val {
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 700;
    color: var(--accent);
    letter-spacing: -0.025em;
    line-height: 1;
  }

  .news-delta-pill {
    display: inline-block;
    padding: 4px 10px;
    background: rgb(0 169 110 / 0.16);
    color: var(--color-success);
    border-radius: var(--radius-pill);
    font-size: 13px;
    font-weight: 700;
  }

  .news-actions {
    display: flex;
    gap: 8px;
    margin-top: 20px;
    flex-wrap: wrap;
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 11px 20px;
    background: var(--accent);
    color: var(--on-accent);
    border-radius: var(--radius-pill);
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
  }

  .cta-primary:hover {
    text-decoration: none;
    background: color-mix(in oklch, var(--accent), black 8%);
  }

  .cta-ghost {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 20px;
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border-2);
    border-radius: var(--radius-pill);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
  }
  .cta-ghost:hover {
    text-decoration: none;
    background: var(--surface-2);
  }

  .news-trend-graph {
    margin-top: 8px;
  }

  .news-trend-axis {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    color: var(--text-3);
    margin-top: 4px;
    padding: 0 4px;
  }

  .news-trend-label {
    font-size: 12px;
    color: var(--text-2);
    margin-top: 6px;
  }

  /* 실시간 인기 카드 */
  .news-trend-card {
    background: linear-gradient(180deg, var(--color-graphite-a) 0%, #1a1a1c 100%);
    color: #f5f5f7;
    border-radius: var(--radius-xl);
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .trend-eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgb(255 255 255 / 0.65);
  }

  .trend-title {
    font-size: 19px;
    font-weight: 700;
    letter-spacing: -0.015em;
    margin-top: 4px;
  }

  .news-trend-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
  }

  .news-trend-item {
    border-radius: var(--radius-sm);
  }

  .trend-link,
  .news-trend-item > .rank {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    color: inherit;
    text-decoration: none;
  }

  .trend-link:hover {
    background: rgb(255 255 255 / 0.06);
    text-decoration: none;
  }

  .rank {
    width: 22px;
    height: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgb(255 255 255 / 0.08);
    border-radius: 6px;
    font-size: 12px;
    font-weight: 700;
    color: rgb(255 255 255 / 0.85);
    flex-shrink: 0;
  }

  .news-trend-item.hot .rank {
    background: rgb(220 38 38 / 0.25);
    color: #fca5a5;
  }

  .title {
    flex: 1;
    font-size: 14px;
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .delta {
    font-size: 12px;
    color: #4ade80;
    font-weight: 600;
    flex-shrink: 0;
  }

  .news-trend-card-foot {
    font-size: 11px;
    color: rgb(255 255 255 / 0.5);
    border-top: 1px solid rgb(255 255 255 / 0.08);
    padding-top: 12px;
    margin-top: 4px;
  }

  /* Stat strip */
  .news-stat-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }

  @media (max-width: 720px) {
    .news-stat-strip {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .news-stat-cell {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 16px 18px;
  }

  .news-stat-cell .label {
    font-size: 12px;
    color: var(--text-2);
    margin-bottom: 4px;
  }

  .news-stat-cell .value {
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 4px;
  }

  .news-stat-cell .sub {
    font-size: 11px;
    color: var(--text-3);
  }

  .tone-accent .value {
    color: var(--accent);
  }
  .tone-positive .value {
    color: var(--color-success);
  }
  .tone-warning .value {
    color: var(--color-warning);
  }
</style>
