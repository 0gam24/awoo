---
import Container from '@/components/Container.astro';
import todayIssue from '@/data/today-issue.json';
import { formatWon } from '@/data/site-data';

// 메인 NewsHero — 자동 큐레이션 today-issue.json 기반.
// 데이터 없으면 graceful empty (CTA 만 노출), 트렌딩 차트·하드코드 fallback 제거.
// CTA 1순위: 1위 토픽의 영구 포스트 (있으면 직진), 없으면 /issues/ 인덱스.
type HistoryEntry = { firstSeen: string; postSlug: string; totalCount: number };
type HistoryFile = { byTerm?: Record<string, HistoryEntry> };
const historyModules = import.meta.glob<{ default: HistoryFile }>(
  '/src/data/issues/_history.json',
  { eager: true },
);
const history: HistoryFile =
  Object.values(historyModules)[0]?.default ?? { byTerm: {} };

function findTopicPostUrl(term: string | undefined): string | null {
  if (!term) return null;
  const entry = history.byTerm?.[term];
  if (!entry?.postSlug || !entry?.firstSeen) return null;
  return `/issues/${entry.firstSeen}/${entry.postSlug}/`;
}

// Cycle #9: thinness 가드 완화 — 모든 트렌딩 키워드(totalCount ≥ 1) 에 토픽 hub 생성됨.
// /issues/ 폴백 제거하여 사이드바 dead text 방지 + 1:1 매핑 보장.
function findTopicHubUrl(term: string | undefined): string | null {
  if (!term) return null;
  const entry = history.byTerm?.[term];
  if (!entry || entry.totalCount < 1) return null;
  return `/issues/topics/${encodeURIComponent(term)}/`;
}

// Cycle #9 Step 1: 최근 영구 포스트 Top 3 — 홈페이지 가시성
type PostMeta = {
  title: string;
  slug: string;
  metaDescription?: string;
  category?: string;
  date?: string;
  publishedAt?: string;
  freshness?: { trendingTerm?: string; daysActive?: number };
  // Cycle #76: reportType별 UI 차별화
  reportType?: 'new-subsidies-weekly' | 'deadline-imminent-weekly' | 'persona-weekly' | 'category-weekly';
};
const postModules = import.meta.glob<{ default: PostMeta }>(
  '/src/data/issues/*/*.json',
  { eager: true },
);
const allPosts: Array<{ date: string; slug: string; data: PostMeta }> = [];
for (const [path, mod] of Object.entries(postModules)) {
  const m = path.match(/\/issues\/(\d{4}-\d{2}-\d{2})\/([^/]+)\.json$/);
  if (!m) continue;
  const date = m[1];
  const slug = m[2];
  if (!date || !slug || slug.startsWith('_')) continue;
  allPosts.push({ date, slug, data: mod.default });
}
allPosts.sort((a, b) => (a.date < b.date ? 1 : a.date > b.date ? -1 : 0));
const recentPosts = allPosts.slice(0, 3);
const totalPostCount = allPosts.length;

// 자동 큐레이션 데이터 — today-issue.json (단일 소스)
interface AutoTrendItem {
  term: string;
  count: number;
  mediaCount?: number;
  topArticle?: {
    title: string;
    link: string;
    pubDate?: string;
    pubDateKR?: string;
    category?: string;
  };
  // Cycle #66 고급화: 2-5위 키워드별 mini summary
  summary?: {
    headline?: string;
    subhead?: string;
    hookCopy?: string;
  };
  cities?: string[];
  publisherCount?: number;
  daysActive?: number;
  matchedCount?: number;
}
interface MatchedSubsidy {
  id: string;
  title: string;
  agency: string;
  category: string;
  icon: string;
  amount: number;
  amountLabel: string;
}
const auto = todayIssue as {
  syncedAt: string;
  headline: string;
  description: string;
  pubDate: string;
  pubDateKR: string;
  link: string;
  category: string;
  source?: string;
  trendingTopic?: string;
  trendingTopicCount?: number;
  trending?: AutoTrendItem[];
  summary?: {
    headline: string;
    subhead: string;
    hookCopy?: string;
    coreFacts?: Array<{ label: string; value: string; sub: string }>;
  };
  daysActive?: number;
  totalCount?: number;
  matchedSubsidies?: MatchedSubsidy[];
  // Cycle #40: 매체 다양성 표기 — sync-issues.mjs aggregate 필드
  aggregate?: {
    publisherCount?: number;
    publishers?: string[];
    cities?: string[];
    newestPubDate?: string | null;
  };
} | null;

// 트렌딩 사이드바 — 자동 데이터 우선 (N-gram 빈도 + 대표 기사)
// 클릭은 외부 기사로 (사이드바 = 빠른 트렌드 일별, 메인 운영과 분리)
const autoTrending: AutoTrendItem[] | null =
  auto?.trending && auto.trending.length > 0 ? auto.trending.slice(0, 5) : null;

// 하단 stat strip — 자동 데이터 있으면 트렌딩 관련 stat 4건 동적 생성
type StatTone = 'accent' | 'positive' | 'default' | 'warning';
interface PublicStat {
  label: string;
  value: string;
  tone: StatTone;
  sub: string;
}
const displayStats: readonly PublicStat[] = autoTrending
  ? [
      {
        label: '이번 주 1위',
        value: autoTrending[0]?.term ?? '-',
        tone: 'accent',
        sub: `${autoTrending[0]?.count ?? 0}건 보도`,
      },
      {
        label: '이번 주 2위',
        value: autoTrending[1]?.term ?? '-',
        tone: 'positive',
        sub: `${autoTrending[1]?.count ?? 0}건 보도`,
      },
      {
        label: '분야',
        value: auto?.category ?? '-',
        tone: 'default',
        sub: '대표 기사 카테고리',
      },
      {
        label: '발행일',
        value: auto?.pubDateKR ?? '-',
        tone: 'warning',
        sub: '대표 기사 기준',
      },
    ]
  : [];

// 표시 데이터 — summary 우선, 없으면 graceful empty
const displayHeadline = auto?.summary?.headline ?? auto?.headline ?? '오늘의 정부 지원금 이슈';
const displaySubhead =
  auto?.summary?.subhead ??
  auto?.description ??
  '매일 자동으로 갱신되는 지원금 이슈를 확인하세요.';
const displayCategory = auto?.category ?? '';
const externalLink = auto?.link;
const isAuto = !!auto;
const hasSummary = !!auto?.summary;
const matchedSubsidies = auto?.matchedSubsidies ?? [];
const daysActive = auto?.daysActive ?? 0;
const totalCount = auto?.totalCount ?? 0;

// 매체명 추출 (URL 도메인 → 사람 친화)
function extractSource(link: string | undefined): string {
  if (!link) return '뉴스 매체';
  try {
    const host = new URL(link).hostname.replace(/^www\./, '');
    const map: Record<string, string> = {
      'yna.co.kr': '연합뉴스', 'newsis.com': '뉴시스',
      'kbs.co.kr': 'KBS', 'imnews.imbc.com': 'MBC뉴스', 'sbs.co.kr': 'SBS', 'ytn.co.kr': 'YTN',
      'joongang.co.kr': '중앙일보', 'chosun.com': '조선일보', 'donga.com': '동아일보',
      'hani.co.kr': '한겨레', 'khan.co.kr': '경향신문',
      'hankyung.com': '한국경제', 'mk.co.kr': '매일경제', 'sedaily.com': '서울경제',
      'jtbc.co.kr': 'JTBC', 'mbn.co.kr': 'MBN',
      'mt.co.kr': '머니투데이', 'asiae.co.kr': '아시아경제', 'edaily.co.kr': '이데일리',
    };
    for (const [k, v] of Object.entries(map)) {
      if (host.endsWith(k)) return v;
    }
    return host;
  } catch {
    return '뉴스 매체';
  }
}

const sourceLabel = isAuto ? extractSource(externalLink) : '뉴스 매체';

// Cycle #40 (사용자 요청): 뉴스 크롤링 시각 표기 (사이트 신선도 신호)
function formatSyncedAt(iso: string): string {
  try {
    const d = new Date(iso);
    if (Number.isNaN(d.getTime())) return iso;
    // KST (UTC+9) 표기
    const kst = new Date(d.getTime() + 9 * 60 * 60 * 1000);
    const yyyy = kst.getUTCFullYear();
    const mm = String(kst.getUTCMonth() + 1).padStart(2, '0');
    const dd = String(kst.getUTCDate()).padStart(2, '0');
    const hh = String(kst.getUTCHours()).padStart(2, '0');
    const mi = String(kst.getUTCMinutes()).padStart(2, '0');
    return `${yyyy}.${mm}.${dd} ${hh}:${mi} KST`;
  } catch {
    return iso;
  }
}

// CTA — 1위 토픽 포스트 + /issues/ 인덱스 둘 다 노출 (시청자 선택권)
const topicPostUrl = isAuto ? findTopicPostUrl(auto?.trendingTopic) : null;

// 핵심 사실 4박스 + 훅 카피 (현재 hero에서는 사용 안 함, 데이터만 유지)
const coreFacts = auto?.summary?.coreFacts ?? [];
const hookCopy = auto?.summary?.hookCopy ?? null;
---

<section class="news-band">
  <Container size="wide">
    <div class="news-meta">
      <span class="news-pulse"><span class="dot" aria-hidden="true"></span>오늘의 이슈</span>
      {hasSummary && daysActive >= 3 && (
        <span class="news-trending-pill">
          <span class="dot-tr" aria-hidden="true" />
          {daysActive}일 연속 화제 · 누적 {totalCount}건 보도
        </span>
      )}
      {isAuto && displayCategory && (
        <span class="news-cat-pill">{displayCategory}</span>
      )}
    </div>

    <div class="news-grid">
      <div class="news-big-card">
        <div class="news-big-head">
          <h1 class="news-headline">{auto?.trendingTopic ?? displayHeadline}</h1>
          {/* Cycle #40 #6: 단일 매체 표기·관련 지원금·훅 카피 제거. 키워드 + 매체 다양성만 표시 */}
          {isAuto && (auto?.trendingTopicCount || (auto?.aggregate?.publisherCount ?? 0) > 0) && (
            <p class="news-subhead">
              {auto?.aggregate?.publisherCount && auto.aggregate.publisherCount > 0 && (
                <>매체 {auto.aggregate.publisherCount}곳 · </>
              )}
              {auto?.trendingTopicCount && (
                <>총 {auto.trendingTopicCount}건 보도</>
              )}
              {daysActive >= 2 && <> · {daysActive}일 연속</>}
            </p>
          )}
          {/* Cycle #40 #6: 매체명 직접 노출 — 통합 검색 다양성 신뢰성 */}
          {isAuto && auto?.aggregate?.publishers && auto.aggregate.publishers.length > 0 && (
            <p class="news-publishers">
              <span class="np-label">취재 매체</span>
              <span class="np-list">
                {auto.aggregate.publishers.slice(0, 6).join(' · ')}
                {auto.aggregate.publishers.length > 6 && ` 외 ${auto.aggregate.publishers.length - 6}곳`}
              </span>
            </p>
          )}
        </div>

        {matchedSubsidies.length > 0 && (
          <div class="news-matched">
            <div class="nm-label">
              <span class="nm-icon" aria-hidden="true">⚡</span>
              이 이슈와 관련해 지금 신청 가능한 지원금
            </div>
            <ul class="nm-list">
              {matchedSubsidies.slice(0, 3).map((m) => (
                <li>
                  <a class="nm-card" href={`/subsidies/${m.id}/`}>
                    <div class="nm-meta">
                      <span class={`nm-cat tint-${m.category}`}>{m.category}</span>
                      <span class="nm-agency">{m.agency}</span>
                    </div>
                    <div class="nm-title">{m.title}</div>
                    {m.amount > 0 && (
                      <div class="nm-amount">
                        {formatWon(m.amount)}
                        <span class="nm-unit">{m.amountLabel}</span>
                      </div>
                    )}
                    <span class="nm-arrow" aria-hidden="true">→</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        <div class="news-actions">
          {topicPostUrl ? (
            <>
              <a class="cta-primary" href={topicPostUrl}>이 이슈 자세히 보기 →</a>
              <a class="cta-ghost" href="/issues/">오늘의 이슈 모두 보기</a>
            </>
          ) : (
            <a class="cta-primary" href="/issues/">오늘의 이슈 모두 보기 →</a>
          )}
        </div>
      </div>

      {autoTrending && (
        <aside class="news-trend-card">
          <div class="news-trend-card-head">
            <div class="trend-eyebrow">트렌딩 키워드</div>
            <div class="trend-title">이번 주 가장 화제인 키워드</div>
          </div>

          <ol class="news-trend-list auto">
            {autoTrending.map((t, i) => {
              // Cycle #9: 사이트 이탈 차단 — 외부 뉴스 링크 X. 3단계 내부 링크만:
              //   1) 영구 포스트 (있으면 가장 풍부)
              //   2) 토픽 hub (totalCount ≥ 3)
              //   3) /issues/ 인덱스 폴백
              const postUrl = findTopicPostUrl(t.term);
              const hubUrl = findTopicHubUrl(t.term);
              const href = postUrl ?? hubUrl ?? '/issues/';
              const tier: 'post' | 'topic' | 'fallback' =
                postUrl ? 'post' : hubUrl ? 'topic' : 'fallback';
              const ctaLabel =
                tier === 'post' ? '포스트로 이동' :
                tier === 'topic' ? '관련 지원금 모아보기' :
                '오늘의 이슈로 이동';
              return (
                <li class:list={['news-trend-item-auto', i === 0 && 'hot']}>
                  <a href={href} class={`trend-link-auto tier-${tier}`}>
                    {/* Cycle #71: 매체 수를 main pill 주 신호로 격상 (count는 부수) — 신뢰도·다양성 우선 */}
                    <div class="trend-row-1">
                      <span class="rank">{i + 1}</span>
                      <span class="trend-pill">
                        <span class="trend-term">{t.term}</span>
                        {(t.mediaCount ?? 0) > 0 && (
                          <span class="trend-publishers" title={`정책성 필터 통과 ${t.mediaCount}곳 매체에서 보도`}>
                            📰 {t.mediaCount}곳
                          </span>
                        )}
                      </span>
                    </div>
                    <div class="trend-row-2">
                      <span class="trend-news-title">
                        {t.topArticle?.title ?? t.term}
                      </span>
                      <span class="trend-arrow" aria-hidden="true">→</span>
                    </div>
                    {/* Cycle #66 고급화 + Cycle #71 재배치: 보조 메타 — count는 raw 빈도, 부수 정보 */}
                    <div class="trend-row-mini">
                      <span class="trend-mini-pill" title="제목 등장 빈도 (raw)">
                        언급 {t.count}회
                      </span>
                      {t.cities && t.cities.length > 0 && (
                        <span class="trend-mini-pill">
                          🏙 {t.cities.slice(0, 2).join('·')}
                          {t.cities.length > 2 && ` 외 ${t.cities.length - 2}곳`}
                        </span>
                      )}
                      {t.matchedCount !== undefined && t.matchedCount > 0 && (
                        <span class="trend-mini-pill">⚡ 매칭 {t.matchedCount}건</span>
                      )}
                      {t.daysActive !== undefined && t.daysActive >= 2 && (
                        <span class="trend-mini-pill">{t.daysActive}일째</span>
                      )}
                    </div>
                    <div class="trend-row-3">
                      <span class="trend-cta">{ctaLabel}</span>
                    </div>
                  </a>
                </li>
              );
            })}
          </ol>

          <div class="news-trend-card-foot">
            클릭하면 사이트 내 관련 포스트·지원금으로 이동합니다
            {auto?.syncedAt && (
              <div class="news-trend-synced">
                <span class="dot-tr" aria-hidden="true" />
                뉴스 수집 시각 · <time datetime={auto.syncedAt}>{formatSyncedAt(auto.syncedAt)}</time>
              </div>
            )}
          </div>
        </aside>
      )}
    </div>

    <div class="news-stat-strip">
      {
        displayStats.map((s) => (
          <div class:list={['news-stat-cell', `tone-${s.tone}`]}>
            <div class="label">{s.label}</div>
            <div class="value">{s.value}</div>
            <div class="sub">{s.sub}</div>
          </div>
        ))
      }
    </div>

    {recentPosts.length > 0 && (
      <section class="recent-posts" aria-label="최근 영구 포스트">
        <div class="recent-posts-head">
          <h2 class="recent-posts-title">최근 분석 포스트 {totalPostCount}건</h2>
          <a class="recent-posts-all" href="/issues/all/">전체 보기 →</a>
        </div>
        <ul class="recent-posts-list">
          {recentPosts.map((p) => (
            <li>
              <a class={`rp-card cat-${p.data.category}`} href={`/issues/${p.date}/${p.slug}/`}>
                <div class="rp-meta">
                  {/* Cycle #76: reportType 배지 — 홈에서 분석 유형 즉시 인지 */}
                  {p.data.reportType && (() => {
                    const rtLabel = {
                      'new-subsidies-weekly': '🆕 신규',
                      'deadline-imminent-weekly': '⏰ 마감',
                      'persona-weekly': '👤 페르소나',
                      'category-weekly': '🗂 분야',
                    };
                    const label = rtLabel[p.data.reportType];
                    return label ? <span class={`rp-rt rt-${p.data.reportType}`}>{label}</span> : null;
                  })()}
                  <span class="rp-cat">{p.data.category}</span>
                  <span class="rp-date">{p.date}</span>
                  {p.data.freshness?.daysActive && p.data.freshness.daysActive >= 3 && (
                    <span class="rp-fresh">{p.data.freshness.daysActive}일 연속</span>
                  )}
                </div>
                <div class="rp-title">{p.data.title}</div>
                {p.data.metaDescription && <div class="rp-desc">{p.data.metaDescription}</div>}
                <span class="rp-arrow" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </Container>
</section>

<style>
  .news-band {
    padding: 56px 0 64px;
    border-bottom: 1px solid var(--border);
  }

  .news-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }

  .news-pulse {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 5px 12px;
    background: rgb(220 38 38 / 0.12);
    color: #c11216;
    border-radius: var(--radius-pill);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  :global([data-theme='dark']) .news-pulse {
    background: rgb(220 38 38 / 0.2);
    color: #fca5a5;
  }

  .news-pulse .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
  }

  .news-meta-text {
    font-size: 13px;
    color: var(--text-2);
  }

  .news-meta-dot {
    color: var(--text-3);
  }

  .news-cat-pill {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    background: rgb(0 113 227 / 0.1);
    color: var(--accent);
    border-radius: var(--radius-pill);
    font-size: 13px;
    font-weight: 600;
  }

  .news-trending-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 12px;
    background: rgb(0 113 227 / 0.12);
    color: var(--accent);
    border-radius: var(--radius-pill);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .dot-tr {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: tr-pulse 1.6s ease-in-out infinite;
    /* paint 영역 격리 — 무한 keyframe이 부모 reflow 무효화하지 않게 */
    contain: layout style paint;
  }

  @keyframes tr-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.3); }
  }

  @media (prefers-reduced-motion: reduce) { .dot-tr { animation: none; } }

  /* 핵심 사실 4박스 — 빠른 스캔 */
  .core-facts {
    list-style: none;
    margin: 22px 0 4px;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
  }
  @media (max-width: 640px) {
    .core-facts { grid-template-columns: repeat(2, 1fr); }
  }

  .core-fact {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 12px 14px;
    text-align: center;
    transition: border-color 0.18s var(--ease-standard), background 0.18s;
  }
  .core-fact:hover {
    background: var(--surface);
    border-color: var(--border-2);
  }

  .cf-label {
    font-size: 12px;
    color: var(--text-2);
    margin-bottom: 4px;
    letter-spacing: 0.02em;
  }

  .cf-value {
    font-size: clamp(20px, 2.4vw, 24px);
    font-weight: 700;
    color: var(--accent);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 2px;
  }

  .cf-sub {
