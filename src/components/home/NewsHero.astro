    color: var(--text-3);
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* 훅 카피 */
  .hook-copy {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin: 18px 0 0;
    padding: 14px 16px;
    background: rgb(0 113 227 / 0.06);
    border-left: 3px solid var(--accent);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }

  .hook-mark {
    color: var(--accent);
    font-size: 14px;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .hook-text {
    font-size: 14px;
    color: var(--text);
    line-height: 1.6;
    font-weight: 500;
  }

  /* 매칭 지원금 미니카드 */
  .matched-row {
    margin: 18px 0 4px;
  }

  .matched-label {
    font-size: 13px;
    font-weight: 700;
    color: var(--text-2);
    margin-bottom: 10px;
    letter-spacing: 0.02em;
  }

  .matched-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 8px;
  }

  .matched-card {
    display: block;
    padding: 12px 14px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--text);
    transition: transform 0.18s var(--ease-standard), border-color 0.18s, background 0.18s;
  }
  .matched-card:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
    background: var(--surface);
    text-decoration: none;
  }

  .m-cat {
    font-size: 11px;
    font-weight: 600;
    color: var(--accent-link);
    margin-bottom: 4px;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .m-title {
    font-size: 13px;
    font-weight: 600;
    line-height: 1.4;
    color: var(--text);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .cta-mini {
    display: inline-flex;
    align-items: center;
    margin-left: auto;
    padding: 8px 12px;
    color: var(--text-3);
    font-size: 12px;
    text-decoration: none;
  }
  .cta-mini:hover {
    color: var(--accent-link);
    text-decoration: underline;
  }

  .news-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 24px;
    margin-bottom: 32px;
  }

  @media (max-width: 880px) {
    .news-grid {
      grid-template-columns: 1fr;
    }
  }

  .news-big-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 36px;
    transition: border-color 0.18s var(--ease-standard), box-shadow 0.18s var(--ease-standard);
  }

  .news-big-card:hover {
    border-color: var(--border-2);
    box-shadow: var(--shadow-pop);
  }

  @media (max-width: 600px) {
    .news-big-card {
      padding: 24px;
    }
  }

  .news-headline {
    font-size: clamp(28px, 3.6vw, 44px);
    font-weight: 700;
    line-height: 1.18;
    letter-spacing: -0.02em;
    margin: 0 0 14px;
  }

  .news-subhead {
    font-size: 17px;
    color: var(--text-2);
    line-height: 1.55;
    margin: 0 0 12px;
  }
  /* Cycle #40 (사용자 요청 #7): 메인 hero = 신규 지원금 API 최신순 */
  .hero-subsidies {
    list-style: none;
    margin: 22px 0 24px;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 10px;
  }
  .hs-card {
    display: block;
    padding: 14px 16px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-left: 4px solid var(--cat-color, var(--accent));
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: transform 0.18s var(--ease-standard), border-color 0.18s, background 0.18s;
  }
  .hs-card:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
    background: var(--surface);
    text-decoration: none;
  }
  .hs-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 6px;
    font-size: 11px;
  }
  .hs-cat {
    padding: 2px 8px;
    background: var(--surface);
    color: var(--cat-color, var(--text-2));
    border-radius: var(--radius-pill);
    font-weight: 700;
  }
  .hs-agency {
    color: var(--accent-link);
    font-weight: 600;
  }
  .hs-title {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.4;
    color: var(--text);
    margin-bottom: 6px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .hs-amount {
    font-size: 14px;
    font-weight: 700;
    color: var(--accent);
  }

  /* Cycle #40 (사용자 요청): 취재 매체 목록 — (사이드바에서만 사용) */
  .news-publishers {
    display: flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
    margin: 0 0 24px;
    padding: 10px 14px;
    background: var(--surface-2);
    border-radius: var(--radius-sm);
    font-size: 13px;
  }
  .np-label {
    color: var(--text-3);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    flex-shrink: 0;
  }
  .np-list {
    color: var(--text-2);
    line-height: 1.6;
  }

  .news-big-number-row {
    padding: 20px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin-bottom: 24px;
  }

  .news-big-label {
    font-size: 13px;
    color: var(--text-2);
    margin-bottom: 6px;
  }

  .news-big-number {
    display: inline-flex;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }

  .prev-val {
    font-size: 24px;
    font-weight: 600;
    color: var(--text-3);
    text-decoration: line-through;
    text-decoration-thickness: 1.5px;
  }

  .arrow {
    font-size: 22px;
    color: var(--text-2);
  }

  .cur-val {
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 700;
    color: var(--accent);
    letter-spacing: -0.025em;
    line-height: 1;
  }

  .news-delta-pill {
    display: inline-block;
    padding: 4px 10px;
    background: rgb(0 169 110 / 0.16);
    color: var(--color-success);
    border-radius: var(--radius-pill);
    font-size: 13px;
    font-weight: 700;
  }

  /* Cycle #50: 트렌딩 1위 카드 → 매칭 지원금 인라인 (data만 있고 UI 미노출이었음) */
  .news-matched {
    margin: 20px 0 4px;
    padding: 14px 16px 16px;
    background: rgb(0 113 227 / 0.04);
    border: 1px solid rgb(0 113 227 / 0.14);
    border-radius: var(--radius-md);
  }
  :global([data-theme='dark']) .news-matched {
    background: rgb(41 151 255 / 0.06);
    border-color: rgb(41 151 255 / 0.18);
  }
  .nm-label {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 10px;
    letter-spacing: 0.01em;
  }
  .nm-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    background: var(--accent);
    color: var(--on-accent);
    border-radius: 50%;
    font-size: 11px;
  }
  .nm-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 8px;
  }
  .nm-card {
    position: relative;
    display: block;
    padding: 12px 14px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, transform 0.15s;
  }
  .nm-card:hover {
    border-color: var(--accent);
    transform: translateY(-1px);
    text-decoration: none;
  }
  .nm-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 6px;
    font-size: 11px;
  }
  .nm-cat {
    padding: 2px 7px;
    border-radius: var(--radius-pill);
    font-weight: 700;
  }
  .nm-cat.tint-주거 { background: rgb(0 113 227 / 0.12); color: var(--accent); }
  .nm-cat.tint-자산 { background: rgb(8 145 178 / 0.12); color: #0891b2; }
  .nm-cat.tint-교육 { background: rgb(139 92 246 / 0.12); color: #8b5cf6; }
  .nm-cat.tint-창업 { background: rgb(234 88 12 / 0.12); color: #ea580c; }
  .nm-cat.tint-복지 { background: rgb(236 72 153 / 0.12); color: #ec4899; }
  .nm-cat.tint-취업 { background: rgb(16 185 129 / 0.12); color: #10b981; }
  .nm-cat.tint-농업 { background: rgb(217 119 6 / 0.12); color: #d97706; }
  .nm-agency {
    color: var(--accent-link);
    font-weight: 600;
  }
  .nm-title {
    font-size: 13px;
    font-weight: 600;
    line-height: 1.4;
    margin-bottom: 4px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .nm-amount {
    font-size: 13px;
    font-weight: 700;
    color: var(--accent);
  }
  .nm-unit {
    font-size: 11px;
    color: var(--text-2);
    font-weight: 500;
    margin-left: 4px;
  }
  .nm-arrow {
    position: absolute;
    top: 12px;
    right: 14px;
    color: var(--text-3);
    font-size: 13px;
    transition: transform 0.15s, color 0.15s;
    opacity: 0;
  }
  .nm-card:hover .nm-arrow {
    opacity: 1;
    transform: translateX(2px);
    color: var(--accent);
  }

  .news-actions {
    display: flex;
    gap: 8px;
    margin-top: 20px;
    flex-wrap: wrap;
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 11px 20px;
    background: var(--accent);
    color: var(--on-accent);
    border-radius: var(--radius-pill);
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
  }

  .cta-primary:hover {
    text-decoration: none;
    background: color-mix(in oklch, var(--accent), black 8%);
  }

  .cta-ghost {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 20px;
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border-2);
    border-radius: var(--radius-pill);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
  }
  .cta-ghost:hover {
    text-decoration: none;
    background: var(--surface-2);
  }

  .news-trend-graph {
    margin-top: 8px;
  }

  .news-trend-axis {
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    color: var(--text-3);
    margin-top: 4px;
    padding: 0 4px;
  }

  .news-trend-label {
    font-size: 13px;
    color: var(--text-2);
    margin-top: 6px;
  }

  /* 실시간 인기 카드 — Cycle #10 P0-2: 다크모드 대응 */
  .news-trend-card {
    position: relative;
    background: linear-gradient(180deg, #0071e3 0%, #003875 100%);
    color: #f5f5f7;
    border-radius: var(--radius-xl);
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    overflow: hidden;
    isolation: isolate;
  }
  /* 다크모드: 채도 낮춘 navy로 — 밝은 파란색 강요 회피 */
  :global([data-theme='dark']) .news-trend-card {
    background: linear-gradient(180deg, #1a3a5c 0%, #0a1e33 100%);
    border: 1px solid rgb(255 255 255 / 0.08);
  }
  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme='light'])) .news-trend-card {
      background: linear-gradient(180deg, #1a3a5c 0%, #0a1e33 100%);
      border: 1px solid rgb(255 255 255 / 0.08);
    }
  }

  .news-trend-card::before {
    content: '';
    position: absolute;
    top: -40px;
    right: -40px;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgb(255 255 255 / 0.16) 0%, transparent 65%);
    pointer-events: none;
    z-index: -1;
  }

  .trend-eyebrow {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgb(255 255 255 / 0.65);
  }

  .trend-title {
    font-size: 19px;
    font-weight: 700;
    letter-spacing: -0.015em;
    margin-top: 4px;
  }

  .news-trend-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
  }

  .news-trend-item {
    border-radius: var(--radius-sm);
  }

  .trend-link,
  .news-trend-item > .rank {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    color: inherit;
    text-decoration: none;
  }

  .trend-link:hover {
    background: rgb(255 255 255 / 0.06);
    text-decoration: none;
  }

  .rank {
    width: 30px;
    height: 30px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgb(255 255 255 / 0.16);
    border-radius: 50%;
    font-size: 14px;
    font-weight: 700;
    color: #ffffff;
    flex-shrink: 0;
  }

  .news-trend-item.hot .rank {
    background: rgb(255 255 255 / 0.95);
    color: #003875;
    animation: trend-rank1-pulse 1.8s ease-in-out infinite;
    /* box-shadow 펄스 paint 격리 → 부모 카드 reflow 비용 0 */
    contain: layout style paint;
  }

  @keyframes trend-rank1-pulse {
    0%, 100% {
      box-shadow: 0 0 0 0 rgb(255 255 255 / 0.55);
    }
    50% {
      box-shadow: 0 0 0 8px rgb(255 255 255 / 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .news-trend-item.hot .rank {
      animation: none;
    }
  }

  .title {
    flex: 1;
    font-size: 16px;
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .delta {
    display: inline-flex;
    align-items: center;
    padding: 5px 12px;
    background: rgb(255 255 255 / 0.12);
    border-radius: var(--radius-pill);
    font-size: 13px;
    color: #ff9caa;
    font-weight: 600;
    flex-shrink: 0;
  }

  .news-trend-card-foot {
    font-size: 12px;
    color: rgb(255 255 255 / 0.5);
    border-top: 1px solid rgb(255 255 255 / 0.08);
    padding-top: 12px;
    margin-top: 4px;
  }
  /* Cycle #40 (사용자 요청): 뉴스 크롤링 시각 표기 */
  .news-trend-synced {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 8px;
    font-size: 11px;
    color: rgb(255 255 255 / 0.65);
    font-variant-numeric: tabular-nums;
  }
  .news-trend-synced .dot-tr {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #6affd0;
  }

  /* ─── 자동 모드 트렌딩 사이드바 (옵션 B: 알약 위 + 제목 아래) ─── */
  .news-trend-list.auto {
    gap: 6px;
  }

  .news-trend-item-auto {
    border-radius: var(--radius-md);
    transition: background 0.15s var(--ease-standard);
  }

  .trend-link-auto {
    display: block;
    padding: 10px 12px;
    color: inherit;
    text-decoration: none;
    border-radius: var(--radius-md);
  }

  .trend-link-auto:hover {
    background: rgb(255 255 255 / 0.08);
    text-decoration: none;
  }

  .news-trend-item-auto.hot .trend-link-auto {
    background: rgb(255 255 255 / 0.06);
  }

  .trend-row-1 {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
  }

  .trend-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 3px 10px;
    background: rgb(255 255 255 / 0.16);
    border-radius: var(--radius-pill);
    font-size: 12px;
    flex: 1;
    min-width: 0;
  }

  .news-trend-item-auto.hot .trend-pill {
    background: rgb(255 255 255 / 0.95);
    color: #003875;
  }

  .trend-term {
    font-weight: 700;
    color: inherit;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .trend-count {
    color: #ff9caa;
    font-weight: 600;
    flex-shrink: 0;
    margin-left: auto;
    font-size: 11px;
  }

  .news-trend-item-auto.hot .trend-count {
    color: #d62c1a;
  }

  /* Cycle #71: trend-pill 안의 매체 수 — 주 신호 (다양성 우선) */
  .trend-publishers {
    color: #6affd0;
    font-weight: 700;
    flex-shrink: 0;
    margin-left: auto;
    font-size: 11px;
    letter-spacing: 0.02em;
  }
  .news-trend-item-auto.hot .trend-publishers {
    color: #003875;
    background: rgb(0 56 117 / 0.12);
    padding: 1px 7px;
    border-radius: var(--radius-pill);
  }

  .trend-row-2 {
    display: flex;
    align-items: flex-start;
    gap: 8px;
  }

  .trend-news-title {
    flex: 1;
    font-size: 13px;
    color: rgb(255 255 255 / 0.92);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .trend-arrow {
    color: rgb(255 255 255 / 0.55);
    font-size: 14px;
    flex-shrink: 0;
    transition: transform 0.18s var(--ease-standard);
  }

  .trend-link-auto:hover .trend-arrow {
    transform: translateX(3px);
    color: #ffffff;
  }

  /* Cycle #66 고급화: 키워드별 mini summary pill 행 */
  .trend-row-mini {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: 6px;
  }
  .trend-mini-pill {
    display: inline-flex;
    align-items: center;
    padding: 2px 8px;
    background: rgb(255 255 255 / 0.1);
    color: rgb(255 255 255 / 0.85);
    border-radius: var(--radius-pill);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.01em;
  }
  .news-trend-item-auto.hot .trend-mini-pill {
    background: rgb(0 56 117 / 0.18);
    color: rgb(0 56 117 / 0.92);
  }

  /* 클릭 destination 명시 chip — 사용자 신뢰성 (Cycle #9) */
  .trend-row-3 {
    margin-top: 6px;
  }
  .trend-cta {
    display: inline-flex;
    align-items: center;
    padding: 2px 10px;
    background: rgb(255 255 255 / 0.16);
    color: rgb(255 255 255 / 0.92);
    border-radius: var(--radius-pill);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .trend-link-auto.tier-post .trend-cta {
    background: rgb(255 255 255 / 0.95);
    color: #003875;
  }
  .news-trend-item-auto.hot .trend-cta {
    background: rgb(255 255 255 / 0.92);
    color: #003875;
  }

  /* Stat strip */
  .news-stat-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }

  @media (max-width: 720px) {
    .news-stat-strip {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .news-stat-cell {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 16px 18px;
    transition: transform 0.18s var(--ease-standard), border-color 0.18s var(--ease-standard);
  }

  .news-stat-cell:hover {
    transform: translateY(-2px);
    border-color: var(--border-2);
