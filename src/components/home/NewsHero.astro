---
import Container from '@/components/Container.astro';
import todayIssue from '@/data/today-issue.json';

// 메인 NewsHero — 자동 큐레이션 today-issue.json 기반.
// 데이터 없으면 graceful empty (CTA 만 노출), 트렌딩 차트·하드코드 fallback 제거.
// CTA 1순위: 1위 토픽의 영구 포스트 (있으면 직진), 없으면 /issues/ 인덱스.
type HistoryEntry = { firstSeen: string; postSlug: string };
type HistoryFile = { byTerm?: Record<string, HistoryEntry> };
const historyModules = import.meta.glob<{ default: HistoryFile }>(
  '/src/data/issues/_history.json',
  { eager: true },
);
const history: HistoryFile =
  Object.values(historyModules)[0]?.default ?? { byTerm: {} };

function findTopicPostUrl(term: string | undefined): string | null {
  if (!term) return null;
  const entry = history.byTerm?.[term];
  if (!entry?.postSlug || !entry?.firstSeen) return null;
  return `/issues/${entry.firstSeen}/${entry.postSlug}/`;
}

// 자동 큐레이션 데이터 — today-issue.json (단일 소스)
interface AutoTrendItem {
  term: string;
  count: number;
  topArticle?: {
    title: string;
    link: string;
    pubDate?: string;
    pubDateKR?: string;
    category?: string;
  };
}
interface MatchedSubsidy {
  id: string;
  title: string;
  agency: string;
  category: string;
  icon: string;
  amount: number;
  amountLabel: string;
}
const auto = todayIssue as {
  syncedAt: string;
  headline: string;
  description: string;
  pubDate: string;
  pubDateKR: string;
  link: string;
  category: string;
  source?: string;
  trendingTopic?: string;
  trendingTopicCount?: number;
  trending?: AutoTrendItem[];
  summary?: {
    headline: string;
    subhead: string;
    hookCopy?: string;
    coreFacts?: Array<{ label: string; value: string; sub: string }>;
  };
  daysActive?: number;
  totalCount?: number;
  matchedSubsidies?: MatchedSubsidy[];
} | null;

// 트렌딩 사이드바 — 자동 데이터 우선 (N-gram 빈도 + 대표 기사)
// 클릭은 외부 기사로 (사이드바 = 빠른 트렌드 일별, 메인 운영과 분리)
const autoTrending: AutoTrendItem[] | null =
  auto?.trending && auto.trending.length > 0 ? auto.trending.slice(0, 5) : null;

// 하단 stat strip — 자동 데이터 있으면 트렌딩 관련 stat 4건 동적 생성
type StatTone = 'accent' | 'positive' | 'default' | 'warning';
interface PublicStat {
  label: string;
  value: string;
  tone: StatTone;
  sub: string;
}
const displayStats: readonly PublicStat[] = autoTrending
  ? [
      {
        label: '이번 주 1위',
        value: autoTrending[0]?.term ?? '-',
        tone: 'accent',
        sub: `${autoTrending[0]?.count ?? 0}건 보도`,
      },
      {
        label: '이번 주 2위',
        value: autoTrending[1]?.term ?? '-',
        tone: 'positive',
        sub: `${autoTrending[1]?.count ?? 0}건 보도`,
      },
      {
        label: '분야',
        value: auto?.category ?? '-',
        tone: 'default',
        sub: '대표 기사 카테고리',
      },
      {
        label: '발행일',
        value: auto?.pubDateKR ?? '-',
        tone: 'warning',
        sub: '대표 기사 기준',
      },
    ]
  : [];

// 표시 데이터 — summary 우선, 없으면 graceful empty
const displayHeadline = auto?.summary?.headline ?? auto?.headline ?? '오늘의 정부 지원금 이슈';
const displaySubhead =
  auto?.summary?.subhead ??
  auto?.description ??
  '매일 자동으로 갱신되는 지원금 이슈를 확인하세요.';
const displayCategory = auto?.category ?? '';
const externalLink = auto?.link;
const isAuto = !!auto;
const hasSummary = !!auto?.summary;
const matchedSubsidies = auto?.matchedSubsidies ?? [];
const daysActive = auto?.daysActive ?? 0;
const totalCount = auto?.totalCount ?? 0;

// 매체명 추출 (URL 도메인 → 사람 친화)
function extractSource(link: string | undefined): string {
  if (!link) return '뉴스 매체';
  try {
    const host = new URL(link).hostname.replace(/^www\./, '');
    const map: Record<string, string> = {
      'yna.co.kr': '연합뉴스', 'newsis.com': '뉴시스',
      'kbs.co.kr': 'KBS', 'imnews.imbc.com': 'MBC뉴스', 'sbs.co.kr': 'SBS', 'ytn.co.kr': 'YTN',
      'joongang.co.kr': '중앙일보', 'chosun.com': '조선일보', 'donga.com': '동아일보',
      'hani.co.kr': '한겨레', 'khan.co.kr': '경향신문',
      'hankyung.com': '한국경제', 'mk.co.kr': '매일경제', 'sedaily.com': '서울경제',
      'jtbc.co.kr': 'JTBC', 'mbn.co.kr': 'MBN',
      'mt.co.kr': '머니투데이', 'asiae.co.kr': '아시아경제', 'edaily.co.kr': '이데일리',
    };
    for (const [k, v] of Object.entries(map)) {
      if (host.endsWith(k)) return v;
    }
    return host;
  } catch {
    return '뉴스 매체';
  }
}

const sourceLabel = isAuto ? extractSource(externalLink) : '뉴스 매체';

// CTA — 1위 토픽 포스트 + /issues/ 인덱스 둘 다 노출 (시청자 선택권)
const topicPostUrl = isAuto ? findTopicPostUrl(auto?.trendingTopic) : null;

// 핵심 사실 4박스 + 훅 카피
const coreFacts = auto?.summary?.coreFacts ?? [];
const hookCopy = auto?.summary?.hookCopy ?? null;
---

<section class="news-band">
  <Container size="wide">
    <div class="news-meta">
      <span class="news-pulse"><span class="dot" aria-hidden="true"></span>오늘의 이슈</span>
      {hasSummary && daysActive >= 3 && (
        <span class="news-trending-pill">
          <span class="dot-tr" aria-hidden="true" />
          {daysActive}일 연속 화제 · 누적 {totalCount}건 보도
        </span>
      )}
      {isAuto && displayCategory && (
        <span class="news-cat-pill">{displayCategory}</span>
      )}
    </div>

    <div class="news-grid">
      <div class="news-big-card">
        <div class="news-big-head">
          <h1 class="news-headline">{displayHeadline}</h1>
          <p class="news-subhead">{displaySubhead}</p>
        </div>

        {coreFacts.length > 0 && (
          <ul class="core-facts">
            {coreFacts.map((f) => (
              <li class="core-fact">
                <div class="cf-label">{f.label}</div>
                <div class="cf-value">{f.value}</div>
                {f.sub && <div class="cf-sub">{f.sub}</div>}
              </li>
            ))}
          </ul>
        )}

        {hookCopy && (
          <div class="hook-copy">
            <span class="hook-mark" aria-hidden="true">★</span>
            <span class="hook-text">{hookCopy}</span>
          </div>
        )}

        {matchedSubsidies.length > 0 && (
          <div class="matched-row">
            <div class="matched-label">관련 지원금 {matchedSubsidies.length}건</div>
            <ul class="matched-list">
              {matchedSubsidies.map((s) => (
                <li>
                  <a class={`matched-card tint-${s.category}`} href={`/subsidies/${s.id}/`}>
                    <div class="m-cat">{s.category} · {s.agency}</div>
                    <div class="m-title">{s.title}</div>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        <div class="news-actions">
          {topicPostUrl ? (
            <>
              <a class="cta-primary" href={topicPostUrl}>이 이슈 자세히 보기 →</a>
              <a class="cta-ghost" href="/issues/">오늘의 이슈 모두 보기</a>
            </>
          ) : (
            <a class="cta-primary" href="/issues/">오늘의 이슈 모두 보기 →</a>
          )}
          <a class="cta-ghost" href="/quick/">5분 진단 →</a>
          {isAuto && externalLink && (
            <a class="cta-mini" href={externalLink} target="_blank" rel="noopener noreferrer">
              원문: {sourceLabel}
            </a>
          )}
        </div>

      </div>

      {autoTrending && (
        <aside class="news-trend-card">
          <div class="news-trend-card-head">
            <div class="trend-eyebrow">트렌딩 키워드</div>
            <div class="trend-title">이번 주 가장 화제인 키워드</div>
          </div>

          <ol class="news-trend-list auto">
            {autoTrending.map((t, i) => {
              const href = t.topArticle?.link ?? '#';
              return (
                <li class:list={['news-trend-item-auto', i === 0 && 'hot']}>
                  <a href={href} class="trend-link-auto" target="_blank" rel="noopener noreferrer">
                    <div class="trend-row-1">
                      <span class="rank">{i + 1}</span>
                      <span class="trend-pill">
                        <span class="trend-term">{t.term}</span>
                        <span class="trend-count">{t.count}건</span>
                      </span>
                    </div>
                    <div class="trend-row-2">
                      <span class="trend-news-title">{t.topArticle?.title ?? t.term}</span>
                      {t.topArticle?.link && <span class="trend-arrow" aria-hidden="true">→</span>}
                    </div>
                  </a>
                </li>
              );
            })}
          </ol>

          <div class="news-trend-card-foot">
            클릭하면 관련 지원금까지 함께 확인할 수 있습니다
          </div>
        </aside>
      )}
    </div>

    <div class="news-stat-strip">
      {
        displayStats.map((s) => (
          <div class:list={['news-stat-cell', `tone-${s.tone}`]}>
            <div class="label">{s.label}</div>
            <div class="value">{s.value}</div>
            <div class="sub">{s.sub}</div>
          </div>
        ))
      }
    </div>
  </Container>
</section>

<style>
  .news-band {
    padding: 56px 0 64px;
    border-bottom: 1px solid var(--border);
  }

  .news-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }

  .news-pulse {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 5px 12px;
    background: rgb(220 38 38 / 0.12);
    color: #c11216;
    border-radius: var(--radius-pill);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  :global([data-theme='dark']) .news-pulse {
    background: rgb(220 38 38 / 0.2);
    color: #fca5a5;
  }

  .news-pulse .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
  }

  .news-meta-text {
    font-size: 13px;
    color: var(--text-2);
  }

  .news-meta-dot {
    color: var(--text-3);
  }

  .news-cat-pill {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    background: rgb(0 113 227 / 0.1);
    color: var(--accent);
    border-radius: var(--radius-pill);
    font-size: 13px;
    font-weight: 600;
  }

  .news-trending-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 12px;
    background: rgb(0 113 227 / 0.12);
    color: var(--accent);
    border-radius: var(--radius-pill);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .dot-tr {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: tr-pulse 1.6s ease-in-out infinite;
  }

  @keyframes tr-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.3); }
  }

  @media (prefers-reduced-motion: reduce) { .dot-tr { animation: none; } }

  /* 핵심 사실 4박스 — 빠른 스캔 */
  .core-facts {
    list-style: none;
    margin: 22px 0 4px;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
  }
  @media (max-width: 640px) {
    .core-facts { grid-template-columns: repeat(2, 1fr); }
  }

  .core-fact {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 12px 14px;
    text-align: center;
    transition: border-color 0.18s var(--ease-standard), background 0.18s;
  }
  .core-fact:hover {
    background: var(--surface);
    border-color: var(--border-2);
  }

  .cf-label {
    font-size: 12px;
    color: var(--text-2);
    margin-bottom: 4px;
    letter-spacing: 0.02em;
  }

  .cf-value {
    font-size: clamp(20px, 2.4vw, 24px);
    font-weight: 700;
    color: var(--accent);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 2px;
  }

  .cf-sub {
    font-size: 12px;
    color: var(--text-3);
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* 훅 카피 */
  .hook-copy {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin: 18px 0 0;
    padding: 14px 16px;
    background: rgb(0 113 227 / 0.06);
    border-left: 3px solid var(--accent);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }

  .hook-mark {
    color: var(--accent);
    font-size: 14px;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .hook-text {
    font-size: 14px;
    color: var(--text);
    line-height: 1.6;
    font-weight: 500;
  }

  /* 매칭 지원금 미니카드 */
  .matched-row {
    margin: 18px 0 4px;
  }

  .matched-label {
    font-size: 13px;
    font-weight: 700;
    color: var(--text-2);
    margin-bottom: 10px;
    letter-spacing: 0.02em;
  }

  .matched-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 8px;
  }

  .matched-card {
    display: block;
    padding: 12px 14px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--text);
    transition: transform 0.18s var(--ease-standard), border-color 0.18s, background 0.18s;
  }
  .matched-card:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
    background: var(--surface);
    text-decoration: none;
  }

  .m-cat {
    font-size: 11px;
    font-weight: 600;
    color: var(--accent-link);
    margin-bottom: 4px;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .m-title {
    font-size: 13px;
    font-weight: 600;
    line-height: 1.4;
    color: var(--text);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .cta-mini {
    display: inline-flex;
    align-items: center;
    margin-left: auto;
    padding: 8px 12px;
    color: var(--text-3);
    font-size: 12px;
    text-decoration: none;
  }
  .cta-mini:hover {
    color: var(--accent-link);
    text-decoration: underline;
  }

  .news-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 24px;
    margin-bottom: 32px;
  }

  @media (max-width: 880px) {
    .news-grid {
      grid-template-columns: 1fr;
    }
  }

  .news-big-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 36px;
    transition: border-color 0.18s var(--ease-standard), box-shadow 0.18s var(--ease-standard);
  }

  .news-big-card:hover {
    border-color: var(--border-2);
    box-shadow: var(--shadow-pop);
  }

  @media (max-width: 600px) {
    .news-big-card {
      padding: 24px;
    }
  }

  .news-headline {
    font-size: clamp(28px, 3.6vw, 44px);
    font-weight: 700;
    line-height: 1.18;
    letter-spacing: -0.02em;
    margin: 0 0 14px;
  }

  .news-subhead {
    font-size: 17px;
    color: var(--text-2);
    line-height: 1.55;
    margin: 0 0 24px;
  }

  .news-big-number-row {
    padding: 20px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin-bottom: 24px;
  }

  .news-big-label {
    font-size: 13px;
    color: var(--text-2);
    margin-bottom: 6px;
  }

  .news-big-number {
    display: inline-flex;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }

  .prev-val {
    font-size: 24px;
    font-weight: 600;
    color: var(--text-3);
    text-decoration: line-through;
    text-decoration-thickness: 1.5px;
  }

  .arrow {
    font-size: 22px;
    color: var(--text-2);
  }

  .cur-val {
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 700;
    color: var(--accent);
    letter-spacing: -0.025em;
    line-height: 1;
  }

  .news-delta-pill {
    display: inline-block;
    padding: 4px 10px;
    background: rgb(0 169 110 / 0.16);
    color: var(--color-success);
    border-radius: var(--radius-pill);
    font-size: 13px;
    font-weight: 700;
  }

  .news-actions {
    display: flex;
    gap: 8px;
    margin-top: 20px;
    flex-wrap: wrap;
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 11px 20px;
    background: var(--accent);
    color: var(--on-accent);
    border-radius: var(--radius-pill);
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
  }

  .cta-primary:hover {
    text-decoration: none;
    background: color-mix(in oklch, var(--accent), black 8%);
  }

  .cta-ghost {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 20px;
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border-2);
    border-radius: var(--radius-pill);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
  }
  .cta-ghost:hover {
    text-decoration: none;
    background: var(--surface-2);
  }

  .news-trend-graph {
    margin-top: 8px;
  }

  .news-trend-axis {
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    color: var(--text-3);
    margin-top: 4px;
    padding: 0 4px;
  }

  .news-trend-label {
    font-size: 13px;
    color: var(--text-2);
    margin-top: 6px;
  }

  /* 실시간 인기 카드 */
  .news-trend-card {
    position: relative;
    background: linear-gradient(180deg, #0071e3 0%, #003875 100%);
    color: #f5f5f7;
    border-radius: var(--radius-xl);
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    overflow: hidden;
    isolation: isolate;
  }

  .news-trend-card::before {
    content: '';
    position: absolute;
    top: -40px;
    right: -40px;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgb(255 255 255 / 0.16) 0%, transparent 65%);
    pointer-events: none;
    z-index: -1;
  }

  .trend-eyebrow {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgb(255 255 255 / 0.65);
  }

  .trend-title {
    font-size: 19px;
    font-weight: 700;
    letter-spacing: -0.015em;
    margin-top: 4px;
  }

  .news-trend-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
  }

  .news-trend-item {
    border-radius: var(--radius-sm);
  }

  .trend-link,
  .news-trend-item > .rank {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    color: inherit;
    text-decoration: none;
  }

  .trend-link:hover {
    background: rgb(255 255 255 / 0.06);
    text-decoration: none;
  }

  .rank {
    width: 30px;
    height: 30px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgb(255 255 255 / 0.16);
    border-radius: 50%;
    font-size: 14px;
    font-weight: 700;
    color: #ffffff;
    flex-shrink: 0;
  }

  .news-trend-item.hot .rank {
    background: rgb(255 255 255 / 0.95);
    color: #003875;
