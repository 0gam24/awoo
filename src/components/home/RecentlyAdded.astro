---
import Container from '@/components/Container.astro';
import Icon from '@/components/Icon.astro';
import { getCollection } from 'astro:content';
import { lastBatchSlugs, lastBatchAtISO, formatDateKR, recentlyAddedSlugs } from '@/lib/subsidies-meta';

const subsidies = await getCollection('subsidies');
const bySlug = new Map(subsidies.map((s) => [s.data.id, s.data]));

// 1순위: 마지막 동기화 회차에서 추가된 항목 (lastBatch)
// 2순위: lastBatch 비어있으면 등록일 desc 상위 6건
let mode: 'batch' | 'recent' = 'batch';
let items = lastBatchSlugs.map((slug) => bySlug.get(slug)).filter(Boolean);
if (items.length === 0) {
  mode = 'recent';
  items = recentlyAddedSlugs(6).map(({ slug }) => bySlug.get(slug)).filter(Boolean);
}

const limited = items.slice(0, 6);
const dateLabel = formatDateKR(lastBatchAtISO);
---

{
  limited.length > 0 && (
    <section class="band">
      <Container size="wide">
        <div class="head">
          <div class="head-meta">
            <span class="badge"><span class="dot" aria-hidden="true" />이번 주 신규</span>
            {mode === 'batch' && dateLabel && (
              <span class="meta">최근 동기화 {dateLabel} · +{limited.length}건</span>
            )}
            {mode === 'recent' && <span class="meta">최근 등록 {limited.length}건</span>}
          </div>
          <a class="more" href="/subsidies/new/">전체보기 →</a>
        </div>

        <ul class="grid">
          {limited.map((s) => (
            <li>
              <a class={`tile tint-${s.category}`} href={`/subsidies/${s.id}/`}>
                <div class="tile-icon">
                  <Icon name={s.icon} size={22} strokeWidth={1.7} />
                </div>
                <div class="tile-body">
                  <div class="tile-cat">{s.category}</div>
                  <div class="tile-title">{s.title}</div>
                  <div class="tile-agency">{s.agency}</div>
                </div>
                <span class="tile-arrow" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ul>
      </Container>
    </section>
  )
}

<style>
  .band {
    padding: 32px 0 16px;
  }

  .head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 18px;
  }

  .head-meta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    background: rgb(0 113 227 / 0.12);
    color: var(--accent);
    border-radius: var(--radius-pill);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse-dot 1.6s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.55; transform: scale(1.3); }
  }

  @media (prefers-reduced-motion: reduce) {
    .dot { animation: none; }
  }

  .meta {
    font-size: 13px;
    color: var(--text-2);
  }

  .more {
    font-size: 14px;
    color: var(--accent-link);
    text-decoration: none;
    font-weight: 500;
  }
  .more:hover {
    text-decoration: underline;
  }

  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 12px;
  }

  .tile {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--text);
    transition: transform 0.18s var(--ease-standard), border-color 0.18s var(--ease-standard);
  }
  .tile:hover {
    transform: translateY(-2px);
    border-color: var(--border-2);
    text-decoration: none;
  }

  .tile-icon {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .tint-주거 .tile-icon { background: rgb(0 113 227 / 0.12); color: var(--accent); }
  .tint-자산 .tile-icon { background: rgb(8 145 178 / 0.12); color: #0891b2; }
  .tint-교육 .tile-icon { background: rgb(139 92 246 / 0.12); color: #8b5cf6; }
  .tint-창업 .tile-icon { background: rgb(234 88 12 / 0.12); color: #ea580c; }
  .tint-복지 .tile-icon { background: rgb(236 72 153 / 0.12); color: #ec4899; }
  .tint-취업 .tile-icon { background: rgb(16 185 129 / 0.12); color: #10b981; }
  .tint-농업 .tile-icon { background: rgb(217 119 6 / 0.12); color: #d97706; }

  .tile-body {
    flex: 1;
    min-width: 0;
  }

  .tile-cat {
    font-size: 12px;
    color: var(--text-3);
    margin-bottom: 2px;
  }

  .tile-title {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .tile-agency {
    font-size: 12px;
    color: var(--accent-link);
    font-weight: 500;
    margin-top: 4px;
  }

  .tile-arrow {
    color: var(--text-3);
    font-weight: 600;
    flex-shrink: 0;
    transition: transform 0.18s var(--ease-standard), color 0.18s var(--ease-standard);
  }
  .tile:hover .tile-arrow {
    transform: translateX(3px);
    color: var(--accent);
  }
</style>
