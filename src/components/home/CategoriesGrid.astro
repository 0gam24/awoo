---
import Container from '@/components/Container.astro';
import Icon from '@/components/Icon.astro';
import { CATEGORIES } from '@/data/site-data';
---

<section class="band">
  <Container size="wide">
    <div class="head-row">
      <h2 class="display">분야별로 둘러보기</h2>
      <a class="link-arrow" href="/subsidies/">전체보기 →</a>
    </div>
    <div class="cat-grid">
      {
        CATEGORIES.slice(1).map((c) => (
          <a class="cat-tile" href={`/subsidies/?category=${encodeURIComponent(c.id)}`}>
            <div class={`cat-glyph tint-${c.id}`}>
              <Icon name={c.icon} size={28} strokeWidth={1.6} />
            </div>
            <div class="cat-name">{c.name}</div>
            <div class="cat-count">{c.count}개</div>
          </a>
        ))
      }
    </div>
  </Container>
</section>

<style>
  .band {
    padding: 56px 0 80px;
  }

  .head-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 24px;
    flex-wrap: wrap;
    gap: 12px;
  }

  .display {
    font-size: clamp(22px, 2.6vw, 30px);
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.015em;
    margin: 0;
  }

  .link-arrow {
    font-size: 14px;
    font-weight: 500;
    color: var(--accent-link);
    text-decoration: none;
  }

  .link-arrow:hover {
    text-decoration: underline;
  }

  .cat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 12px;
  }

  .cat-tile {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
    padding: 24px 20px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--text);
    transition: transform 0.18s var(--ease-standard), border-color 0.18s var(--ease-standard);
  }

  .cat-tile:hover {
    transform: translateY(-2px);
    border-color: var(--border-2);
    text-decoration: none;
  }

  .cat-glyph {
    width: 48px;
    height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--surface-2);
    border-radius: var(--radius-md);
    color: var(--accent);
  }

  .tint-주거 {
    background: rgb(0 113 227 / 0.12);
    color: var(--accent);
  }
  .tint-취업 {
    background: rgb(16 185 129 / 0.12);
    color: #10b981;
  }
  .tint-창업 {
    background: rgb(234 88 12 / 0.12);
    color: #ea580c;
  }
  .tint-교육 {
    background: rgb(139 92 246 / 0.12);
    color: #8b5cf6;
  }
  .tint-자산 {
    background: rgb(8 145 178 / 0.12);
    color: #0891b2;
  }
  .tint-복지 {
    background: rgb(236 72 153 / 0.12);
    color: #ec4899;
  }

  .cat-name {
    font-size: 15px;
    font-weight: 600;
    line-height: 1.35;
  }

  .cat-count {
    font-size: 13px;
    color: var(--text-2);
    font-weight: 500;
  }
</style>
