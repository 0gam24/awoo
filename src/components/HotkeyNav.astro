---
// 키보드 단축키 + 도움말 모달.
// - g h / g s / g i / g q / g g — go-to 패턴
// - / — focus 첫 검색·필터 입력
// - ? — 도움말 토글
// - input·textarea·contenteditable 안에서는 비활성
// - 모바일에는 도움말 버튼만 보이게 (단축키 안내 X)
---

<div class="hk-help" id="hk-help" hidden>
  <div class="hk-overlay" data-hk-overlay></div>
  <div class="hk-panel" role="dialog" aria-labelledby="hk-title" aria-modal="true">
    <header class="hk-head">
      <h2 id="hk-title">키보드 단축키</h2>
      <button type="button" class="hk-close" data-hk-close aria-label="닫기">×</button>
    </header>
    <dl class="hk-list">
      <dt><kbd>g</kbd> <kbd>h</kbd></dt><dd>홈으로</dd>
      <dt><kbd>g</kbd> <kbd>i</kbd></dt><dd>오늘의 이슈</dd>
      <dt><kbd>g</kbd> <kbd>s</kbd></dt><dd>전체 지원금</dd>
      <dt><kbd>g</kbd> <kbd>p</kbd></dt><dd>페르소나</dd>
      <dt><kbd>g</kbd> <kbd>q</kbd></dt><dd>5분 진단</dd>
      <dt><kbd>g</kbd> <kbd>g</kbd></dt><dd>가이드</dd>
      <dt><kbd>?</kbd></dt><dd>이 도움말 토글</dd>
      <dt><kbd>Esc</kbd></dt><dd>도움말 닫기</dd>
    </dl>
    <p class="hk-note">단축키는 입력 필드 안에서는 작동하지 않습니다.</p>
  </div>
</div>

<script>
  // 입력 필드 내부면 단축키 무시
  function isEditable(el: EventTarget | null): boolean {
    if (!(el instanceof HTMLElement)) return false;
    const tag = el.tagName;
    if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return true;
    if (el.isContentEditable) return true;
    return false;
  }

  const help = document.getElementById('hk-help');
  if (!help) {
    /* noop */
  } else {
    const overlay = help.querySelector('[data-hk-overlay]');
    const close = help.querySelector('[data-hk-close]');
    function show() { help!.hidden = false; }
    function hide() { help!.hidden = true; }
    overlay?.addEventListener('click', hide);
    close?.addEventListener('click', hide);

    let lastG = 0;

    document.addEventListener('keydown', (e) => {
      if (e.metaKey || e.ctrlKey || e.altKey) return;
      if (isEditable(e.target)) return;

      const k = e.key;

      // ? 도움말 토글
      if (k === '?') {
        e.preventDefault();
        if (help.hidden) show();
        else hide();
        return;
      }

      // Esc — 도움말 닫기
      if (k === 'Escape' && !help.hidden) {
        e.preventDefault();
        hide();
        return;
      }

      // / — 첫 가시적 input·검색 필드 포커스
      if (k === '/') {
        const input = document.querySelector<HTMLInputElement>(
          'input[type="search"], input[name="persona"], [data-quick-app] input',
        );
        if (input) {
          e.preventDefault();
          input.focus();
        }
        return;
      }

      // g 시퀀스
      if (k === 'g') {
        lastG = Date.now();
        return;
      }

      const goWithin = Date.now() - lastG < 1500;
      if (!goWithin) return;
      lastG = 0;

      const route: Record<string, string> = {
        h: '/',
        i: '/issues/',
        s: '/subsidies/',
        p: '/personas/',
        q: '/quick/',
        g: '/guide/',
      };
      const dest = route[k.toLowerCase()];
      if (dest) {
        e.preventDefault();
        window.location.href = dest;
      }
    });
  }
</script>

<style>
  .hk-help[hidden] { display: none; }

  .hk-help {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }

  .hk-overlay {
    position: absolute;
    inset: 0;
    background: rgb(0 0 0 / 0.45);
    backdrop-filter: blur(4px);
  }

  .hk-panel {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 24px 28px;
    max-width: 420px;
    width: 100%;
    box-shadow: 0 24px 48px rgb(0 0 0 / 0.18);
  }

  .hk-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .hk-head h2 {
    font-size: 17px;
    font-weight: 700;
    margin: 0;
  }

  .hk-close {
    background: none;
    border: none;
    color: var(--text-2);
    font-size: 24px;
    cursor: pointer;
    padding: 4px 10px;
    border-radius: var(--radius-sm);
    line-height: 1;
  }

  .hk-close:hover {
    background: var(--surface-2);
    color: var(--text);
  }

  .hk-list {
    margin: 0;
    display: grid;
    grid-template-columns: 100px 1fr;
    row-gap: 8px;
    column-gap: 16px;
  }

  .hk-list dt {
    font-size: 13px;
    display: flex;
    gap: 4px;
  }

  .hk-list dd {
    margin: 0;
    font-size: 14px;
    color: var(--text-2);
  }

  kbd {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 22px;
    height: 22px;
    padding: 0 5px;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 11px;
    font-weight: 600;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text);
  }

  .hk-note {
    margin: 16px 0 0;
    font-size: 12px;
    color: var(--text-3);
    line-height: 1.5;
  }
</style>
