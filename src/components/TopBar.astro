---
interface NavItem {
  href: string;
  label: string;
}

interface Props {
  active?: string;
}

const { active = '' } = Astro.props;

const items: NavItem[] = [
  { href: '/', label: '홈' },
  { href: '/issues/', label: '오늘의 이슈' },
  { href: '/subsidies/', label: '지원금' },
  { href: '/guide/', label: '가이드' },
];

const isActive = (href: string) => {
  if (href === '/') {
    // 홈은 정확히 / 또는 명시적 'home' active 시에만
    return active === 'home' || active === '/' || Astro.url.pathname === '/';
  }
  // 명시 active 우선
  if (active === href) return true;
  // 경로 기반: /issues/ 와 /issues/[date]/[slug]/ 등 모두 매칭
  return Astro.url.pathname.startsWith(href);
};
---

<header class="topbar">
  <div class="topbar-inner">
    <a href="/" class="brand" aria-label="지원금가이드 홈">
      <span class="brand-mark" aria-hidden="true">지</span>
      <span class="brand-name">지원금가이드</span>
    </a>

    <nav class="nav-links" aria-label="주 메뉴">
      {
        items.map((it) => (
          <a
            href={it.href}
            class:list={['nav-link', isActive(it.href) && 'nav-active']}
            aria-current={isActive(it.href) ? 'page' : undefined}
          >
            {it.label}
          </a>
        ))
      }
    </nav>

    <div class="actions">
      {/* Cycle #52: 5분 진단 진입점 — 사이트 어디서든 1-click 매칭 도달 */}
      <a
        href="/quick/"
        class:list={['quick-cta', isActive('/quick/') && 'quick-cta-active']}
        aria-label="5분 진단으로 지원금 매칭"
        aria-current={isActive('/quick/') ? 'page' : undefined}
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M13 2L3 14h7l-1 8 11-12h-7l1-8z"></path>
        </svg>
        <span>5분 진단</span>
      </a>

      <button
        type="button"
        class="theme-toggle nav-link"
        id="theme-toggle"
        aria-label="테마 전환"
      >
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M2 12h2M20 12h2M5 5l1.5 1.5M17.5 17.5L19 19M5 19l1.5-1.5M17.5 6.5L19 5"></path>
        </svg>
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
        </svg>
      </button>

      <button
        type="button"
        class="menu-toggle nav-link"
        id="menu-toggle"
        aria-label="메뉴 열기"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <nav class="mobile-nav" id="mobile-nav" hidden aria-label="모바일 메뉴">
    {/* Cycle #52: 모바일 메뉴 상단에 5분 진단 강조 항목 */}
    <a
      href="/quick/"
      class:list={['mobile-nav-link mobile-quick-cta', isActive('/quick/') && 'mobile-nav-active']}
      aria-current={isActive('/quick/') ? 'page' : undefined}
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M13 2L3 14h7l-1 8 11-12h-7l1-8z"></path>
      </svg>
      5분 진단으로 매칭
    </a>
    {
      items.map((it) => (
        <a
          href={it.href}
          class:list={['mobile-nav-link', isActive(it.href) && 'mobile-nav-active']}
          aria-current={isActive(it.href) ? 'page' : undefined}
        >
          {it.label}
        </a>
      ))
    }
  </nav>
</header>

<script>
  const root = document.documentElement;
  const themeBtn = document.getElementById('theme-toggle');
  const menuBtn = document.getElementById('menu-toggle');
  const mobileNav = document.getElementById('mobile-nav');

  // Theme toggle
  const updateThemeIcon = () => {
    const theme = root.getAttribute('data-theme');
    const effective = theme || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    document.body.dataset.themeEffective = effective;
  };

  themeBtn?.addEventListener('click', () => {
    const current = root.getAttribute('data-theme');
    const effective = current || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    const next = effective === 'dark' ? 'light' : 'dark';
    root.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    updateThemeIcon();
  });

  // Mobile menu toggle
  menuBtn?.addEventListener('click', () => {
    if (!mobileNav) return;
    const isOpen = !mobileNav.hidden;
    mobileNav.hidden = isOpen;
    menuBtn.setAttribute('aria-expanded', String(!isOpen));
    menuBtn.setAttribute('aria-label', isOpen ? '메뉴 열기' : '메뉴 닫기');
  });

  updateThemeIcon();
</script>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklch, var(--bg), transparent 12%);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border-bottom: 1px solid var(--border);
  }

  .topbar-inner {
    max-width: 1200px;
    margin-inline: auto;
    padding: 12px 24px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
    font-size: 17px;
  }
  .brand:hover {
    text-decoration: none;
  }

  .brand-mark {
    width: 28px;
    height: 28px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--accent);
    color: var(--on-accent);
    border-radius: 8px;
    font-size: 16px;
    font-weight: 700;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-inline-start: auto;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    border-radius: var(--radius-pill);
    font-size: 14px;
    font-weight: 500;
    color: var(--text-2);
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    transition:
      background 0.15s var(--ease-standard),
      color 0.15s var(--ease-standard);
  }

  .nav-link:hover {
    color: var(--text);
    background: var(--surface-2);
    text-decoration: none;
  }

  .nav-active {
    color: var(--text);
    font-weight: 600;
  }

  .actions {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  /* Cycle #52: 5분 진단 진입점 — accent-tinted 강조 버튼 */
  .quick-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    background: rgb(0 113 227 / 0.1);
    color: var(--accent);
    border-radius: var(--radius-pill);
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
    margin-right: 4px;
    transition: background 0.15s, transform 0.15s;
  }
  :global([data-theme='dark']) .quick-cta {
    background: rgb(41 151 255 / 0.16);
  }
  .quick-cta:hover {
    text-decoration: none;
    background: rgb(0 113 227 / 0.18);
    transform: translateY(-1px);
  }
  :global([data-theme='dark']) .quick-cta:hover {
    background: rgb(41 151 255 / 0.24);
  }
  .quick-cta-active {
    background: var(--accent);
    color: var(--on-accent);
  }
  .quick-cta-active:hover {
    background: var(--accent);
  }

  /* 모바일에서 5분 진단을 nav 영역에서 hide (모바일 메뉴 상단으로 이동) */
  @media (max-width: 720px) {
    .quick-cta {
      display: none;
    }
  }

  /* 모바일 메뉴 상단 강조 5분 진단 항목 */
  .mobile-quick-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgb(0 113 227 / 0.1);
    color: var(--accent);
    font-weight: 700;
    margin-bottom: 8px;
  }
  :global([data-theme='dark']) .mobile-quick-cta {
    background: rgb(41 151 255 / 0.16);
  }
  .mobile-quick-cta:hover {
    background: rgb(0 113 227 / 0.18);
  }

  .theme-toggle {
    padding: 8px;
  }

  /* Theme icon swap — light shows moon (to switch to dark), dark shows sun */
  .icon-moon {
    display: inline;
  }
  .icon-sun {
    display: none;
  }
  :global([data-theme='dark']) .icon-moon,
  :global(body[data-theme-effective='dark']) .icon-moon {
    display: none;
  }
  :global([data-theme='dark']) .icon-sun,
  :global(body[data-theme-effective='dark']) .icon-sun {
    display: inline;
  }

  /* Mobile */
  .menu-toggle {
    display: none;
    padding: 8px;
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    padding: 12px 24px 16px;
    border-top: 1px solid var(--border);
    gap: 4px;
  }

  .mobile-nav-link {
    padding: 10px 14px;
    font-size: 16px;
    color: var(--text);
    border-radius: var(--radius-md);
    text-decoration: none;
  }

  .mobile-nav-link:hover {
    background: var(--surface-2);
    text-decoration: none;
  }

  .mobile-nav-active {
    background: var(--surface-2);
    font-weight: 600;
  }

  @media (max-width: 720px) {
    .nav-links {
      display: none;
    }
    .menu-toggle {
      display: inline-flex;
    }
  }

  @media (min-width: 721px) {
    .mobile-nav {
      display: none !important;
    }
  }
</style>
