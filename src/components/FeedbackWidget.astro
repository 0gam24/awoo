---
/**
 * "이 페이지가 도움이 되셨나요?" 위젯.
 * 클릭 시 옆에 숫자 카운트만 표시 (Cycle #7 — 전송 실패 메시지 제거).
 * API 호출은 백그라운드 — 성공/실패 무관, 사용자 UX는 카운트만.
 */
---

<section class="feedback-widget" aria-labelledby="fb-title">
  <h2 id="fb-title" class="fb-title">이 페이지가 도움이 되셨나요?</h2>
  <p class="fb-sub">의견을 남겨주시면 콘텐츠 개선에 반영합니다.</p>

  <div class="fb-buttons" id="fb-buttons">
    <button type="button" class="fb-btn" data-helpful="1" id="fb-yes">
      <span aria-hidden="true">👍</span>
      <span class="fb-label">도움됐어요</span>
      <span class="fb-count" data-count="0" aria-live="polite"></span>
    </button>
    <button type="button" class="fb-btn" data-helpful="0" id="fb-no">
      <span aria-hidden="true">👎</span>
      <span class="fb-label">아쉬워요</span>
      <span class="fb-count" data-count="0" aria-live="polite"></span>
    </button>
  </div>
</section>

<script>
  const widget = document.querySelector<HTMLElement>('.feedback-widget');
  if (widget) {
    const path = location.pathname;
    const buttons = widget.querySelectorAll<HTMLButtonElement>('.fb-btn');

    // 페이지별 카운트 (localStorage 누적)
    function loadCount(helpful: string): number {
      try {
        const key = `fb-count-${path}-${helpful}`;
        const v = Number(localStorage.getItem(key) ?? '0');
        return Number.isFinite(v) ? v : 0;
      } catch {
        return 0;
      }
    }
    function saveCount(helpful: string, n: number): void {
      try {
        localStorage.setItem(`fb-count-${path}-${helpful}`, String(n));
      } catch {
        /* localStorage 비활성 — 무시 */
      }
    }
    function renderCount(btn: HTMLButtonElement, n: number): void {
      const slot = btn.querySelector<HTMLElement>('.fb-count');
      if (!slot) return;
      slot.textContent = n > 0 ? `(${n})` : '';
      slot.dataset.count = String(n);
    }

    // 초기 렌더 — 페이지 진입 시 누적 카운트 표시
    buttons.forEach((btn) => {
      const helpful = btn.dataset.helpful ?? '0';
      renderCount(btn, loadCount(helpful));
    });

    // 백그라운드 전송 — 결과 무시 (사용자 UX는 카운트만)
    function sendBackground(helpful: boolean, comment?: string): void {
      try {
        fetch('/api/feedback', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ page_path: path, helpful, comment }),
          keepalive: true,
        }).catch(() => {});
      } catch {
        /* 무시 */
      }
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const helpful = btn.dataset.helpful ?? '0';
        const next = loadCount(helpful) + 1;
        saveCount(helpful, next);
        renderCount(btn, next);
        sendBackground(helpful === '1');
      });
    });
  }
</script>

<style>
  .feedback-widget {
    margin: 64px 0 32px;
    padding: 28px;
    background: var(--surface-2);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .fb-title {
    font-size: 17px;
    font-weight: 600;
    margin: 0 0 6px;
  }

  .fb-sub {
    font-size: 13px;
    color: var(--text-2);
    margin: 0 0 16px;
  }

  .fb-buttons {
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .fb-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    color: var(--text);
    min-height: 36px;
    transition: border-color 0.15s var(--ease-standard), transform 0.15s var(--ease-standard);
  }
  .fb-btn:hover {
    border-color: var(--border-2);
  }
  .fb-btn:active {
    transform: scale(0.97);
  }

  .fb-count {
    font-size: 13px;
    color: var(--accent);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    min-width: 0;
  }
  .fb-count:empty {
    display: none;
  }
</style>
