---
/**
 * "이 페이지가 도움이 되셨나요?" 위젯.
 * 양/부 선택 → /api/feedback POST → 감사 메시지.
 * 코멘트 입력은 부정 응답 시에만 노출 (UX 향상).
 */
---

<section class="feedback-widget" aria-labelledby="fb-title">
  <h2 id="fb-title" class="fb-title">이 페이지가 도움이 되셨나요?</h2>
  <p class="fb-sub">의견을 남겨주시면 콘텐츠 개선에 반영합니다.</p>

  <div class="fb-buttons" id="fb-buttons">
    <button type="button" class="fb-btn" data-helpful="1" id="fb-yes">
      <span aria-hidden="true">👍</span>
      <span>도움됐어요</span>
    </button>
    <button type="button" class="fb-btn" data-helpful="0" id="fb-no">
      <span aria-hidden="true">👎</span>
      <span>아쉬워요</span>
    </button>
  </div>

  <form class="fb-form" id="fb-form" hidden>
    <label class="sr-only" for="fb-comment">개선 의견</label>
    <textarea
      id="fb-comment"
      name="comment"
      rows="3"
      maxlength="2000"
      placeholder="어떤 부분이 부족했나요? 구체적인 개선 제안이 있으면 알려주세요."
    ></textarea>
    {/* honeypot — 봇 차단 */}
    <input type="text" name="_hp" tabindex="-1" autocomplete="off" class="fb-hp" aria-hidden="true" />
    <div class="fb-actions">
      <button type="submit" class="fb-submit">전송</button>
      <button type="button" id="fb-skip" class="fb-skip">건너뛰기</button>
    </div>
  </form>

  <p class="fb-thanks" id="fb-thanks" hidden role="status">의견 감사합니다.</p>
  <p class="fb-error" id="fb-error" hidden role="alert">전송 실패. 잠시 후 다시 시도해주세요.</p>
</section>

<script>
  const widget = document.querySelector<HTMLElement>('.feedback-widget');
  if (widget) {
    const buttons = widget.querySelector<HTMLElement>('#fb-buttons');
    const form = widget.querySelector<HTMLFormElement>('#fb-form');
    const comment = widget.querySelector<HTMLTextAreaElement>('#fb-comment');
    const thanks = widget.querySelector<HTMLElement>('#fb-thanks');
    const error = widget.querySelector<HTMLElement>('#fb-error');
    const skipBtn = widget.querySelector<HTMLButtonElement>('#fb-skip');
    const hp = widget.querySelector<HTMLInputElement>('input[name="_hp"]');

    let helpful: boolean | null = null;

    interface Payload {
      page_path: string;
      helpful: boolean;
      comment?: string | undefined;
      _hp?: string | undefined;
    }

    const send = async (payload: Payload): Promise<void> => {
      try {
        const res = await fetch('/api/feedback', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        if (buttons) buttons.hidden = true;
        if (form) form.hidden = true;
        if (thanks) thanks.hidden = false;
      } catch {
        if (error) error.hidden = false;
      }
    };

    widget.querySelectorAll<HTMLButtonElement>('.fb-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        helpful = btn.dataset.helpful === '1';
        if (helpful) {
          // 양수 응답: 코멘트 단계 건너뛰고 즉시 전송
          send({ page_path: location.pathname, helpful: true });
        } else {
          // 부수 응답: 코멘트 폼 노출
          if (buttons) buttons.hidden = true;
          if (form) form.hidden = false;
          comment?.focus();
        }
      });
    });

    skipBtn?.addEventListener('click', () => {
      send({ page_path: location.pathname, helpful: helpful ?? false });
    });

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      send({
        page_path: location.pathname,
        helpful: helpful ?? false,
        comment: comment?.value.trim() || undefined,
        _hp: hp?.value,
      });
    });
  }
</script>

<style>
  .feedback-widget {
    margin: 64px 0 32px;
    padding: 28px;
    background: var(--surface-2);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .fb-title {
    font-size: 17px;
    font-weight: 600;
    margin: 0 0 6px;
  }

  .fb-sub {
    font-size: 13px;
    color: var(--text-2);
    margin: 0 0 16px;
  }

  .fb-buttons {
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .fb-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    color: var(--text);
    min-height: 36px;
    transition: border-color 0.15s var(--ease-standard), transform 0.15s var(--ease-standard);
  }
  .fb-btn:hover {
    border-color: var(--border-2);
  }
  .fb-btn:active {
    transform: scale(0.97);
  }

  .fb-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-width: 480px;
    margin: 0 auto;
    text-align: left;
  }

  .fb-form textarea {
    width: 100%;
    padding: 12px 14px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    font-family: inherit;
    font-size: 14px;
    color: var(--text);
    resize: vertical;
    min-height: 80px;
  }

  .fb-form textarea:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 1px;
    border-color: var(--accent);
  }

  .fb-actions {
    display: flex;
    gap: 8px;
    justify-content: flex-end;
  }

  .fb-submit {
    padding: 8px 18px;
    background: var(--accent);
    color: var(--on-accent);
    border: 0;
    border-radius: var(--radius-pill);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    min-height: 36px;
  }
  .fb-submit:hover {
    background: color-mix(in oklch, var(--accent), black 8%);
  }

  .fb-skip {
    padding: 8px 18px;
    background: transparent;
    color: var(--text-2);
    border: 0;
    cursor: pointer;
    font-size: 13px;
    min-height: 36px;
  }
  .fb-skip:hover {
    color: var(--text);
  }

  .fb-thanks {
    margin: 0;
    color: var(--color-success);
    font-weight: 600;
    font-size: 14px;
  }

  .fb-error {
    margin: 0;
    color: var(--color-danger);
    font-weight: 600;
    font-size: 14px;
  }

  .fb-hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
