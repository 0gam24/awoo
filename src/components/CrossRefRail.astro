---
// 4축 cross-reference rail — 페르소나↔상황↔토픽↔용어↔카테고리 hub 진입점.
// detail 페이지(personas/[id], situations/[id], topics/[id], glossary/[id])에 공통 적용.
//
// 사용:
//   <CrossRefRail
//     persona={p.data.id}
//     situations={['marriage', 'childbirth']}
//     topics={['youth-housing']}
//     glossary={['median-income']}
//   />

interface Item {
  href: string;
  label: string;
  sub?: string;
}

interface Props {
  /** "이 페이지를 본 사람이 함께 보는 다른 hub" 안내 */
  title?: string;
  items: Item[];
}

const { title = '함께 보면 좋은 다른 관점', items } = Astro.props;

if (items.length === 0) {
  // 비어있으면 렌더 X
}
---

{items.length > 0 && (
  <nav class="cross-ref-rail" aria-label={title}>
    <div class="crr-eyebrow">{title}</div>
    <ul class="crr-list">
      {items.map((item) => (
        <li>
          <a class="crr-card" href={item.href}>
            <div class="crr-body">
              <div class="crr-label">{item.label}</div>
              {item.sub && <div class="crr-sub">{item.sub}</div>}
            </div>
            <span class="crr-arrow" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  .cross-ref-rail {
    margin-top: 40px;
    padding: 24px 28px;
    background: var(--bg-alt);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .crr-eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .crr-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 8px;
  }

  .crr-card {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, transform 0.15s;
  }

  .crr-card:hover {
    border-color: var(--border-2);
    transform: translateY(-1px);
    text-decoration: none;
  }

  .crr-body {
    flex: 1;
    min-width: 0;
  }

  .crr-label {
    font-size: 14px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 2px;
  }

  .crr-sub {
    font-size: 12px;
    color: var(--text-2);
    line-height: 1.4;
  }

  .crr-arrow {
    color: var(--text-3);
    font-size: 16px;
    flex-shrink: 0;
    transition: transform 0.15s, color 0.15s;
  }

  .crr-card:hover .crr-arrow {
    transform: translateX(3px);
    color: var(--accent);
  }
</style>
