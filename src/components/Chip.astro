---
interface Props {
  variant?: 'default' | 'active';
  size?: 'sm' | 'md';
  href?: string;
  class?: string;
}

const { variant = 'default', size = 'md', href, class: className = '' } = Astro.props;
const classes = ['chip', `chip-${size}`, variant === 'active' && 'chip-active', className];
---

{
  href ? (
    <a class:list={classes} href={href}>
      <slot />
    </a>
  ) : (
    <span class:list={classes}>
      <slot />
    </span>
  )
}

<style>
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-weight: 500;
    border-radius: var(--radius-pill);
    background: var(--surface-2);
    color: var(--text);
    border: 1px solid transparent;
    transition: all 0.15s var(--ease-standard);
    white-space: nowrap;
    word-break: keep-all;
    flex-shrink: 0;
    text-decoration: none;
  }

  .chip-md {
    font-size: 14px;
    padding: 7px 14px;
  }

  .chip-sm {
    font-size: 13px;
    padding: 5px 10px;
  }

  .chip:hover {
    border-color: var(--border-2);
    text-decoration: none;
  }

  .chip-active {
    background: var(--color-ink);
    color: #fff;
  }

  :global([data-theme='dark']) .chip-active {
    background: #f5f5f7;
    color: #000;
  }
</style>
