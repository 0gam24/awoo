---
import '@/styles/global.css';
import Footer from '@/components/Footer.astro';
import HotkeyNav from '@/components/HotkeyNav.astro';
import TopBar from '@/components/TopBar.astro';
import { buildBreadcrumb, buildOrganization, buildWebSite, type BreadcrumbItem } from '@/lib/schema';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  /** 활성 nav 키: 'home' | '/subsidies' | '/guide' 등 */
  activeNav?: string;
  /** 페이지별 breadcrumb — 명시 시 BreadcrumbList JSON-LD 자동 출력 */
  breadcrumbs?: BreadcrumbItem[];
}

const {
  title,
  description,
  canonical,
  ogImage = '/og-default.png',
  noindex = false,
  activeNav = '',
  breadcrumbs,
} = Astro.props;

// breadcrumbSchema에 @id 부여 (canonical URL + #breadcrumb) — entity 그래프 강화 (Cycle #4 P0-5)
const canonicalPath = canonical ?? Astro.url.pathname;
const breadcrumbSchema = breadcrumbs && breadcrumbs.length > 1 ? buildBreadcrumb(breadcrumbs, canonicalPath) : null;

// 사이트와이드 entity — 모든 페이지에 1회 노출 (Organization + WebSite, @id 앵커로 다른 schema에서 참조)
const orgSchema = buildOrganization();
const siteSchema = buildWebSite();

const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImageURL = new URL(ogImage, Astro.site).toString();
const siteName = '지원금가이드';
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" type="image/png" href="/favicon.svg" />

    {/* RSS 피드 — 신규 지원금 + 이슈 포스트 별도 채널 */}
    <link rel="alternate" type="application/rss+xml" title="신규 정부 지원금" href="/feed.xml" />
    <link rel="alternate" type="application/rss+xml" title="오늘의 이슈 포스트" href="/feed-issues.xml" />

    {/* 검색엔진 사이트 인증 — 등록 시 docs/ops/SEARCH-CONSOLE.md / NAVER-SEARCH-ADVISOR.md 참조
        DNS TXT 권장 (이중 인증 시 메타 태그도 함께)
        Google: <meta name="google-site-verification" content="..." />
        Naver:  <meta name="naver-site-verification" content="..." />  */}

    {/* Pretendard 폰트는 preload 안 함 — Pretendard Adjusted(size-adjust) fallback이
        먼저 그려지고 woff2 로드 후 CLS 없이 swap. preload하면 모바일 LCP가
        font 다운로드를 기다리느라 지연됨 (300KB / Slow 4G = ~1.5s 페널티). */}

    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {!noindex && (
      <Fragment>
        {/* Discover·검색 결과에서 큰 이미지 미리보기 허용 (썸네일 → 와이드 카드) */}
        <meta name="robots" content="max-image-preview:large, max-snippet:-1" />
        <meta name="googlebot" content="max-image-preview:large, max-snippet:-1" />
      </Fragment>
    )}

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content="ko_KR" />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <meta name="theme-color" content="#0071e3" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#000000" media="(prefers-color-scheme: dark)" />

    {/* 다크모드 깜빡임 방지 — 첫 페인트 전 테마 결정 */}
    <script is:inline>
      (() => {
        const saved = localStorage.getItem('theme');
        if (saved === 'dark' || saved === 'light') {
          document.documentElement.setAttribute('data-theme', saved);
        }
      })();
    </script>
    <meta name="naver-site-verification" content="8203ca7628a4c7bc8b90fb2086b0086ec3c62ac9" />

    {/* 사이트와이드 entity — 모든 페이지 1회. AI 인용·지식 그래프·sitelinks 신호. */}
    <script is:inline type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(siteSchema)} />

    {breadcrumbSchema && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    )}
  </head>
  <body>
    <a href="#main" class="skip-link">본문으로 건너뛰기</a>
    <TopBar active={activeNav} />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <HotkeyNav />

    {/* Web Vitals beacon — idle 시점에 import (TBT 측정창 안에 들어가지 않게) */}
    <script>
      const _initVitals = () => import('@/lib/vitals').then((m) => m.initVitals()).catch(() => {});
      if ('requestIdleCallback' in window) {
        (window as Window).requestIdleCallback(_initVitals, { timeout: 3000 });
      } else {
        setTimeout(_initVitals, 2500);
      }
    </script>
  </body>
</html>
