{
  "ci": {
    "collect": {
      "staticDistDir": "./dist/client",
      "url": [
        "http://localhost/index.html",
        "http://localhost/about/index.html",
        "http://localhost/quick/index.html",
        "http://localhost/issues/index.html",
        "http://localhost/subsidies/index.html",
        "http://localhost/personas/index.html",
        "http://localhost/issues/all/index.html"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "throttlingMethod": "simulate",
        "chromeFlags": "--headless=new --no-sandbox --disable-dev-shm-usage"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 1.0 }],
        "categories:accessibility": ["error", { "minScore": 1.0 }],
        "categories:best-practices": ["error", { "minScore": 1.0 }],
        "categories:seo": ["error", { "minScore": 1.0 }],
        "largest-contentful-paint": ["error", { "maxNumericValue": 2500 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "total-blocking-time": ["error", { "maxNumericValue": 200 }],
        "interactive": ["warn", { "maxNumericValue": 3000 }],
        "max-potential-fid": ["warn", { "maxNumericValue": 150 }],
        "interaction-to-next-paint": ["warn", { "maxNumericValue": 150 }],
        "speed-index": ["warn", { "maxNumericValue": 2500 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
