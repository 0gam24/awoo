{
  "name": "awoo",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "지원금가이드 — 정부 지원금 안내 사이트 (운영: 스마트데이터샵)",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "npm run build && wrangler dev",
    "astro": "astro",
    "check": "astro check && tsc --noEmit",
    "lint:content": "node scripts/lint-content.mjs",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome check --write .",
    "lhci": "lhci autorun",
    "lhci:mobile": "lhci autorun --collect.settings.preset=mobile",
    "verify": "npm run lint && npm run lint:content && npm run check && npm run build && npm run lhci",
    "generate-types": "wrangler types",
    "deploy": "npm run build && wrangler deploy",
    "sync:subsidies": "node scripts/sync-subsidies.mjs",
    "sync:subsidies:new": "node scripts/sync-subsidies.mjs new",
    "sync:subsidies:bootstrap": "node scripts/sync-subsidies.mjs bootstrap",
    "sync:issues": "node scripts/sync-issues.mjs",
    "generate:issues": "node scripts/generate-issue-posts.mjs",
    "sweep:stale": "node scripts/sweep-stale.mjs",
    "sweep:stale:apply": "node scripts/sweep-stale.mjs --apply",
    "tag:personas": "node scripts/tag-personas.mjs",
    "tag:personas:apply": "node scripts/tag-personas.mjs --apply",
    "check:apply-urls": "node scripts/check-apply-urls.mjs",
    "check:apply-urls:all": "node scripts/check-apply-urls.mjs --all",
    "indexnow:ping": "node scripts/indexnow-ping.mjs"
  },
  "dependencies": {
    "@astrojs/cloudflare": "13.2.2",
    "@astrojs/react": "5.0.4",
    "@astrojs/sitemap": "3.7.2",
    "@tailwindcss/vite": "4.2.4",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "astro": "6.1.10",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwindcss": "4.2.4",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@biomejs/biome": "2.4.13",
    "@lhci/cli": "0.15.1",
    "lefthook": "2.1.6",
    "typescript": "5.9.3",
    "web-vitals": "5.2.0",
    "wrangler": "4.86.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "overrides": {
    "vite": "^7"
  }
}
