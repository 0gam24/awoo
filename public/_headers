# Cloudflare Pages — HTTP Security Headers (§14)
/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=()
  Cross-Origin-Opener-Policy: same-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests
  X-XSS-Protection: 1; mode=block

# 정적 자산 — 1년 immutable 캐시
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# HTML — 엣지 캐시 + stale-while-revalidate
/*.html
  Cache-Control: public, max-age=0, s-maxage=86400, stale-while-revalidate=604800

# Cycle #34: SEO 핵심 파일 캐시 — sitemap·llms·feed (1시간 엣지 캐시 + SWR)
/sitemap-index.xml
  Cache-Control: public, max-age=3600, s-maxage=3600, stale-while-revalidate=86400
/sitemap-0.xml
  Cache-Control: public, max-age=3600, s-maxage=3600, stale-while-revalidate=86400
/sitemap-news.xml
  Cache-Control: public, max-age=600, s-maxage=600, stale-while-revalidate=3600
/llms.txt
  Cache-Control: public, max-age=3600, s-maxage=3600, stale-while-revalidate=86400
/llms-full.txt
  Cache-Control: public, max-age=3600, s-maxage=3600, stale-while-revalidate=86400
/feed.xml
  Cache-Control: public, max-age=600, s-maxage=600, stale-while-revalidate=3600
/feed-issues.xml
  Cache-Control: public, max-age=600, s-maxage=600, stale-while-revalidate=3600
/robots.txt
  Cache-Control: public, max-age=86400
/manifest.webmanifest
  Cache-Control: public, max-age=86400
